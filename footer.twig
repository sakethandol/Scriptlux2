<script src="https://www.google.com/recaptcha/api.js?hl=en"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/js-cookie/2.1.3/js.cookie.min.js"></script>

<script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>
<script>
  function submitChangePassword() {
    const errorContainer = document.getElementById('changePasswordErrors');
    const newPassword = document.getElementById('newPassword').value.trim();
    const confirmPassword = document.getElementById('confirmPassword').value.trim();

    // Clear previous errors
    errorContainer.innerHTML = '';
    errorContainer.style.display = 'none';

    // Collect errors
    let errors = [];

    // Validate password length
    if (newPassword.length === 0) {
      errors.push('Password cannot be empty.');
    } else if (newPassword.length < 8) {
      errors.push('Password must be at least 8 characters long.');
    }

    // Validate password strength
    const passwordRegex = /^(?=.*[a-zA-Z])(?=.*[0-9])/;
    if (newPassword.length > 0 && !passwordRegex.test(newPassword)) {
      errors.push('Password must contain at least one letter and one number.');
    }

    // Validate if passwords match
    if (newPassword !== confirmPassword) {
      errors.push('Passwords do not match.');
    }

    // Show errors if any
    if (errors.length > 0) {
      errorContainer.innerHTML = errors.join('<br>');
      errorContainer.style.display = 'block';
      return;
    }

    // If no errors, submit the form
    document.getElementById('changePasswordForm').submit();
  }

  // Password toggle visibility
  const toggleNewPassword = document.getElementById('toggleNewPassword');
  const newPassword = document.getElementById('newPassword');
  const toggleConfirmPassword = document.getElementById('toggleConfirmPassword');
  const confirmPassword = document.getElementById('confirmPassword');

  toggleNewPassword.addEventListener('click', () => {
    const type = newPassword.getAttribute('type') === 'password' ? 'text' : 'password';
    newPassword.setAttribute('type', type);
    toggleNewPassword.innerHTML = type === 'password' ? '<i class="fas fa-eye"></i>' : '<i class="fas fa-eye-slash"></i>';
  });

  toggleConfirmPassword.addEventListener('click', () => {
    const type = confirmPassword.getAttribute('type') === 'password' ? 'text' : 'password';
    confirmPassword.setAttribute('type', type);
    toggleConfirmPassword.innerHTML = type === 'password' ? '<i class="fas fa-eye"></i>' : '<i class="fas fa-eye-slash"></i>';
  }); 
 
  $(function () {
  $('[data-toggle="tooltip"]').tooltip()
})
  
</script>

</body></html>
