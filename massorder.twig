{% include 'header.twig' %}

<div class="min-vh-100 py-5 d-flex align-items-center" style="background-color: var(--color-bg);">
    
    <div class="container">
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.0/dist/js/bootstrap.bundle.min.js"></script>

        <div class="row justify-content-center">
            
            
            {% if contentText is not empty %}
                <div class="col-lg-11 mb-5">
                    <div class="p-4 rounded-4 shadow-sm border-start border-5" 
                         style="border-color: var(--color-accent) !important; background-color: var(--color-hover-bg);">
                        <div class="lead fs-6" style="color: var(--color-text); opacity: 0.9;">
                            {{ contentText }}
                        </div>
                    </div>
                </div>
            {% endif %}

            <div class="col-lg-11">
                
                {% if error %}
                    <div class="alert alert-danger border-0 shadow-sm mb-4 rounded-4 p-3 fade show" role="alert">
                        <div class="d-flex align-items-center">
                            <span class="fs-4 me-3">⚠️</span>
                            <div class="fw-bold">{{ errorText }}</div>
                        </div>
                    </div>
                {% endif %}

                <div class="card border-0 shadow-lg position-relative" style="border-radius: 24px; overflow: hidden;">
                    
                    <div class="opacity-75" style="height: 10px; background-color: var(--color-accent);"></div>
                    
                    <div class="card-body p-4 p-md-5 bg-white">
                        
                        <div class="mb-5">
                            <h2 class="h4 fw-bold text-uppercase mb-1" style="color: var(--color-text); letter-spacing: 1px;">
                                {{lang["massorder.title"]|default('Bulk Order')}}
                            </h2>
                            <p class="small opacity-50" style="color: var(--color-text);">Process multiple requests instantly</p>
                        </div>

                        <form method="post" id="massorder-form" action="">
                            <div class="mb-4">
                                <label for="mass_order_textarea" class="badge rounded-pill mb-3 px-3 py-2" 
                                       style="background-color: var(--color-hover-bg); color: var(--color-text); font-weight: 600;">
                                    {{lang["massorder.instruction"]}}
                                </label>
                                
                                <textarea 
                                    class="form-control form-control-lg border-2 shadow-none transition-all" 
                                    name="MassOrderForm[orders]" 
                                    rows="10" 
                                    id="mass_order_textarea" 
                                    placeholder="service_id | link | quantity"
                                    style="border-color: var(--color-border); color: var(--color-text); border-radius: 15px; background-color: #fafafa; font-family: monospace;"></textarea>
                                
                                <div class="d-flex align-items-center mt-3 p-3 rounded-3" style="background-color: var(--color-bg);">
                                    <div class="spinner-grow spinner-grow-sm me-3" role="status" style="color: var(--color-accent);"></div>
                                    <span class="small fw-medium" style="color: var(--color-text);">
                                        Format: <code style="color: var(--color-accent);">service_id | link | quantity</code>
                                    </span>
                                </div>
                            </div>

                            <div class="d-grid gap-2">
                                <input type="hidden" name="crsf_token" value="{{ csrf_token() }}">
                                <button type="submit" 
                                        class="btn btn-lg fw-bold text-uppercase py-3 shadow-sm border-0 position-relative overflow-hidden" 
                                        style="background-color: var(--color-accent); color: var(--color-accent-contrast); border-radius: 12px; letter-spacing: 2px; transition: 0.3s ease;">
                                    {{lang["massorder.submit"]}}
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <div id="massorder-result" class="mt-4"></div>
            </div>

            {% if contentTextBottom is not empty %}
                <div class="col-lg-11 mt-5">
                    <div class="card border-0 shadow-sm" style="border-radius: 15px; background-color: var(--color-hover-bg);">
                        <div class="card-body p-4 text-center" style="color: var(--color-text); opacity: 0.8;">
                            {{ contentTextBottom }}
                        </div>
                    </div>
                </div>
            {% endif %}

        </div>
    </div>
</div>

{% include 'footer.twig' %}