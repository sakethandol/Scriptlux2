{% include 'header.twig' %}

<div class="signup-page-wrapper" style="min-height: 100vh; background-color: var(--color-bg); display: flex; align-items: center; justify-content: center; padding: clamp(120px, 15vh, 150px) 0.75rem 2rem; overflow-x: hidden;">

  <div class="signup-card" style="width: 100%; max-width: 1350px; background: var(--color-bg); border-radius: 28px; border: 1.5px solid var(--color-border); box-shadow: 0 20px 60px rgba(0,0,0,0.1); overflow: hidden; display: flex; flex-wrap: wrap;">

    {# ══════════════════════════════
        Left Panel (Marketing/Visual)
        Hidden on tablets/phones (d-lg-flex)
    ══════════════════════════════ #}
    <div class="col-lg-6 d-none d-lg-flex flex-column align-items-center justify-content-center position-relative p-5" 
         style="background: var(--color-accent); min-height: 750px;">
      
      <div class="position-absolute" style="inset:0; background: radial-gradient(circle at 15% 15%, rgba(255,255,255,0.15), transparent), radial-gradient(circle at 85% 85%, rgba(0,0,0,0.1), transparent); z-index:1;"></div>
      <div class="position-absolute" style="inset:0; background-image: radial-gradient(rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 32px 32px; z-index: 1;"></div>
      
      <div class="position-relative text-center w-100" style="z-index:2; max-width: 450px;">
        {% if site["logo"] %}
          <img src="{{ site['logo'] }}" alt="Logo" class="mb-4" style="height: 65px; width:auto; filter: brightness(0) invert(1);">
        {% else %}
          <div class="fw-black mb-3 text-white" style="font-size: 2.5rem; letter-spacing: -1px;">{{ site["site_name"] }}</div>
        {% endif %}

        <h1 class="fw-black text-white mb-3" style="font-size: clamp(3rem, 4.5vw, 4rem); line-height: 0.95; letter-spacing: -3px;">
          Join Us<br>Today.
        </h1>

        <p class="text-white opacity-75 mb-5" style="font-size: 1.2rem; font-weight: 400; line-height: 1.6;">
          Unlock the power of the world's most trusted social growth platform.
        </p>
        
        {# Stats Grid #}
        <div class="row g-3 text-center mb-5">
          {% set stats = [{'v':'35K+','l':'Users'}, {'v':'99%','l':'Uptime'}, {'v':'24/7','l':'Support'}] %}
          {% for stat in stats %}
          <div class="col-4">
            <div class="p-3 rounded-4" style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.1);">
              <div class="fw-black text-white h3 mb-0">{{ stat.v }}</div>
              <div class="small text-uppercase fw-bold opacity-50" style="font-size: 0.7rem; letter-spacing: 1px;">{{ stat.l }}</div>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>

    {# ══════════════════════════════
        Right Panel (The Form)
        Full width on mobile (col-12)
    ══════════════════════════════ #}
    <div class="col-12 col-lg-6 d-flex align-items-center justify-content-center p-3 p-md-5">
      
      <div class="form-inner-box" style="width: 100%; max-width: 460px; padding: 1rem 0;">
        
        <div class="d-lg-none text-center mb-5">
          <div class="p-4 rounded-4 shadow-sm" style="background: var(--color-accent); border: 1px solid rgba(255,255,255,0.1);">
            <h3 class="text-white fw-black mb-1">{{ site['site_name'] }}</h3>
            <p class="text-white opacity-75 small mb-0 fw-medium">Join 35,000+ happy resellers</p>
          </div>
        </div>

        <div class="mb-4">
            <h2 class="fw-black mb-1" style="font-size: 2.8rem; color: var(--color-text); letter-spacing: -1.5px; line-height: 1.1;">Sign Up</h2>
            <p style="color: var(--color-text); opacity: 0.5; font-size: 1.15rem; font-weight: 500;">Create your account to get started.</p>
        </div>

        {# Alerts #}
        {% if errorText %}
        <div class="alert alert-danger rounded-4 d-flex align-items-center justify-content-between p-3 border-0 mb-4 shadow-sm" style="background:#fff1f2; color:#be123c;">
            <div class="d-flex align-items-center gap-2">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span class="fw-bold" style="font-size: 1rem;">{{ errorText }}</span>
            </div>
            <button onclick="this.parentElement.style.display='none'" style="background:none; border:none; color:inherit; cursor:pointer;"><i class="fa-solid fa-xmark"></i></button>
        </div>
        {% endif %}

        <form method="post" action="">
          {% for field in fields %}
          <div class="mb-4">
            <label for="{{ field['name'] }}" style="display:block; font-size: 0.95rem; font-weight:900; text-transform:uppercase; letter-spacing:0.07em; color:var(--color-text); opacity:0.7; margin-bottom:0.8rem;">
              {{ lang[field['field_name']] }}
            </label>
            <div class="input-group">
              <span class="input-group-text bg-light border-end-0 px-3" style="border-color:var(--color-border); color:var(--color-accent);">
                {% if field['type'] == 'email' %}<i class="fa-solid fa-envelope"></i>
                {% elseif 'password' in field['name'] %}<i class="fa-solid fa-lock"></i>
                {% else %}<i class="fa-solid fa-user"></i>{% endif %}
              </span>
              <input type="{{ field['type'] }}" class="form-control bg-light border-start-0" 
                     id="{{ field['name'] }}" name="{{ field['name'] }}" 
                     placeholder="Enter {{ lang[field['field_name']]|lower }}"
                     {% if field['required'] %}required{% endif %}
                     style="font-size: 1.1rem; font-weight: 500; padding: 0.9rem 1.1rem; border-color:var(--color-border); border-radius: 0 12px 12px 0;">
            </div>
          </div>

          {# Injects Last Name specifically after the 'name' field #}
          {% if field['name'] == "name" %}
          <div class="mb-4">
            <label for="last_name" style="display:block; font-size: 0.95rem; font-weight:900; text-transform:uppercase; letter-spacing:0.07em; color:var(--color-text); opacity:0.7; margin-bottom:0.8rem;">
              {{ lang["signup.last.name"] }}
            </label>
            <div class="input-group">
              <span class="input-group-text bg-light border-end-0 px-3" style="border-color:var(--color-border); color:var(--color-accent);">
                <i class="fa-solid fa-user"></i>
              </span>
              <input type="text" class="form-control bg-light border-start-0" id="last_name" name="last_name" required
                     style="font-size: 1.1rem; font-weight: 500; padding: 0.9rem 1.1rem; border-color:var(--color-border); border-radius: 0 12px 12px 0;">
            </div>
          </div>
          {% endif %}
          {% endfor %}

          {# Terms Checkbox #}
          <div class="form-check mb-4 p-3 rounded-4" style="background: var(--color-hover-bg); border: 1.2px solid var(--color-border);">
            <input class="form-check-input ms-0 me-3" type="checkbox" name="terms" value="1" id="termsCheck" required style="width: 1.3rem; height: 1.3rem; cursor:pointer;">
            <label class="form-check-label fw-bold" for="termsCheck" style="font-size: 1rem; opacity: 0.9; cursor:pointer; color: var(--color-text);">
              {{ lang['signup.accept_terms_text'] }}
            </label>
          </div>

          {# Captcha Support #}
          {% if captcha %}
          <div class="mb-4 d-flex justify-content-center">
            <div class="g-recaptcha" data-sitekey="{{ captchaKey }}"></div>
          </div>
          {% endif %}

          <input type="hidden" name="crsf_token" value="{{ csrf_token() }}">

          <button type="submit" class="btn-signup-submit w-100" 
                  style="background: var(--color-accent); color: white; padding: 1.1rem; border-radius: 18px; border: none; font-weight: 900; font-size: 1.2rem; box-shadow: 0 12px 30px rgba(var(--color-accent-rgb), 0.3); cursor: pointer; transition: all 0.3s ease; display: flex; align-items: center; justify-content: center; gap: 10px;">
            <span>{{ lang['signup.button'] }}</span>
            <i class="fa-solid fa-arrow-right"></i>
          </button>
        </form>

        {# Footer Redirect #}
        <div class="text-center mt-5 pt-4" style="border-top: 2px solid var(--color-border);">
            <p class="mb-0" style="color:var(--color-text); opacity:0.6; font-size: 1.1rem; font-weight: 500;">
                Already a member? <a href="/" style="color:var(--color-accent); font-weight:900; text-decoration:none; margin-left: 6px;">Sign In Now</a>
            </p>
        </div>

      </div>
    </div>
  </div>
</div>

{% include 'footer.twig' %}