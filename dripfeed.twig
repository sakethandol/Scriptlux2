{% include 'header.twig' %}

<style>
  html { scroll-behavior: smooth; }
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .drip-table tbody tr { transition: background 0.15s ease; }
  .drip-table tbody tr:hover { background-color: var(--color-hover-bg) !important; }
  .page-link { transition: all 0.18s ease; }
  .status-filter-btn {
    transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
  }
  .status-filter-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 22px var(--color-border) !important;
    filter: saturate(1.08);
  }
  .status-filter-btn:focus-visible {
    transform: translateY(-1px);
    box-shadow: 0 0 0 0.2rem var(--color-border), 0 8px 18px var(--color-border) !important;
  }
  .status-pill { display:inline-block; font-size:0.7rem; font-weight:600;
                 letter-spacing:0.5px; padding:4px 12px; border-radius:50px; }
  .link-cell { max-width:180px; overflow:hidden; text-overflow:ellipsis;
               white-space:nowrap; display:block; }
  @media (max-width: 576px) { .hero-title { font-size: 1.3rem; } }
</style>

<div class="min-vh-100 pb-5" style="background-color:var(--color-bg); color:var(--color-text);">

  <div class="py-4 mb-2" style="background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-text) 100%);">
    <div class="container-fluid px-3 px-md-5">
      <div class="row align-items-center g-3">

        <div class="col-12 col-md-5">
          <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center justify-content-center rounded-3 shadow"
                 style="width:48px;height:48px;background:var(--color-border);">
              <i class="fas fa-tint" style="color:var(--color-accent-contrast);font-size:1.25rem;"></i>
            </div>
            <div>
              <h1 class="hero-title fw-bold mb-0" style="color:var(--color-accent-contrast);letter-spacing:-0.5px;">
                Drip Feed
              </h1>
              <p class="mb-0 small" style="color:var(--color-accent-contrast);opacity:0.75;">
                Manage your scheduled drip feed orders
              </p>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-7">
          <form action="" method="get">
            <div class="input-group shadow" style="border-radius:50px;overflow:hidden;">
              <span class="input-group-text border-0 px-3" style="background:var(--color-bg);">
                <i class="fa fa-search" style="color:var(--color-accent);opacity:0.6;"></i>
              </span>
              <input type="text" name="search"
                     class="form-control border-0 shadow-none py-2"
                     value="{{ search }}"
                     placeholder="Search drip feeds..."
                     style="background:var(--color-bg);color:var(--color-text);font-size:0.9rem;">
              <button type="submit" class="btn border-0 px-4 fw-bold"
                      style="background-color:var(--color-accent-contrast);color:var(--color-accent);font-size:0.85rem;border-radius:0 50px 50px 0;">
                <i class="fa fa-search me-1"></i> Search
              </button>
            </div>
          </form>
        </div>

      </div>
    </div>
  </div>

  <div class="container-fluid px-3 px-md-5 mt-4">
    {% if contentText is not empty %}
      <div class="alert border-0 rounded-4 mb-4 p-4 shadow-sm"
           style="background:var(--color-hover-bg);color:var(--color-text);border-left:4px solid var(--color-accent) !important;">
        <div class="d-flex align-items-start gap-3">
          <i class="fas fa-info-circle mt-1" style="color:var(--color-accent);opacity:0.6;"></i>
          <div>{{ contentText }}</div>
        </div>
      </div>
    {% endif %}
    <div class="d-flex overflow-auto no-scrollbar gap-2 pb-4 mb-6" style="white-space:nowrap;">
      {% set all_color = 'var(--color-text)' %}
      {% set active_color = 'var(--color-accent)' %}
      {% set canceled_color = 'var(--color-accent)' %}
      {% set completed_color = 'var(--color-accent)' %}
      {% set all_bg = 'var(--color-hover-bg)' %}
      {% set active_bg = 'var(--color-hover-bg)' %}
      {% set canceled_bg = 'var(--color-hover-bg)' %}
      {% set completed_bg = 'var(--color-hover-bg)' %}
      {% set all_bg_soft = 'var(--color-bg)' %}
      {% set active_bg_soft = 'var(--color-bg)' %}
      {% set canceled_bg_soft = 'var(--color-bg)' %}
      {% set completed_bg_soft = 'var(--color-bg)' %}

      <a href="dripfeed"
         class="btn btn-sm status-filter-btn fw-semibold px-4 py-2 rounded-pill border-0 shadow-sm flex-shrink-0"
        style="{% if 'all' == status %}background-color:{{ all_bg }};color:{{ all_color }};border:1.5px solid {{ all_color }} !important;{% else %}background:{{ all_bg_soft }};color:{{ all_color }};border:1.5px solid {{ all_color }} !important;{% endif %}font-size:0.78rem;">
        {{ lang['dripfeed.status.all'] }}
      </a>
      <a href="dripfeed/active"
         class="btn btn-sm status-filter-btn fw-semibold px-4 py-2 rounded-pill border-0 shadow-sm flex-shrink-0"
        style="{% if 'active' == status %}background-color:{{ active_bg }};color:{{ active_color }};border:1.5px solid {{ active_color }} !important;{% else %}background:{{ active_bg_soft }};color:{{ active_color }};border:1.5px solid {{ active_color }} !important;{% endif %}font-size:0.78rem;">
        {{ lang['dripfeed.status.active'] }}
      </a>
      <a href="dripfeed/canceled"
         class="btn btn-sm status-filter-btn fw-semibold px-4 py-2 rounded-pill border-0 shadow-sm flex-shrink-0"
        style="{% if 'canceled' == status %}background-color:{{ canceled_bg }};color:{{ canceled_color }};border:1.5px solid {{ canceled_color }} !important;{% else %}background:{{ canceled_bg_soft }};color:{{ canceled_color }};border:1.5px solid {{ canceled_color }} !important;{% endif %}font-size:0.78rem;">
        {{ lang['dripfeed.status.canceled'] }}
      </a>
      <a href="dripfeed/completed"
         class="btn btn-sm status-filter-btn fw-semibold px-4 py-2 rounded-pill border-0 shadow-sm flex-shrink-0"
        style="{% if 'completed' == status %}background-color:{{ completed_bg }};color:{{ completed_color }};border:1.5px solid {{ completed_color }} !important;{% else %}background:{{ completed_bg_soft }};color:{{ completed_color }};border:1.5px solid {{ completed_color }} !important;{% endif %}font-size:0.78rem;">
        {{ lang['dripfeed.status.completed'] }}
      </a>
    </div>
    <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table drip-table mb-0 align-middle">

            <thead>
              <tr style="background:var(--color-accent);">
                {% set headers = [
                  lang['dripfeed.id'],
                  lang['dripfeed.date'],
                  lang['dripfeed.link'],
                  lang['dripfeed.total_charges'],
                  lang['dripfeed.quantity'],
                  lang['dripfeed.service'],
                  lang['dripfeed.runs'],
                  lang['dripfeed.interval'],
                  lang['dripfeed.total_quantity'],
                  lang['dripfeed.status']
                ] %}
                {% for h in headers %}
                  <th class="fw-semibold px-3 py-3 border-0"
                      style="color:var(--color-accent-contrast);font-size:0.72rem;letter-spacing:0.6px;
                             text-transform:uppercase;white-space:nowrap;">
                    {{ h }}
                  </th>
                {% endfor %}
              </tr>
            </thead>

            <tbody>
              {% for dripFeed in orders %}
                <tr style="border-bottom:1px solid var(--color-border);">

                  <!-- ID -->
                  <td class="px-3 py-3">
                    <span class="fw-bold rounded-2 px-2 py-1"
                          style="background:var(--color-hover-bg);color:var(--color-text);font-size:0.75rem;">
                      #{{ dripFeed['id'] }}
                    </span>
                  </td>

                  <!-- Date -->
                  <td class="px-3 py-3">
                    <span class="small" style="color:var(--color-text);opacity:0.65;font-size:0.8rem;white-space:nowrap;">
                      {{ show_date(dripFeed['date']) }}
                    </span>
                  </td>

                  <td class="px-3 py-3" style="max-width:200px;">
                    <span class="link-cell small d-flex align-items-center gap-1"
                          style="color:var(--color-text);opacity:0.75;font-size:0.78rem;" title="{{ dripFeed['link'] }}">
                      <i class="fas fa-link" style="font-size:0.6rem;flex-shrink:0;opacity:0.5;"></i>
                      <span class="text-truncate">{{ dripFeed['link'] }}</span>
                    </span>
                  </td>
                  <td class="px-3 py-3">
                    <span class="fw-semibold" style="font-size:0.85rem;">
                      {{ dripFeed['total_charges'] }}
                    </span>
                  </td>

                  <!-- Quantity -->
                  <td class="px-3 py-3">
                    <span class="fw-semibold" style="font-size:0.85rem;white-space:nowrap;">
                      {{ dripFeed['quantity'] }}
                    </span>
                  </td>
                  <td class="px-3 py-3" style="max-width:200px;">
                    <span class="d-block text-truncate small fw-semibold"
                          style="max-width:180px;font-size:0.82rem;" title="{{ dripFeed['service'] }}">
                      {{ dripFeed['service'] }}
                    </span>
                  </td>
                  <td class="px-3 py-3">
                    <span class="fw-semibold" style="font-size:0.85rem;white-space:nowrap;">
                      {% if dripFeed['delivery'] %}
                        <a href="{{site["url"]}}/orders?dripfeed={{ dripFeed['id'] }}"
                          class="text-decoration-none fw-bold" style="color:var(--color-accent);">
                          {{ dripFeed['delivery'] }}
                        </a>
                        <span style="opacity:0.4;">/</span>
                        {{ dripFeed['runs'] }}
                      {% else %}
                        {{ dripFeed['delivery'] }}
                        <span style="opacity:0.4;">/</span>
                        {{ dripFeed['runs'] }}
                      {% endif %}
                    </span>
                  </td>

                  <!-- Interval -->
                  <td class="px-3 py-3">
                    <span class="small" style="font-size:0.82rem;">{{ dripFeed['interval'] }}</span>
                  </td>
                  <td class="px-3 py-3">
                    <span class="fw-semibold" style="font-size:0.85rem;">{{ dripFeed['total_quantity'] }}</span>
                  </td>
                  <td class="px-3 py-3 text-center">
                    {% set s = dripFeed['status']|lower %}
                    {% if s == 'active' %}
                      <span class="status-pill" style="background:var(--color-hover-bg);color:var(--color-accent);border:1px solid var(--color-border);">
                        <i class="fas fa-circle-notch fa-spin me-1" style="font-size:0.6rem;"></i>
                        {{ dripFeed['status'] }}
                      </span>
                    {% elseif s == 'completed' %}
                      <span class="status-pill" style="background:var(--color-hover-bg);color:var(--color-accent);border:1px solid var(--color-border);">
                        <i class="fas fa-check-circle me-1" style="font-size:0.6rem;"></i>
                        {{ dripFeed['status'] }}
                      </span>
                    {% elseif s == 'canceled' %}
                      <span class="status-pill" style="background:var(--color-hover-bg);color:var(--color-accent);border:1px solid var(--color-border);">
                        <i class="fas fa-times-circle me-1" style="font-size:0.6rem;"></i>
                        {{ dripFeed['status'] }}
                      </span>
                    {% else %}
                      <span class="status-pill" style="background:var(--color-hover-bg);color:var(--color-accent);border:1px solid var(--color-border);">
                        <i class="fas fa-dot-circle me-1" style="font-size:0.6rem;"></i>
                        {{ dripFeed['status'] }}
                      </span>
                    {% endif %}
                  </td>

                </tr>
              {% endfor %}
              {% if orders is empty %}
                <tr>
                  <td colspan="10" class="text-center py-5">
                    <div class="mb-3 mx-auto d-flex align-items-center justify-content-center rounded-circle"
                         style="width:64px;height:64px;background:var(--color-hover-bg);">
                      <i class="fas fa-tint-slash" style="font-size:1.5rem;color:var(--color-accent);opacity:0.35;"></i>
                    </div>
                    <p class="fw-bold mb-1" style="color:var(--color-text);">No drip feeds found</p>
                    <p class="small mb-0" style="opacity:0.45;">Try a different filter or search term.</p>
                  </td>
                </tr>
              {% endif %}

            </tbody>
          </table>
        </div>
      </div>
    </div>
    {% if pagination["count"] > 1 %}
    <nav class="mt-4" aria-label="Drip feed pagination">
      <ul class="pagination justify-content-center flex-wrap gap-2 mb-0">

        {% if pagination["current"] != 1 %}
          <li class="page-item">
            <a class="page-link border-0 rounded-circle shadow-sm d-flex align-items-center justify-content-center fw-bold"
               href="dripfeed/{{ status }}/{{ pagination["previous"] }}{% if search %}?search={{ search }}{% endif %}"
               aria-label="Previous"
               style="width:40px;height:40px;background:var(--color-bg);color:var(--color-text);">
              <i class="fas fa-chevron-left" style="font-size:0.7rem;"></i>
            </a>
          </li>
        {% endif %}

        {% set r, l = 3, 3 %}
        {% if pagination['current'] == 1 %}{% set r = 7 %}{% endif %}
        {% if pagination['current'] == 2 %}{% set r = 5 %}{% endif %}
        {% if pagination['current'] >= pagination['count'] %}{% set l = 5 %}{% endif %}

        {% for page in 1..pagination["count"] %}
          {% if page >= (pagination['current']-l) and page <= (pagination['current']+r) %}
            <li class="page-item">
              <a class="page-link border-0 rounded-circle shadow-sm d-flex align-items-center justify-content-center fw-bold"
                 href="dripfeed/{{ status }}/{{ page }}{% if search %}?search={{ search }}{% endif %}"
                 style="width:40px;height:40px;font-size:0.85rem;
                        {% if page == pagination['current'] %}
                          background-color:var(--color-accent);color:var(--color-accent-contrast);
                        {% else %}
                          background:var(--color-bg);color:var(--color-text);
                        {% endif %}">
                {{ page }}
              </a>
            </li>
          {% endif %}
        {% endfor %}

        {% if pagination['current'] < pagination['count'] %}
          <li class="page-item">
            <a class="page-link border-0 rounded-circle shadow-sm d-flex align-items-center justify-content-center fw-bold"
               href="dripfeed/{{ status }}/{{ pagination['next'] }}{% if search %}?search={{ search }}{% endif %}"
               aria-label="Next"
               style="width:40px;height:40px;background:var(--color-bg);color:var(--color-text);">
              <i class="fas fa-chevron-right" style="font-size:0.7rem;"></i>
            </a>
          </li>
        {% endif %}

      </ul>
    </nav>
    {% endif %}

    {% if contentTextBottom is not empty %}
      <div class="alert border-0 rounded-4 mt-4 p-4 shadow-sm"
           style="background:var(--color-hover-bg);color:var(--color-text);border-left:4px solid var(--color-accent) !important;">
        <div class="d-flex align-items-start gap-3">
          <i class="fas fa-info-circle mt-1" style="color:var(--color-accent);opacity:0.6;"></i>
          <div>{{ contentTextBottom }}</div>
        </div>
      </div>
    {% endif %}

  </div>
</div>

{% include 'footer.twig' %}