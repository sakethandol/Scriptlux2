{% include 'header.twig' %}

<style>
  html { scroll-behavior: smooth; }
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .refill-table tbody tr { transition: background 0.15s ease; }
  .refill-table tbody tr:hover { background-color: var(--color-hover-bg) !important; }
  .page-link { transition: all 0.18s ease; }
  .status-pill { display:inline-block; font-size:0.7rem; font-weight:600; letter-spacing:0.5px;
                 padding:4px 12px; border-radius:50px; }
  @media (max-width: 576px) {
    .hero-title { font-size: 1.3rem; }
  }
</style>

<div class="min-vh-100 pb-5" style="background-color: var(--color-bg); color: var(--color-text);">
  <div class="py-4 mb-2" style="background: linear-gradient(135deg, var(--color-accent) 0%, #1e3d2b 100%);">
    <div class="container-fluid px-3 px-md-5">
      <div class="row align-items-center g-3">

        <!-- Title -->
        <div class="col-12 col-md-5">
          <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center justify-content-center rounded-3 shadow"
                 style="width:48px;height:48px;background:rgba(255,252,237,0.12);">
              <i class="fas fa-sync-alt" style="color:var(--color-accent-contrast);font-size:1.25rem;"></i>
            </div>
            <div>
              <h1 class="hero-title fw-bold mb-0" style="color:var(--color-accent-contrast);letter-spacing:-0.5px;">
                My Refills
              </h1>
              <p class="mb-0 small" style="color:rgba(255,252,237,0.65);">
                Track all your refill requests
              </p>
            </div>
          </div>
        </div>

        <!-- Search -->
        <div class="col-12 col-md-7">
          <form action="" method="get">
            <div class="input-group shadow" style="border-radius:50px;overflow:hidden;">
              <span class="input-group-text border-0 px-3" style="background:#fff;">
                <i class="fa fa-search" style="color:var(--color-accent);opacity:0.6;"></i>
              </span>
              <input type="text" name="search"
                     class="form-control border-0 shadow-none py-2"
                     value="{{ search }}"
                     placeholder="Search refills by ID or order..."
                     style="background:#fff;color:#14281D;font-size:0.9rem;">
              <button type="submit" class="btn border-0 px-4 fw-bold"
                      style="background-color:var(--color-accent-contrast);color:var(--color-accent);
                             font-size:0.85rem;border-radius:0 50px 50px 0;">
                <i class="fa fa-search me-1"></i> Search
              </button>
            </div>
          </form>
        </div>

      </div>
    </div>
  </div>

  <div class="container-fluid px-3 px-md-5 mt-4">
    {% if contentText is not empty %}
      <div class="alert border-0 rounded-4 mb-4 p-4 shadow-sm"
           style="background:var(--color-hover-bg);color:var(--color-text);border-left:4px solid var(--color-accent) !important;">
        <div class="d-flex align-items-start gap-3">
          <i class="fas fa-info-circle mt-1" style="color:var(--color-accent);opacity:0.7;"></i>
          <div>{{ contentText }}</div>
        </div>
      </div>
    {% endif %}
    <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table refill-table mb-0 align-middle">
            <thead>
              <tr style="background:var(--color-accent);">
                <th class="fw-semibold px-4 py-3 border-0"
                    style="color:var(--color-accent-contrast);font-size:0.75rem;letter-spacing:0.6px;text-transform:uppercase;white-space:nowrap;">
                  {{lang["refill.table.id"]}}
                </th>
                <th class="fw-semibold px-3 py-3 border-0"
                    style="color:var(--color-accent-contrast);font-size:0.75rem;letter-spacing:0.6px;text-transform:uppercase;white-space:nowrap;">
                  {{lang["refill.table.order"]}}
                </th>
                <th class="fw-semibold px-3 py-3 border-0"
                    style="color:var(--color-accent-contrast);font-size:0.75rem;letter-spacing:0.6px;text-transform:uppercase;white-space:nowrap;">
                  {{lang["refill.table.link"]}}
                </th>
                <th class="fw-semibold px-3 py-3 border-0"
                    style="color:var(--color-accent-contrast);font-size:0.75rem;letter-spacing:0.6px;text-transform:uppercase;white-space:nowrap;">
                  {{lang["refill.table.start.count"]}}
                </th>
                <th class="fw-semibold px-3 py-3 border-0"
                    style="color:var(--color-accent-contrast);font-size:0.75rem;letter-spacing:0.6px;text-transform:uppercase;white-space:nowrap;">
                  {{lang["refill.table.quantity"]}}
                </th>
                <th class="fw-semibold px-3 py-3 border-0"
                    style="color:var(--color-accent-contrast);font-size:0.75rem;letter-spacing:0.6px;text-transform:uppercase;white-space:nowrap;">
                  {{lang["refill.table.date"]}}
                </th>
                <th class="fw-semibold px-3 py-3 border-0 text-center"
                    style="color:var(--color-accent-contrast);font-size:0.75rem;letter-spacing:0.6px;text-transform:uppercase;white-space:nowrap;">
                  {{lang["refill.table.status"]}}
                </th>
              </tr>
            </thead>
            <tbody>
              {% for order in orders %}
                <tr style="border-bottom:1px solid var(--color-border);">

                  <!-- ID -->
                  <td class="px-4 py-3">
                    <span class="fw-bold rounded-2 px-2 py-1"
                          style="background:var(--color-hover-bg);color:var(--color-accent);font-size:0.78rem;">
                      #{{ order['task_id'] }}
                    </span>
                  </td>

                  <!-- Order -->
                  <td class="px-3 py-3">
                    <a href="{{site['url']}}/orders/?search={{order['order_id']}}"
                       class="fw-semibold text-decoration-none"
                       style="color:var(--color-accent);font-size:0.85rem;">
                      {{ order['order_id'] }}
                    </a>
                  </td>

                  <!-- Link -->
                  <td class="px-3 py-3" style="max-width:200px;">
                    <a target="_blank" href="{{ order['order_link'] }}"
                       class="text-decoration-none d-flex align-items-center gap-1 text-truncate"
                       style="color:var(--color-accent);font-size:0.8rem;max-width:180px;">
                      <i class="fas fa-external-link-alt" style="font-size:0.6rem;flex-shrink:0;opacity:0.6;"></i>
                      <span class="text-truncate">{{ order['order_link'] }}</span>
                    </a>
                  </td>

                  <!-- Start Count -->
                  <td class="px-3 py-3">
                    <span class="fw-semibold" style="font-size:0.85rem;">{{ order['order_start'] }}</span>
                  </td>

                  <!-- Quantity -->
                  <td class="px-3 py-3">
                    <span class="fw-semibold" style="font-size:0.85rem;">{{ order['order_quantity'] }}</span>
                  </td>

                  <!-- Date -->
                  <td class="px-3 py-3">
                    <span class="small" style="color:var(--color-text);opacity:0.7;font-size:0.8rem;white-space:nowrap;">
                      {{ show_date(order['createdAtFormatted']) }}
                    </span>
                  </td>

                  <!-- Status -->
                  <td class="px-3 py-3 text-center">
                    {% if order['task_status'] == " completed" %}
                      <span class="status-pill" style="background:rgba(25,135,84,0.12);color:#198754;">
                        <i class="fas fa-check-circle me-1" style="font-size:0.65rem;"></i>
                        {{ order['task_status']|capitalize }}
                      </span>
                    {% elseif order['task_status'] == " inprogress" %}
                      <span class="status-pill" style="background:rgba(2,132,199,0.12);color:#0284c7;">
                        <i class="fas fa-spinner me-1" style="font-size:0.65rem;"></i>
                        {{ order['task_status']|capitalize }}
                      </span>
                    {% elseif order['task_status'] == " pending" %}
                      <span class="status-pill" style="background:rgba(217,119,6,0.12);color:#d97706;">
                        <i class="fas fa-clock me-1" style="font-size:0.65rem;"></i>
                        {{ order['task_status']|capitalize }}
                      </span>
                    {% elseif order['task_status'] == " error" %}
                      <span class="status-pill" style="background:rgba(220,53,69,0.12);color:#dc3545;">
                        <i class="fas fa-exclamation-circle me-1" style="font-size:0.65rem;"></i>
                        {{ order['task_status']|capitalize }}
                      </span>
                    {% else %}
                      <span class="status-pill" style="background:rgba(108,117,125,0.12);color:#6c757d;">
                        <i class="fas fa-dot-circle me-1" style="font-size:0.65rem;"></i>
                        {{ order['task_status']|capitalize }}
                      </span>
                    {% endif %}
                  </td>

                </tr>
              {% endfor %}

              <!-- Empty State Row -->
              {% if orders is empty %}
                <tr>
                  <td colspan="7" class="text-center py-5">
                    <div class="mb-3 mx-auto d-flex align-items-center justify-content-center rounded-circle"
                         style="width:64px;height:64px;background:var(--color-hover-bg);">
                      <i class="fas fa-inbox" style="font-size:1.5rem;color:var(--color-accent);opacity:0.4;"></i>
                    </div>
                    <p class="fw-bold mb-1" style="color:var(--color-text);">No refills found</p>
                    <p class="small mb-0" style="opacity:0.5;">Try a different search term.</p>
                  </td>
                </tr>
              {% endif %}

            </tbody>
          </table>
        </div>
      </div>
    </div>

    {% if pagination["count"] > 1 %}
    <nav class="mt-4" aria-label="Refill pagination">
      <ul class="pagination justify-content-center flex-wrap gap-2 mb-0">

        {% if pagination["current"] == 1 %}
          <li class="page-item">
            <a class="page-link border-0 rounded-circle shadow-sm d-flex align-items-center justify-content-center fw-bold"
               href="refill/{{ status }}/{{ pagination["previous"] }}{% if search %}?search={{ search }}{% endif %}"
               aria-label="Previous"
               style="width:40px;height:40px;background:#fff;color:var(--color-text);">
              <i class="fas fa-chevron-left" style="font-size:0.7rem;"></i>
            </a>
          </li>
        {% endif %}

        {% set r, l = 3, 3 %}
        {% if pagination['current'] == 1 %}{% set r = 7 %}{% endif %}
        {% if pagination['current'] == 2 %}{% set r = 5 %}{% endif %}
        {% if pagination['current'] >= pagination['count'] %}{% set l = 5 %}{% endif %}

        {% for page in 1..pagination["count"] %}
          {% if page >= (pagination['current']-l) and page <= (pagination['current']+r) %}
            <li class="page-item">
              <a class="page-link border-0 rounded-circle shadow-sm d-flex align-items-center justify-content-center fw-bold"
                 href="refill/{{ status }}/{{ page }}{% if search %}?search={{ search }}{% endif %}"
                 style="width:40px;height:40px;font-size:0.85rem;
                        {% if page == pagination['current'] %}
                          background-color:var(--color-accent);color:var(--color-accent-contrast);
                        {% else %}
                          background:#fff;color:var(--color-text);
                        {% endif %}">
                {{ page }}
              </a>
            </li>
          {% endif %}
        {% endfor %}

        {% if pagination['current'] < pagination['count'] %}
          <li class="page-item">
            <a class="page-link border-0 rounded-circle shadow-sm d-flex align-items-center justify-content-center fw-bold"
               href="refill/{{ status }}/{{ pagination['next'] }}{% if search %}?search={{ search }}{% endif %}"
               aria-label="Next"
               style="width:40px;height:40px;background:#fff;color:var(--color-text);">
              <i class="fas fa-chevron-right" style="font-size:0.7rem;"></i>
            </a>
          </li>
        {% endif %}

      </ul>
    </nav>
    {% endif %}
    {% if contentTextBottom is not empty %}
      <div class="alert border-0 rounded-4 mt-4 p-4 shadow-sm"
           style="background:var(--color-hover-bg);color:var(--color-text);border-left:4px solid var(--color-accent) !important;">
        <div class="d-flex align-items-start gap-3">
          <i class="fas fa-info-circle mt-1" style="color:var(--color-accent);opacity:0.7;"></i>
          <div>{{ contentTextBottom }}</div>
        </div>
      </div>
    {% endif %}

  </div>
</div>

{% include 'footer.twig' %}