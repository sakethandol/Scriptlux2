{% include 'header.twig' %}

<div class="terms-wrapper section-hunter-cream" style="min-height: 100vh; padding: clamp(120px, 12vh, 120px) 0 5rem;">

    <div class="container-fluid" style="max-width: 1350px;">
        <div class="row mb-5">
            <div class="col-12 text-center">
                <div class="badge rounded-pill mb-3" style="background: rgba(var(--color-accent-rgb), 0.1); color: var(--color-accent-contrast); padding: 0.6rem 1.2rem; font-weight: 800; letter-spacing: 1px;">
                    LEGAL INFORMATION
                </div>
                <h1 class="fw-black mb-2" style="font-size: clamp(2.5rem, 5vw, 3.8rem); color: var(--color-accent-contrast); letter-spacing: -2px;">Terms of Service</h1>
                <p class="opacity-50 fw-medium" style="font-size: 1.1rem; color: var(--color-accent-contrast);">
                    Please read these terms carefully before using our services.
                </p>
            </div>
        </div>

        <div class="row g-4">

            <div class="col-lg-12">
                <div class="terms-card" style="background: var(--color-bg); border: 1.5px solid var(--color-border); border-radius: 32px; box-shadow: 0 20px 50px rgba(0,0,0,0.05); overflow: hidden;">
                    
                    {% if contentText is not empty %}
                    <div class="p-4 p-md-5 border-bottom" style="border-color: var(--color-border) !important;">
                        <div class="terms-body">
                            {{ contentText }}
                        </div>
                    </div>
                    {% endif %}
                    {% if contentTextBottom is not empty %}
                    <div class="p-4 p-md-5" style="background: var(--color-hover-bg);">
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <i class="fa-solid fa-scale-balanced text-accent" style="color: var(--color-accent-contrast); font-size: 1.5rem;"></i>
                            <h3 class="fw-black mb-0" style="letter-spacing: -1px;">Additional Clauses</h3>
                        </div>
                        <div class="terms-body">
                            {{ contentTextBottom }}
                        </div>
                    </div>
                    {% endif %}
                    <div class="p-4 text-center border-top" style="border-color: var(--color-border) !important; background: var(--color-bg);">
                        <p class="small opacity-50 mb-3 font-italic">By continuing to use our platform, you acknowledge that you have read and understood these terms.</p>
                        <div class="d-flex flex-wrap justify-content-center gap-3">
                            <button onclick="window.print()" class="btn fw-bold px-4 py-2 rounded-pill" style="border: 1.5px solid var(--color-border); color: white;">
                                <i class="fa-solid fa-print me-2"></i> Print Terms
                            </button>
                            <a href="mailto:support@{{ site['site_name']|lower }}.com" class="btn fw-bold px-4 py-2 rounded-pill" style="background: var(--color-accent); color: white;">
                                <i class="fa-solid fa-envelope me-2"></i> Contact Legal
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
	
    .terms-body {
        color: var(--color-text);
        line-height: 1.8;
        font-size: 1.1rem;
    }

    .terms-body h1, .terms-body h2, .terms-body h3 {
        color: var(--color-text);
        font-weight: 900;
        margin-top: 2.5rem;
        margin-bottom: 1.2rem;
        letter-spacing: -0.5px;
    }

    .terms-body h1:first-child, 
    .terms-body h2:first-child {
        margin-top: 0;
    }

    .terms-body p {
        margin-bottom: 1.5rem;
        opacity: 0.8;
    }

    .terms-body ul, .terms-body ol {
        margin-bottom: 2rem;
        padding-left: 1.2rem;
    }

    .terms-body li {
        margin-bottom: 0.8rem;
        padding-left: 0.5rem;
    }

    .terms-body strong, .terms-body b {
        color: var(--color-text);
        font-weight: 800;
    }

    @media (max-width: 991px) {
        .terms-card {
            border-radius: 0 !important;
            border-left: none !important;
            border-right: none !important;
        }
        .terms-wrapper {
            padding-top: 100px !important;
        }
    }
</style>
<style>
    .section-hunter-cream {
        background-color: var(--color-accent);
        background-image:
            radial-gradient(at 0% 0%, rgba(255, 252, 222, 0.18) 0px, transparent 55%),
            radial-gradient(at 100% 100%, rgba(255, 252, 222, 0.14) 0px, transparent 55%),
            radial-gradient(at 0% 100%, rgba(255, 252, 222, 0.08) 0px, transparent 45%),
            radial-gradient(at 100% 0%, rgba(255, 252, 222, 0.06) 0px, transparent 45%),
            radial-gradient(at 50% 50%, rgba(255, 252, 222, 0.12) 0px, transparent 75%),
            linear-gradient(
                152deg,
                rgba(255, 252, 222, 0.06) 0%,
                rgba(255, 252, 222, 0.00) 40%,
                rgba(255, 252, 222, 0.04) 100%
            );
        background-attachment: fixed;
        position: relative;
        isolation: isolate;
        overflow: hidden;
    }

    .section-hunter-cream::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0.5;
        background-image:
            radial-gradient(circle, rgba(255, 252, 222, 0.12) 1px, transparent 1px),
            radial-gradient(circle, rgba(255, 252, 222, 0.05) 1.5px, transparent 1.5px);
        background-size: 28px 28px, 56px 56px;
        background-position: 0 0, 14px 14px;
        z-index: 0;
    }

    .terms-wrapper > * {
        position: relative;
        z-index: 1;
    }

    .terms-body h1, .terms-body h2, .terms-body h3 {
        color: var(--color-text);
        font-weight: 900;
        margin-top: 3rem;
        margin-bottom: 1.5rem;
        letter-spacing: -1px;
        line-height: 1.2;
    }

    .terms-body p {
        margin-bottom: 1.8rem;
        opacity: 0.85;
    }
    .terms-body strong, .terms-body b {
        color: var(--color-accent);
        font-weight: 800;
    }

    .terms-body ul {
        list-style: none;
        padding-left: 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 15px;
        margin: 2rem 0;
    }

    .terms-body li {
        padding: 15px 20px;
        background: var(--color-hover-bg);
        border-radius: 16px;
        border: 1px solid var(--color-border);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .terms-body li::before {
        content: "\f00c"; /* FontAwesome Check */
        font-family: "Font Awesome 6 Free";
        font-weight: 900;
        color: var(--color-accent);
    }

    .back-to-top { transition: transform 0.3s ease; }
    .back-to-top:hover { transform: translateY(-5px); }
    @media (max-width: 991px) {
        .terms-card {
            border-radius: 24px !important;
            border-left: 1.5px solid var(--color-border) !important;
            border-right: 1.5px solid var(--color-border) !important;
            box-shadow: 0 18px 40px -24px rgba(0, 0, 0, 0.35) !important;
        }
        .terms-wrapper {
            padding: 100px 0.9rem 3rem !important;
        }
        .terms-body {
            font-size: 1.1rem !important;
        }

        .section-hunter-cream {
            background-attachment: scroll;
        }
    }

    @media (max-width: 767px) {
        .terms-wrapper {
            padding: 92px 0.75rem 2.25rem !important;
        }

        .terms-card {
            border-radius: 20px !important;
        }

        .terms-body ul {
            grid-template-columns: 1fr;
        }

        .terms-card .btn {
            width: 100%;
        }
    }
</style>

{% include 'footer.twig' %}