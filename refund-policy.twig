{% include 'header.twig' %}

{# Unified Black Background Wrapper #}
<div class="bg-black min-h-screen transition-all duration-300">

{% if user['auth'] %}
    <div class="lg:ml-64 px-4 md:px-8 lg:px-10 pt-24 pb-20">
        <div class="max-w-[1400px] mx-auto">
            
            <div class="mb-8">
                <h1 class="text-3xl text-white tracking-tight">{{ site["site_name"] }} Terms & Conditions</h1>
                <p class="text-zinc-500 text-sm mt-1">Authorized Access Only</p>
            </div>

            <div class="relative group">
                <div class="absolute -inset-0.5 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-2xl blur opacity-20 group-hover:opacity-40 transition duration-700"></div>
                <div class="relative bg-zinc-900/80 backdrop-blur-md border border-zinc-800 rounded-2xl overflow-hidden shadow-2xl">
                    <div class="p-8">
                        <div class="prose prose-invert max-w-none text-zinc-300">
                            {{ contentText|raw }}
                            {% if contentText is empty %}
                                <p>Welcome to your secure area. Everything is running smoothly today.</p>
                            {% endif %}
                        </div>
                    </div>
                    
                    {% if contentTextBottom is not empty %}
                    <div class="bg-black/40 border-t border-zinc-800 px-8 py-4 text-xs text-zinc-500 italic">
                        {{ contentTextBottom|raw }}
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

{% else %}
    <div class="px-4 pt-32 pb-20">
        <div class="container mx-auto">
            <div class="max-w-3xl mx-auto">
                
                <div class="text-center mb-12">
                    <div class="inline-block px-3 py-1 rounded-full border border-zinc-800 bg-zinc-900/50 text-zinc-500 text-[10px] uppercase tracking-[0.2em] mb-4">
                        Terms & Conditions
                    </div>
                    <h2 class="text-4xl text-white tracking-tight">{{ site["site_name"] }}</h2>
                </div>

                <div class="bg-zinc-900/40 border border-zinc-800 rounded-3xl p-8 md:p-12 shadow-2xl backdrop-blur-sm">
                    <article class="prose prose-invert max-w-none">
                        <h3 class="text-xl font-bold text-white mb-6">General Information</h3>
                        <div class="text-zinc-400 leading-relaxed space-y-4">
                            {{ contentText|raw }}
                            {% if contentText is empty %}
                                <p>Welcome to <strong>{{ site["site_name"] }}</strong>. Please sign in to access your private dashboard and premium features.</p>
                            {% endif %}
                        </div>
                    </article>

                    <div class="mt-10 pt-8 border-t border-zinc-800/50 flex flex-col md:flex-row items-center justify-between gap-6">
                        <div class="text-sm text-zinc-500 italic">
                            {{ contentTextBottom|raw }}
                        </div>
                        <a href="/login" class="px-6 py-2 bg-white text-black font-bold rounded-lg hover:bg-zinc-200 transition-colors">
                            Sign In
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>
{% endif %}

</div> {% include 'footer.twig' %}

<style>
    /* Smooth transition for sidebar layout */
    .lg\:ml-64 { transition: margin-left 0.3s ease-in-out; }
    
    /* Global Typography Fixes */
    .prose-invert h1, .prose-invert h2, .prose-invert h3 {
        color: #ffffff !important;
        font-weight: 700;
    }
    .prose-invert strong {
        color: #60a5fa; /* Light blue emphasis */
    }
</style>