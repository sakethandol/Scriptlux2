{% include 'header.twig' %}

<style>
  html { scroll-behavior: smooth; }
  .form-control:focus {
    border-color: var(--color-accent) !important;
    box-shadow: 0 0 0 3px var(--color-border) !important;
    background-color: var(--color-accent-contrast) !important;
  }

  /* Chat bubbles */
  .bubble-user {
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    border-radius: 18px 18px 4px 18px;
    padding: 14px 18px;
    font-size: 0.88rem;
    line-height: 1.6;
    max-width: 75%;
    word-break: break-word;
  }
  .bubble-admin {
    background: var(--color-accent-contrast);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: 18px 18px 18px 4px;
    padding: 14px 18px;
    font-size: 0.88rem;
    line-height: 1.6;
    max-width: 75%;
    word-break: break-word;
  }
  .avatar-circle {
    width: 36px; height: 36px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; font-size: 0.75rem; font-weight: 700;
  }
  .chat-area { display: flex; flex-direction: column; gap: 24px; }
  .msg-user  { display: flex; justify-content: flex-end; align-items: flex-end; gap: 10px; }
  .msg-admin { display: flex; justify-content: flex-start; align-items: flex-end; gap: 10px; }
  .msg-meta  { font-size: 0.7rem; margin-top: 6px; opacity: 0.5; }
  .msg-user  .msg-meta { text-align: right; }
  .msg-admin .msg-meta { text-align: left; }
  
  /* Blinking dot animation */
  @keyframes blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0.3; }
  }
  .online-dot {
    animation: blink 1.5s infinite;
  }

  @media (max-width: 576px) {
    .hero-title  { font-size: 1.2rem; }
    .bubble-user,
    .bubble-admin { max-width: 90%; }
  }
</style>

<div class="min-vh-100 pb-5" style="background-color: var(--color-bg); color: var(--color-text);">

  <!-- ══════════════════════════════════════════
       HERO HEADER
  ══════════════════════════════════════════ -->
  <div style="background: var(--color-accent); position: relative; overflow: hidden;">
    <div style="position:absolute;top:-70px;right:-70px;width:240px;height:240px;
                border-radius:50%;background:rgba(214,255,246,0.05);pointer-events:none;"></div>
    <div style="position:absolute;bottom:-50px;left:80px;width:160px;height:160px;
                border-radius:50%;background:rgba(214,255,246,0.04);pointer-events:none;"></div>

    <div class="container-fluid px-3 px-md-5 py-4">
      <div class="d-flex align-items-center gap-3 flex-wrap">

        <!-- Back button -->
        <a href="tickets" class="text-decoration-none d-flex align-items-center justify-content-center"
           style="width:38px;height:38px;border-radius:10px;flex-shrink:0;
                  background:rgba(214,255,246,0.1);color:var(--color-accent-contrast);">
          <i class="fas fa-arrow-left" style="font-size:0.8rem;"></i>
        </a>

        <!-- Icon -->
        <div style="width:46px;height:46px;border-radius:13px;flex-shrink:0;
                    background:rgba(214,255,246,0.12);
                    display:flex;align-items:center;justify-content:center;">
          <i class="fas fa-comments" style="color:var(--color-accent-contrast);font-size:1.1rem;"></i>
        </div>

        <!-- Title + status -->
        <div class="flex-grow-1 min-width-0">
          <div class="d-flex align-items-center gap-2 flex-wrap">
            <h1 class="hero-title fw-bold mb-0"
                style="color:var(--color-accent-contrast);font-size:1.2rem;
                       letter-spacing:-0.3px;line-height:1.3;">
              {{ messageList['ticket']['subject'] }}
            </h1>
            {% if messageList["ticket"]["status"] == "closed" %}
              <span style="display:inline-flex;align-items:center;gap:5px;
                           font-size:0.65rem;font-weight:700;letter-spacing:0.5px;
                           padding:4px 10px;border-radius:50px;
                           background:rgba(108,117,125,0.3);color:var(--color-accent-contrast);">
                <i class="fas fa-lock" style="font-size:0.55rem;"></i>
                {{ lang["tickets.open.closed"] }}
              </span>
            {% else %}
              <span style="display:inline-flex;align-items:center;gap:5px;
                           font-size:0.65rem;font-weight:700;letter-spacing:0.5px;
                           padding:4px 10px;border-radius:50px;
                           background:rgba(25,135,84,0.3);color:var(--color-accent-contrast);">
                <i class="fas fa-circle" style="font-size:0.45rem;"></i>
                Open
              </span>
            {% endif %}
          </div>
          <p class="mb-0 mt-1"
             style="color:var(--color-accent-contrast);opacity:0.45;font-size:0.75rem;">
            Ticket #{{ messageList['ticket']['ticket_id'] }}
            &nbsp;·&nbsp;
            <i class="fas fa-headset me-1" style="font-size:0.65rem;"></i>
            Support Team
          </p>
        </div>

      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════
       ALERTS
  ══════════════════════════════════════════ -->
  <div class="container-fluid px-3 px-md-5 mt-4">

    {% if error %}
      <div class="d-flex align-items-start gap-3 p-3 mb-4 rounded-3"
           style="background:rgba(220,53,69,0.08);border-left:4px solid #dc3545;
                  border:1px solid rgba(220,53,69,0.15);">
        <i class="fas fa-exclamation-circle mt-1"
           style="color:#dc3545;flex-shrink:0;font-size:0.85rem;"></i>
        <div style="font-size:0.85rem;color:#dc3545;flex-grow:1;">{{ errorText }}</div>
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"
                style="font-size:0.65rem;opacity:0.5;"></button>
      </div>
    {% endif %}

    {% if success %}
      <div class="d-flex align-items-start gap-3 p-3 mb-4 rounded-3"
           style="background:rgba(25,135,84,0.08);border-left:4px solid #198754;
                  border:1px solid rgba(25,135,84,0.15);">
        <i class="fas fa-check-circle mt-1"
           style="color:#198754;flex-shrink:0;font-size:0.85rem;"></i>
        <div style="font-size:0.85rem;color:#198754;flex-grow:1;">{{ successText }}</div>
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"
                style="font-size:0.65rem;opacity:0.5;"></button>
      </div>
    {% endif %}

    <!-- ══════════════════════════════════════════
         CHAT WINDOW
    ══════════════════════════════════════════ -->
    <div class="row justify-content-center">
      <div class="col-12 col-lg-9 col-xl-8">

        <!-- Chat container -->
        <div class="rounded-4 overflow-hidden mb-4"
             style="background:var(--color-accent-contrast);border:1px solid var(--color-border);">

          <!-- Chat header bar -->
          <div class="d-flex align-items-center gap-3 px-4 py-3"
               style="background:var(--color-hover-bg);border-bottom:1px solid var(--color-border);">
            <div class="d-flex align-items-center gap-2">
              <div class="online-dot" style="width:9px;height:9px;border-radius:50%;background:#198754;"></div>
              <span style="font-size:0.78rem;font-weight:600;color:var(--color-text);opacity:0.65;">
                Support Team Online
              </span>
            </div>
            <div class="ms-auto d-flex align-items-center gap-2">
              <i class="fas fa-shield-alt"
                 style="font-size:0.7rem;color:var(--color-accent);opacity:0.4;"></i>
              <span style="font-size:0.7rem;color:var(--color-text);opacity:0.4;">
                Encrypted &amp; Secure
              </span>
            </div>
          </div>

          <!-- Messages area -->
          <div class="px-3 px-md-5 py-4 chat-area"
               style="min-height:320px;max-height:600px;overflow-y:auto;">

            {% if messageList %}
              {% for message in messageList %}

                {% if message["support"] == 1 %}
                  <!-- User message (right) -->
                  <div class="msg-user">
                    <div>
                      <div class="bubble-user">
                        {{ message["message"] }}
                      </div>
                      <div class="msg-meta d-flex align-items-center justify-content-end gap-2">
                        <span class="fw-semibold" style="color:var(--color-text);">
                          {{ user["username"] }}
                        </span>
                        <span>·</span>
                        <span>{{ show_date(message["time"]) }}</span>
                        <i class="fas fa-check-double"
                           style="color:var(--color-accent);font-size:0.6rem;opacity:0.6;"></i>
                      </div>
                    </div>
                    <!-- User avatar -->
                    <div class="avatar-circle flex-shrink-0"
                         style="background:var(--color-accent);color:var(--color-accent-contrast);
                                align-self:flex-end;">
                      <i class="fas fa-user" style="font-size:0.75rem;"></i>
                    </div>
                  </div>

                {% elseif message["subject"] %}
                  {# skip subject entries #}
                {% else %}
                  <!-- Admin message (left) -->
                  <div class="msg-admin">
                    <!-- Admin avatar -->
                    <div class="avatar-circle flex-shrink-0"
                         style="background:var(--color-hover-bg);color:var(--color-accent);
                                align-self:flex-end;border:1px solid var(--color-border);">
                      <i class="fas fa-headset" style="font-size:0.75rem;"></i>
                    </div>
                    <div>
                      <div class="bubble-admin">
                        {{ message["message"] }}
                      </div>
                      <div class="msg-meta d-flex align-items-center gap-2">
                        <span class="fw-semibold" style="color:var(--color-text);">
                          {{ lang["tickets.open.admin.name"] }}
                        </span>
                        <span>·</span>
                        <span>{{ show_date(message["time"]) }}</span>
                      </div>
                    </div>
                  </div>
                {% endif %}

              {% endfor %}
            {% endif %}

          </div><!-- /chat-area -->

        </div><!-- /chat container -->

        <!-- ══════════════════════════════════════════
             REPLY FORM
        ══════════════════════════════════════════ -->
        {% if messageList['ticket']['canmessage'] == 2 %}
          <div class="p-4 p-md-5 rounded-4"
               style="background:var(--color-accent-contrast);border:1px solid var(--color-border);">

            <!-- Header -->
            <div class="d-flex align-items-center gap-3 mb-4 pb-3"
                 style="border-bottom:1px solid var(--color-border);">
              <div style="width:40px;height:40px;border-radius:10px;background:var(--color-hover-bg);
                          display:flex;align-items:center;justify-content:center;">
                <i class="fas fa-reply" style="color:var(--color-accent);font-size:0.9rem;"></i>
              </div>
              <div>
                <h6 class="fw-bold mb-0" style="color:var(--color-text);font-size:0.95rem;">
                  {{ lang["tickets.open.label.message"] }}
                </h6>
                <p class="mb-0 small" style="color:var(--color-text);opacity:0.45;font-size:0.72rem;">
                  Your reply will be sent to the support team
                </p>
              </div>
            </div>

            <form method="post"
                  action="tickets/{{ messageList['ticket']['ticket_id'] }}">

              <!-- Textarea -->
              <div class="mb-4" style="position:relative;">
                <textarea id="message" rows="5"
                          class="form-control border rounded-3 py-3 px-3"
                          name="message"
                          placeholder="Type your reply here..."
                          style="background:var(--color-bg);color:var(--color-text);
                                 border-color:var(--color-border) !important;
                                 font-size:0.88rem;resize:vertical;line-height:1.6;">{{ data["message"] }}</textarea>
              </div>

              <input type="hidden" name="crsf_token" value="{{ csrf_token() }}">

              <!-- Footer row: tips + button -->
              <div class="d-flex align-items-center justify-content-between
                           flex-wrap gap-3 pt-3"
                   style="border-top:1px solid var(--color-border);">

                <div class="d-flex align-items-center gap-3 flex-wrap">
                  <span style="font-size:0.72rem;color:var(--color-text);opacity:0.4;">
                    <i class="fas fa-lock me-1" style="font-size:0.65rem;"></i>
                    End-to-end secure
                  </span>
                  <span style="font-size:0.72rem;color:var(--color-text);opacity:0.4;">
                    <i class="fas fa-bolt me-1" style="font-size:0.65rem;"></i>
                    Usually replied within 24h
                  </span>
                </div>

                <button type="submit" class="btn fw-bold px-5 py-2"
                        style="background:var(--color-accent);color:var(--color-accent-contrast);
                               border-radius:12px;font-size:0.85rem;letter-spacing:0.3px;border:none;">
                  <i class="fas fa-paper-plane me-2" style="font-size:0.78rem;"></i>
                  {{ lang["tickets.open.button.reply"] }}
                </button>

              </div>

            </form>
          </div>

        {% else %}
          <!-- Ticket closed — no reply -->
          <div class="text-center py-4 px-4 rounded-4"
               style="background:var(--color-accent-contrast);border:1px solid var(--color-border);">
            <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle"
                 style="width:52px;height:52px;background:var(--color-hover-bg);">
              <i class="fas fa-lock"
                 style="font-size:1.1rem;color:var(--color-accent);opacity:0.4;"></i>
            </div>
            <p class="fw-bold mb-1" style="color:var(--color-text);font-size:0.9rem;">
              This ticket is closed
            </p>
            <p class="small mb-3" style="color:var(--color-text);opacity:0.45;">
              You can no longer reply to this ticket. Open a new one if you need further help.
            </p>
            <a href="tickets" class="btn fw-bold px-4 py-2"
               style="background:var(--color-accent);color:var(--color-accent-contrast);
                      border-radius:10px;font-size:0.82rem;border:none;">
              <i class="fas fa-plus me-2" style="font-size:0.75rem;"></i>
              Open New Ticket
            </a>
          </div>
        {% endif %}

      </div>
    </div>

  </div>
</div>

{% include 'footer.twig' %}