{% include 'header.twig' %}

<div class="about-page-wrapper section-hunter-cream" style="min-height: 90vh; 
display: flex; flex-direction: column; align-items: center; padding: clamp(120px, 12vh, 120px) 0 5rem; overflow-x: hidden;">

    <div class="text-center mb-5 px-3" style="max-width: 900px;">
        <div class="d-inline-flex align-items-center gap-2 mb-3 px-3 py-1 rounded-pill" 
             style="background: rgba(var(--color-accent-rgb), 0.1); border: 1px solid rgba(var(--color-accent-rgb), 0.2);">
            <i class="fa-solid fa-heart" style="color: var(--color-accent-contrast); font-size: 0.8rem;"></i>
            <span style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-accent-contrast);">
                Our Story & Mission
            </span>
        </div>
        <h1 class="fw-black mb-3" style="font-size: clamp(2.5rem, 5vw, 4rem); color: var(--color-accent-contrast); letter-spacing: -2px; line-height: 1;">
            Get to Know Us.
        </h1>
        <p class="mx-auto opacity-60 fw-medium" style="max-width: 600px; font-size: 1.2rem; line-height: 1.5; color: var(--color-accent-contrast);">
            We are more than just a platform; we are a community dedicated to your social growth and success.
        </p>
    </div>


    {% if contentText is not empty %}
    <div class="about-card" style="width: 100%; max-width: 1350px; background: var(--color-bg); 
                border: 1.5px solid var(--color-border); border-radius: 40px; 
                box-shadow: 0 30px 70px -20px rgba(0, 0, 0, 0.1); overflow: hidden; margin: 0 auto;">
        
        <div class="p-4 p-md-5 p-lg-5" style="position: relative;">
            
            <div class="position-absolute top-0 end-0 p-5 opacity-10 d-none d-lg-block">
                <i class="fa-solid fa-users-rays" style="font-size: 15rem; color: var(--color-accent); transform: rotate(-10deg);"></i>
            </div>

            <div class="about-rich-text" style="position: relative; z-index: 2; 
                        color: var(--color-text); line-height: 1.9; font-size: 1.2rem; font-weight: 400;">
                
                {{ contentText }}
                
            </div>
        </div>


        <div class="p-4 p-md-5 border-top text-center" style="background: var(--color-hover-bg); border-color: var(--color-border) !important;">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <h3 class="fw-black mb-3" style="letter-spacing: -1px;">Ready to start your journey?</h3>
                    <p class="opacity-50 mb-4 fw-medium">Join thousands of users who trust us for their digital presence.</p>
                    <div class="d-flex flex-wrap justify-content-center gap-3">
                        <a href="/signup" class="btn px-5 py-3 rounded-pill fw-black" 
                           style="background: var(--color-accent); color: white; box-shadow: 0 10px 20px rgba(var(--color-accent-rgb), 0.3);">
                            Get Started Now <i class="fa-solid fa-arrow-right ms-2"></i>
                        </a>
                        <a href="/contact" class="btn px-5 py-3 rounded-pill fw-black" 
                           style="background: transparent; border: 1.5px solid var(--color-border); color: var(--color-text);">
                            Contact Us
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    <a href="/aboutus" class="mt-5 text-decoration-none fw-black back-to-top" style="color: var(--color-accent); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.15em;">
        Scroll to Top <i class="fa-solid fa-chevron-up ms-2"></i>
    </a>
</div>

<style>
    .section-hunter-cream {
        background-color: var(--color-accent);
        background-image:
            radial-gradient(at 0% 0%, rgba(255, 252, 222, 0.18) 0px, transparent 55%),
            radial-gradient(at 100% 100%, rgba(255, 252, 222, 0.14) 0px, transparent 55%),
            radial-gradient(at 0% 100%, rgba(255, 252, 222, 0.08) 0px, transparent 45%),
            radial-gradient(at 100% 0%, rgba(255, 252, 222, 0.06) 0px, transparent 45%),
            radial-gradient(at 50% 50%, rgba(255, 252, 222, 0.12) 0px, transparent 75%),
            linear-gradient(
                152deg,
                rgba(255, 252, 222, 0.06) 0%,
                rgba(255, 252, 222, 0.00) 40%,
                rgba(255, 252, 222, 0.04) 100%
            );
        background-attachment: fixed;
        position: relative;
        isolation: isolate;
    }

    .section-hunter-cream::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0.5;
        background-image:
            radial-gradient(circle, rgba(255, 252, 222, 0.12) 1px, transparent 1px),
            radial-gradient(circle, rgba(255, 252, 222, 0.05) 1.5px, transparent 1.5px);
        background-size: 28px 28px, 56px 56px;
        background-position: 0 0, 14px 14px;
        z-index: 0;
    }

    .about-page-wrapper > * {
        position: relative;
        z-index: 1;
    }

    .about-rich-text h1, .about-rich-text h2, .about-rich-text h3 {
        color: var(--color-text);
        font-weight: 900;
        margin-top: 3rem;
        margin-bottom: 1.5rem;
        letter-spacing: -1px;
        line-height: 1.2;
    }

    .about-rich-text p {
        margin-bottom: 1.8rem;
        opacity: 0.85;
    }
    .about-rich-text strong, .about-rich-text b {
        color: var(--color-accent);
        font-weight: 800;
    }

    /* Style for lists in About Us */
    .about-rich-text ul {
        list-style: none;
        padding-left: 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 15px;
        margin: 2rem 0;
    }

    .about-rich-text li {
        padding: 15px 20px;
        background: var(--color-hover-bg);
        border-radius: 16px;
        border: 1px solid var(--color-border);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .about-rich-text li::before {
        content: "\f00c"; /* FontAwesome Check */
        font-family: "Font Awesome 6 Free";
        font-weight: 900;
        color: var(--color-accent);
    }

    .back-to-top { transition: transform 0.3s ease; }
    .back-to-top:hover { transform: translateY(-5px); }
    @media (max-width: 991px) {
        .about-card {
            border-radius: 24px !important;
            border-left: 1.5px solid var(--color-border) !important;
            border-right: 1.5px solid var(--color-border) !important;
            box-shadow: 0 18px 40px -24px rgba(0, 0, 0, 0.35) !important;
        }
        .about-page-wrapper {
            padding: 100px 0.9rem 3rem !important;
        }
        .about-rich-text {
            font-size: 1.1rem !important;
        }

        .section-hunter-cream {
            background-attachment: scroll;
        }
    }

    @media (max-width: 767px) {
        .about-page-wrapper {
            padding: 92px 0.75rem 2.25rem !important;
        }

        .about-card {
            border-radius: 20px !important;
        }

        .about-rich-text ul {
            grid-template-columns: 1fr;
        }

        .about-card .btn {
            width: 100%;
        }
    }
</style>

{% include 'footer.twig' %}