							<span class="sr-only">Toggle navigation</span>
							<span class="icon-bar"></span>
							<span class="icon-bar"></span>
							<span class="icon-bar"></span>
						</button>
						<a class="navbar-brand" href="{{ site['url'] }}">
							{% if site["logo"] %}
								<img src="{{ site['logo'] }}" alt="" title="">
							{% else %}
								<span style="font-weight:700;">
									{{ site["site_name"] }}
								</span>
							{% endif %}
						</a>
					</div>
					<div id="navbar" class="collapse navbar-collapse">
						<ul class="nav navbar-nav navbar-left-block">

							{% for page in pagesInformation %}

								{% set page_get = page["page_get"] %}
								{% set page_icon = page["page_icon"] %}


								<li {% if isPageActive("#{page_get}") %} class="active" {% endif %}>

									<a href="{{ site['url'] }}/{{page_get}}">
										<span>
											<i class="{{ page_icon }}"></i>
										</span>

										{% set custom_page = page["custom_page"] %}
										{% set page_name = page["page_name"] %}
										{% if custom_page == 1 %}
											{{ lang["#{page_get}.title"] }}
										{% else %}
											{{page_name}}
										{% endif %}

										{% if page_get == "tickets" %}
											{% if ticketCount %}
												<span class="badge">{{ ticketCount }}
												</span>
											{% endif %}
										{% endif %}
									</a>

								</li>


							{% endfor  %}


						</ul>


						<ul class="nav navbar-nav navbar-right navbar-right-block">


							{% if user["access"]["admin_access"] %}

								<li class="nav-item component-navbar-nav-item component-navbar-private-nav-item">
