{% include 'header.twig' %}

<div class="reset-page-wrapper" style="min-height: 100vh; background-color: var(--color-bg); display: flex; align-items: center; justify-content: center; padding: clamp(120px, 14vh, 120px) 0.75rem 2rem; overflow-x: hidden;">

  <div class="reset-card" style="width: 100%; max-width: 1350px; background: var(--color-bg); border-radius: 28px; border: 1.5px solid var(--color-border); box-shadow: 0 20px 60px rgba(0,0,0,0.1); overflow: hidden; display: flex; flex-wrap: wrap;">
    <div class="col-lg-6 d-none d-lg-flex flex-column align-items-center justify-content-center position-relative p-5" 
         style="background: var(--color-accent); min-height: 600px;">
      
      <div class="position-absolute" style="inset:0; background: radial-gradient(circle at 15% 15%, rgba(255,255,255,0.15), transparent), radial-gradient(circle at 85% 85%, rgba(0,0,0,0.1), transparent); z-index:1;"></div>
      <div class="position-absolute" style="inset:0; background-image: radial-gradient(rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 32px 32px; z-index: 1;"></div>
      
      <div class="position-relative text-center w-100" style="z-index:2; max-width: 450px;">
        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4" 
             style="width: 100px; height: 100px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); backdrop-filter: blur(10px);">
          <i class="fa-solid fa-shield-keyhole text-white" style="font-size: 3rem;"></i>
        </div>

        <h1 class="fw-black text-white mb-3" style="font-size: clamp(2.5rem, 4vw, 3.5rem); line-height: 1; letter-spacing: -2px;">
          Secure Your<br>Account.
        </h1>

        <p class="text-white opacity-75" style="font-size: 1.2rem; font-weight: 400; line-height: 1.6;">
          Don't worry, it happens to the best of us. Let's get you back into your account safely.
        </p>
      </div>
    </div>
    <div class="col-12 col-lg-6 d-flex align-items-center justify-content-center p-3 p-md-5">
      
      <div class="form-inner-box" style="width: 100%; max-width: 460px; padding: 1rem 0;">
        
        <div class="d-lg-none text-center mb-5">
          <div class="p-4 rounded-4 shadow-sm" style="background: var(--color-accent); border: 1px solid rgba(255,255,255,0.1);">
            <h3 class="text-white fw-black mb-1">Account Recovery</h3>
            <p class="text-white opacity-75 small mb-0 fw-medium">Recover your password quickly</p>
          </div>
        </div>

        <div class="mb-5">
            <h2 class="fw-black mb-1" style="font-size: 2.8rem; color: var(--color-text); letter-spacing: -1.5px; line-height: 1.1;">Reset Password</h2>
            <p style="color: var(--color-text); opacity: 0.5; font-size: 1.15rem; font-weight: 500;">Enter your username or email to proceed.</p>
        </div>

        {# Alerts #}
        {% if errorText %}
        <div class="alert alert-danger rounded-4 d-flex align-items-center justify-content-between p-3 border-0 mb-4 shadow-sm" style="background:#fff1f2; color:#be123c;">
            <div class="d-flex align-items-center gap-2">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span class="fw-bold" style="font-size: 1rem;">{{ errorText }}</span>
            </div>
            <button onclick="this.parentElement.style.display='none'" style="background:none; border:none; color:inherit; cursor:pointer;"><i class="fa-solid fa-xmark"></i></button>
        </div>
        {% endif %}

        {% if successText %}
        <div class="alert alert-success rounded-4 d-flex align-items-center justify-content-between p-3 border-0 mb-4 shadow-sm" style="background:#f0fdf4; color:#16a34a;">
            <div class="d-flex align-items-center gap-2">
                <i class="fa-solid fa-circle-check"></i>
                <span class="fw-bold" style="font-size: 1rem;">{{ successText }}</span>
            </div>
            <button onclick="this.parentElement.style.display='none'" style="background:none; border:none; color:inherit; cursor:pointer;"><i class="fa-solid fa-xmark"></i></button>
        </div>
        {% endif %}

        <form method="post" action="">
          <div class="mb-4">
            <label for="username" style="display:block; font-size: 0.95rem; font-weight:900; text-transform:uppercase; letter-spacing:0.07em; color:var(--color-text); opacity:0.7; margin-bottom:0.8rem;">
              {{ lang['resetpassword.user'] }}
            </label>
            <div class="input-group">
              <span class="input-group-text bg-light border-end-0 px-3" style="border-color:var(--color-border); color:var(--color-accent);">
                <i class="fa-solid fa-user-tag"></i>
              </span>
              <input type="text" class="form-control bg-light border-start-0" 
                     id="username" name="user" value="{{ data['user'] }}"
                     placeholder="{{ lang['resetpassword.user.placeholder'] }}"
                     style="font-size: 1.1rem; font-weight: 500; padding: 0.9rem 1.1rem; border-color:var(--color-border); border-radius: 0 12px 12px 0;">
            </div>
          </div>

          {# Captcha Support #}
          {% if captcha %}
          <div class="mb-4 d-flex justify-content-center">
            <div class="g-recaptcha" data-sitekey="{{ captchaKey }}"></div>
          </div>
          {% endif %}

          <input type="hidden" name="crsf_token" value="{{ csrf_token() }}">

          <button type="submit" class="btn-reset-submit w-100" 
                  style="background: var(--color-accent); color: white; padding: 1.1rem; border-radius: 18px; border: none; font-weight: 900; font-size: 1.2rem; box-shadow: 0 12px 30px rgba(var(--color-accent-rgb), 0.3); cursor: pointer; transition: all 0.3s ease; display: flex; align-items: center; justify-content: center; gap: 10px;">
            <i class="fa-solid fa-envelope-open-text"></i>
            <span>{{ lang['resetpassword.button'] }}</span>
          </button>
        </form>

        {# Footer Redirect #}
        <div class="text-center mt-5 pt-4" style="border-top: 2px solid var(--color-border);">
            <p class="mb-0" style="color:var(--color-text); opacity:0.6; font-size: 1.1rem; font-weight: 500;">
                Remember your password? <a href="/" style="color:var(--color-accent); font-weight:900; text-decoration:none; margin-left: 6px;">Back to Sign In</a>
            </p>
        </div>

      </div>
    </div>
  </div>
</div>

<style>
  .form-control:focus {
    box-shadow: 0 0 0 5px rgba(var(--color-accent-rgb), 0.12) !important;
    border-color: var(--color-accent) !important;
    background: #fff !important;
    outline: none;
  }
  
  .btn-reset-submit:hover {
    filter: brightness(1.1);
    transform: translateY(-3px);
    box-shadow: 0 15px 35px rgba(var(--color-accent-rgb), 0.45);
  }

  /* Responsive Fixes */
  @media (max-width: 991px) {
    .reset-card { 
        border-radius: 0 !important; 
        border: none !important; 
        box-shadow: none !important;
        flex-direction: column;
    }
    .reset-page-wrapper { 
        padding: 0 !important; 
        background: var(--color-bg) !important;
    }
    .form-inner-box {
        max-width: 100% !important;
        padding-left: 1rem !important;
        padding-right: 1rem !important;
    }
  }

  @media (max-width: 576px) {
    h2 { font-size: 2.2rem !important; }
    .form-control { font-size: 16px !important; }
  }
</style>

{% include 'footer.twig' %}