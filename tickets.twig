{% include 'header.twig' %}

<div class="container">

	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-U1DAWAznBHeqEIlVSCgzq+c9gqGAJn5c/t99JyeKa9xxaYpSvHU5awsuZVVFIhvj" crossorigin="anonymous"></script>

	<div class="row">
		{% if contentText is not empty %}
			<div class="col-md-12">
				<div class="well ">
					{{ contentText }}
				</div>
			</div>
		{% endif %}
		<div class="col-md-12">

			{% if error %}
				<div class="alert alert-dismissible alert-danger {% if site['rtl'] %} rtl-alert {% endif %}">
					<button type="button" class="close" data-dismiss="alert">×</button>
					{{ errorText }}
				</div>
			{% elseif success %}
				<div class="alert alert-dismissible alert-success {% if site['rtl'] %} rtl-alert {% endif %}">
					<button type="button" class="close" data-dismiss="alert">×</button>
					{{ successText }}
				</div>
			{% endif %}

			{% if settings['ticket_system'] == 2 %}

				{% if settings['ticket_version'] == 1 %}
					<div class="well">
						<form method="post" action="tickets">
							<div class="form-group">
								<label for="subject" class="control-label">{{ lang['tickets.subject'] }}</label>
								<input type="text" class="form-control" id="subject" name="subject" value="{{ data['subject'] }}">
							</div>
							<div class="form-group">
								<label for="message" class="control-label">{{ lang['tickets.message'] }}</label>
								<textarea class="form-control" rows="7" id="message" name="message">{{ data['message'] }}</textarea>
							</div>
							<input type="hidden" name="crsf_token" value="{{ csrf_token() }}">
							<button type="submit" class="btn btn-primary">{{ lang['tickets.button'] }}</button>
						</form>
					</div>
				{% endif %}
				{% if settings['ticket_version'] == 2 %}

					<div
						class="tab-content" id="pills-tabContent">
						<!-- New Order Tab -->

						<div class="tab-pane fade active in" id="new-ticket" role="tabpanel" aria-labelledby="pills-home-tab">
							<div id="main-page" class="well  table-responsive">

								<form method="post" action="tickets" id="ticketsend" onsubmit="form_submit()">

									<div class="form-group">
										<label for="subject" class="control-label">{{ lang['tickets.subject'] }}</label>
										<select class="form-control" id="subject" name="Subject[main]">
											{% for ticketSubject in ticketSubjectList %}
												<option {% if ticketSubject["subject_id"] == user["ticket_data"]["subject"] %} selected {% endif %} value="{{ticketSubject["subject_id"]}}" {% if ticketSubject["subject_id"] == 1 %} selected {% endif %}>{{ticketSubject["subject"]}}</option>
											{% endfor %}
										</select>
									</div>

									<div id="ticketsData"></div>

									<div class="form-group message">
										<label for="message" class="control-label">{{ lang['tickets.message'] }}</label>
										<textarea class="form-control" rows="7" id="message" name="message">{{user["ticket_data"]["message"]}}</textarea>
									</div>
									<input type="hidden" name="crsf_token" value="{{ csrf_token() }}">
									<button type="submit" class="btn btn-block btn-primary">{{lang["tickets.button"]}}</button>
								</form>
							</div>


						</div>


					</div>
				</div>

			</div>
		{% endif %}
	{% endif %}

	<div class="well" style="overflow:auto;">
		<table class="table ">
			<thead>
				<tr>
					<th>{{ lang['tickets.id'] }}</th>
					<th>{{ lang['tickets.subject'] }}</th>
					<th>{{ lang['tickets.status'] }}</th>
					<th class="nowrap">{{ lang['tickets.updated'] }}</th>
				</tr>
			</thead>
			<tbody>
				{% for ticket in ticketList %}
					<tr>
						<td>{{ ticket['ticket_id'] }}</td>
						{% if ticket["support_new"] == 2 %}
							<td>
								<a href="tickets/{{ ticket['ticket_id'] }}">
									<strong>{{ ticket['subject'] }}</strong>
								</a>
							</td>
						{% else %}
							<td>
								<a href="tickets/{{ ticket['ticket_id'] }}">{{ ticket['subject'] }}</a>
							</td>
						{% endif %}
						<td>{{ ticket['status'] }}</td>
						<td>
							<span class="nowrap">{{ show_date(ticket['lastupdate_time']) }}</span>
						</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	</div>
</div></div>
{% if contentTextBottom is not empty %}
	<div class="col-md-12">
		<div class="well ">
			{{ contentTextBottom }}
		</div>
	</div>
{% endif %}
</div>{% include 'footer.twig' %}
