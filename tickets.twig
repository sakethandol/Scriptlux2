{% include 'header.twig' %}

<style>
  html { scroll-behavior: smooth; }
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .page-link { transition: all 0.18s ease; }
  .ticket-row { transition: background 0.15s ease, transform 0.15s ease; }
  .ticket-row:hover { background: var(--color-hover-bg) !important; transform: translateX(3px); }
  .form-control:focus, .form-select:focus {
    border-color: var(--color-accent) !important;
    box-shadow: 0 0 0 3px var(--color-border) !important;
    background-color: var(--color-accent-contrast) !important;
  }
  .feature-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .feature-card:hover { transform: translateY(-4px); box-shadow: 0 10px 28px var(--color-border) !important; }
  .decorative-card {
    position: relative;
    overflow: hidden;
  }
  .decorative-card::after {
    content: "";
    position: absolute;
    right: -26px;
    top: -26px;
    width: 108px;
    height: 108px;
    border-radius: 50%;
    background: var(--decor-circle-color, var(--color-text));
    opacity: 0.8;
    pointer-events: none;
    z-index: 0;
  }
  .decorative-card > * {
    position: relative;
    z-index: 1;
  }
  .feature-a {
    background: var(--color-accent-contrast);
    border-color: var(--color-border) !important;
  }
  .feature-a .feature-icon {
    background: var(--color-hover-bg);
    color: var(--color-accent);
  }
  .feature-a .feature-title,
  .feature-a .feature-desc {
    color: var(--color-text);
  }
  .feature-b {
    background: var(--color-text);
    border-color: rgba(214,255,246,0.08) !important;
  }
  .feature-b .feature-icon {
    background: rgba(214,255,246,0.08);
    color: var(--color-accent-contrast);
  }
  .feature-b .feature-title,
  .feature-b .feature-desc {
    color: var(--color-bg);
  }
  .input-icon-wrap { position: relative; }
  .input-icon-wrap .form-control,
  .input-icon-wrap .form-select { padding-left: 42px; }
  .input-icon-wrap .field-icon {
    position: absolute; left: 14px; top: 50%;
    transform: translateY(-50%);
    color: var(--color-accent); opacity: 0.45;
    font-size: 0.8rem; pointer-events: none; z-index: 5;
  }
  .input-icon-wrap.textarea-wrap .field-icon { top: 18px; transform: none; }
  .new-ticket-badge {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.5px;
    padding: 3px 8px; border-radius: 50px;
    background: rgba(2,132,199,0.12); color: #0284c7;
    vertical-align: middle; margin-left: 6px;
  }
  @media (max-width: 576px) {
    .hero-title { font-size: 1.3rem; }
    .feature-grid > div:nth-child(1) .feature-card,
    .feature-grid > div:nth-child(4) .feature-card { background: var(--color-accent-contrast) !important; }
    .feature-grid > div:nth-child(1) .feature-card,
    .feature-grid > div:nth-child(4) .feature-card { --decor-circle-color: var(--color-text) !important; }
    .feature-grid > div:nth-child(1) .feature-icon,
    .feature-grid > div:nth-child(4) .feature-icon { background: var(--color-hover-bg) !important; color: var(--color-accent) !important; }
    .feature-grid > div:nth-child(1) .feature-title,
    .feature-grid > div:nth-child(1) .feature-desc,
    .feature-grid > div:nth-child(4) .feature-title,
    .feature-grid > div:nth-child(4) .feature-desc { color: var(--color-text) !important; }
    .feature-grid > div:nth-child(2) .feature-card,
    .feature-grid > div:nth-child(3) .feature-card { background: var(--color-text) !important; }
    .feature-grid > div:nth-child(2) .feature-card,
    .feature-grid > div:nth-child(3) .feature-card { --decor-circle-color: var(--color-bg) !important; }
    .feature-grid > div:nth-child(2) .feature-icon,
    .feature-grid > div:nth-child(3) .feature-icon { background: rgba(214,255,246,0.08) !important; color: var(--color-accent-contrast) !important; }
    .feature-grid > div:nth-child(2) .feature-title,
    .feature-grid > div:nth-child(2) .feature-desc,
    .feature-grid > div:nth-child(3) .feature-title,
    .feature-grid > div:nth-child(3) .feature-desc { color: var(--color-bg) !important; }
  }
</style>

<div class="min-vh-100 pb-5" style="background-color: var(--color-bg); color: var(--color-text);">

  <div style="background: var(--color-accent); position: relative; overflow: hidden;">
    <div style="position:absolute;top:-80px;right:-80px;width:260px;height:260px;
                border-radius:50%;background:rgba(214,255,246,0.05);pointer-events:none;"></div>
    <div style="position:absolute;bottom:-60px;left:80px;width:180px;height:180px;
                border-radius:50%;background:rgba(214,255,246,0.04);pointer-events:none;"></div>

    <div class="container-fluid px-3 px-md-5 py-5">
      <div class="row align-items-center g-4">

        <!-- Title -->
        <div class="col-12 col-md-7">
          <div class="d-flex align-items-center gap-3 mb-3">
            <div style="width:52px;height:52px;border-radius:14px;
                        background:rgba(214,255,246,0.12);
                        display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-headset" style="color:var(--color-accent-contrast);font-size:1.3rem;"></i>
            </div>
            <div>
              <p class="mb-0 fw-semibold"
                 style="color:var(--color-accent-contrast);opacity:0.5;
                        font-size:0.7rem;letter-spacing:2px;text-transform:uppercase;">
                Support
              </p>
              <h1 class="hero-title fw-bold mb-0"
                  style="color:var(--color-accent-contrast);letter-spacing:-0.5px;font-size:1.75rem;">
                Help & Tickets
              </h1>
            </div>
          </div>
          <p style="color:var(--color-accent-contrast);opacity:0.5;
                    font-size:0.85rem;max-width:460px;line-height:1.6;">
            Submit a support request and track all your open and resolved tickets in one place.
          </p>
          <div class="d-flex flex-wrap gap-2 mt-3">
            <span style="display:inline-flex;align-items:center;gap:7px;font-size:0.72rem;
                         font-weight:600;padding:6px 14px;border-radius:50px;
                         background:rgba(214,255,246,0.1);color:var(--color-accent-contrast);">
              <i class="fas fa-bolt" style="font-size:0.7rem;opacity:0.75;"></i> Fast Response
            </span>
            <span style="display:inline-flex;align-items:center;gap:7px;font-size:0.72rem;
                         font-weight:600;padding:6px 14px;border-radius:50px;
                         background:rgba(214,255,246,0.1);color:var(--color-accent-contrast);">
              <i class="fas fa-shield-alt" style="font-size:0.7rem;opacity:0.75;"></i> Secure Chat
            </span>
            <span style="display:inline-flex;align-items:center;gap:7px;font-size:0.72rem;
                         font-weight:600;padding:6px 14px;border-radius:50px;
                         background:rgba(214,255,246,0.1);color:var(--color-accent-contrast);">
              <i class="fas fa-clock" style="font-size:0.7rem;opacity:0.75;"></i> 24/7 Support
            </span>
          </div>
        </div>

        <!-- Stats block -->
        <div class="col-12 col-md-5">
          <div class="row g-3">
            <div class="col-6">
              <div class="p-3 rounded-4 text-center"
                   style="background:rgba(214,255,246,0.08);border:1px solid rgba(214,255,246,0.12);">
                <i class="fas fa-ticket-alt mb-2 d-block"
                   style="color:var(--color-accent-contrast);opacity:0.5;font-size:1.1rem;"></i>
                <p class="mb-0 fw-bold" style="color:var(--color-accent-contrast);font-size:1.4rem;">
                  {{ ticketList|length }}
                </p>
                <p class="mb-0" style="color:var(--color-accent-contrast);opacity:0.45;
                           font-size:0.7rem;letter-spacing:0.5px;text-transform:uppercase;">
                  Total Tickets
                </p>
              </div>
            </div>
            <div class="col-6">
              <div class="p-3 rounded-4 text-center"
                   style="background:rgba(214,255,246,0.08);border:1px solid rgba(214,255,246,0.12);">
                <i class="fas fa-clock mb-2 d-block"
                   style="color:var(--color-accent-contrast);opacity:0.5;font-size:1.1rem;"></i>
                <p class="mb-0 fw-bold" style="color:var(--color-accent-contrast);font-size:1.4rem;">
                  &lt; 24h
                </p>
                <p class="mb-0" style="color:var(--color-accent-contrast);opacity:0.45;
                           font-size:0.7rem;letter-spacing:0.5px;text-transform:uppercase;">
                  Avg Response
                </p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <div class="container-fluid px-3 px-md-5 mt-4">
    <div class="row g-2 g-md-3 mb-4 feature-grid">
      {% set features = [
        {'icon':'fa-paper-plane',  'title':'Submit a Ticket',    'desc':'Describe your issue clearly and our team will respond as fast as possible.'},
        {'icon':'fa-comments',     'title':'Real-time Chat',     'desc':'Ticket threads are updated in real-time so you never miss a reply.'},
        {'icon':'fa-history',      'title':'Full History',       'desc':'Access every ticket you have ever opened along with all replies.'},
        {'icon':'fa-star',         'title':'Priority Support',   'desc':'Premium users get prioritized routing to senior support agents.'}
      ] %}
      {% for f in features %}
        <div class="col-6 col-lg-3">
          <div class="feature-card decorative-card {% if loop.index is odd %}feature-a{% else %}feature-b{% endif %} h-100 p-3 p-md-4 rounded-4"
               style="--decor-circle-color:{% if loop.index is odd %}var(--color-text){% else %}var(--color-bg){% endif %};border:1px solid;">
            <div class="feature-icon" style="width:38px;height:38px;border-radius:11px;
                        display:flex;align-items:center;justify-content:center;margin-bottom:14px;">
              <i class="fas {{ f.icon }}" style="font-size:0.88rem;"></i>
            </div>
            <h6 class="feature-title fw-bold mb-1" style="font-size:0.82rem;">{{ f.title }}</h6>
            <p class="feature-desc mb-0 small" style="opacity:0.5;line-height:1.45;font-size:0.74rem;">
              {{ f.desc }}
            </p>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if contentText is not empty %}
      <div class="d-flex align-items-start gap-3 p-4 mb-4"
           style="background:var(--color-accent-contrast);border-left:4px solid var(--color-accent);
                  border-radius:14px;border:1px solid var(--color-border);">
        <i class="fas fa-info-circle mt-1"
           style="color:var(--color-accent);opacity:0.6;flex-shrink:0;"></i>
        <div style="font-size:0.88rem;line-height:1.6;">{{ contentText }}</div>
      </div>
    {% endif %}


    {% if error %}
      <div class="d-flex align-items-start gap-3 p-3 mb-4 rounded-3
                  {% if site['rtl'] %}rtl-alert{% endif %}"
           style="background:rgba(220,53,69,0.08);border-left:4px solid #dc3545;
                  border:1px solid rgba(220,53,69,0.15);">
        <i class="fas fa-exclamation-circle mt-1"
           style="color:#dc3545;flex-shrink:0;font-size:0.85rem;"></i>
        <div style="font-size:0.85rem;color:#dc3545;flex-grow:1;">{{ errorText }}</div>
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"
                style="font-size:0.65rem;opacity:0.5;"></button>
      </div>
    {% elseif success %}
      <div class="d-flex align-items-start gap-3 p-3 mb-4 rounded-3
                  {% if site['rtl'] %}rtl-alert{% endif %}"
           style="background:rgba(25,135,84,0.08);border-left:4px solid #198754;
                  border:1px solid rgba(25,135,84,0.15);">
        <i class="fas fa-check-circle mt-1"
           style="color:#198754;flex-shrink:0;font-size:0.85rem;"></i>
        <div style="font-size:0.85rem;color:#198754;flex-grow:1;">{{ successText }}</div>
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"
                style="font-size:0.65rem;opacity:0.5;"></button>
      </div>
    {% endif %}
    {% if settings['ticket_system'] == 2 %}

      <div class="row g-4 mb-5">

        <!-- Form card -->
        <div class="col-12 col-lg-8">
          <div class="decorative-card p-4 p-md-5 rounded-4"
            style="--decor-circle-color:var(--color-text);background:var(--color-accent-contrast);border:1px solid var(--color-border);">

            <!-- Form header -->
            <div class="d-flex align-items-center gap-3 mb-4 pb-3"
                 style="border-bottom:1px solid var(--color-border);">
              <div style="width:42px;height:42px;border-radius:11px;background:var(--color-hover-bg);
                          display:flex;align-items:center;justify-content:center;">
                <i class="fas fa-paper-plane"
                   style="color:var(--color-accent);font-size:0.95rem;"></i>
              </div>
              <div>
                <h5 class="fw-bold mb-0" style="color:var(--color-text);font-size:1rem;">
                  Open a New Ticket
                </h5>
                <p class="mb-0 small"
                   style="color:var(--color-text);opacity:0.45;font-size:0.75rem;">
                  We'll get back to you within 24 hours
                </p>
              </div>
            </div>

            {% if settings['ticket_version'] == 1 %}
              <form method="post" action="tickets">

                <div class="mb-4">
                  <label for="subject" class="fw-semibold d-block mb-2"
                         style="font-size:0.82rem;color:var(--color-text);letter-spacing:0.3px;">
                    <i class="fas fa-tag me-2" style="opacity:0.45;font-size:0.75rem;"></i>
                    {{ lang['tickets.subject'] }}
                  </label>
                  <div class="input-icon-wrap">
                    <i class="fas fa-tag field-icon"></i>
                    <input type="text" class="form-control border rounded-3 py-3"
                           id="subject" name="subject" value="{{ data['subject'] }}"
                           placeholder="Brief summary of your issue"
                           style="background:var(--color-bg);color:var(--color-text);
                                  border-color:var(--color-border) !important;font-size:0.88rem;">
                  </div>
                </div>

                <div class="mb-4">
                  <label for="message" class="fw-semibold d-block mb-2"
                         style="font-size:0.82rem;color:var(--color-text);letter-spacing:0.3px;">
                    <i class="fas fa-comment-alt me-2" style="opacity:0.45;font-size:0.75rem;"></i>
                    {{ lang['tickets.message'] }}
                  </label>
                  <div class="input-icon-wrap textarea-wrap">
                    <i class="fas fa-comment-alt field-icon"></i>
                    <textarea class="form-control border rounded-3 py-3"
                              rows="7" id="message" name="message"
                              placeholder="Describe your issue in detail..."
                              style="background:var(--color-bg);color:var(--color-text);
                                     border-color:var(--color-border) !important;
                                     font-size:0.88rem;resize:vertical;">{{ data['message'] }}</textarea>
                  </div>
                </div>

                <input type="hidden" name="crsf_token" value="{{ csrf_token() }}">

                <div class="pt-3" style="border-top:1px solid var(--color-border);">
                  <button type="submit" class="btn fw-bold px-5 py-3"
                          style="background:var(--color-accent);color:var(--color-accent-contrast);
                                 border-radius:12px;font-size:0.88rem;letter-spacing:0.3px;border:none;">
                    <i class="fas fa-paper-plane me-2" style="font-size:0.8rem;"></i>
                    {{ lang['tickets.button'] }}
                  </button>
                </div>

              </form>
            {% endif %}


            {% if settings['ticket_version'] == 2 %}
              <div class="tab-content" id="pills-tabContent">
                <div class="tab-pane fade show active" id="new-ticket"
                     role="tabpanel" aria-labelledby="pills-home-tab">
                  <div id="main-page">

                    <form method="post" action="tickets"
                          id="ticketsend" onsubmit="form_submit()">

                      <div class="mb-4">
                        <label for="subject" class="fw-semibold d-block mb-2"
                               style="font-size:0.82rem;color:var(--color-text);letter-spacing:0.3px;">
                          <i class="fas fa-list me-2"
                             style="opacity:0.45;font-size:0.75rem;"></i>
                          {{ lang['tickets.subject'] }}
                        </label>
                        <div class="input-icon-wrap">
                          <i class="fas fa-list field-icon"></i>
                          <select class="form-select border rounded-3 py-3 px-3"
                                  id="subject" name="Subject[main]"
                                  style="background:var(--color-bg);color:var(--color-text);
                                         border-color:var(--color-border) !important;
                                         font-size:0.88rem;">
                            {% for ticketSubject in ticketSubjectList %}
                              <option
                                {% if ticketSubject["subject_id"] == user["ticket_data"]["subject"] %}
                                  selected
                                {% endif %}
                                value="{{ ticketSubject["subject_id"] }}"
                                {% if ticketSubject["subject_id"] == 1 %} selected {% endif %}>
                                {{ ticketSubject["subject"] }}
                              </option>
                            {% endfor %}
                          </select>
                        </div>
                      </div>

                      <div id="ticketsData"></div>

                      <div class="mb-4 message">
                        <label for="message" class="fw-semibold d-block mb-2"
                               style="font-size:0.82rem;color:var(--color-text);letter-spacing:0.3px;">
                          <i class="fas fa-comment-alt me-2"
                             style="opacity:0.45;font-size:0.75rem;"></i>
                          {{ lang['tickets.message'] }}
                        </label>
                        <div class="input-icon-wrap textarea-wrap">
                          <i class="fas fa-comment-alt field-icon"></i>
                          <textarea class="form-control border rounded-3 py-3"
                                    rows="7" id="message" name="message"
                                    placeholder="Describe your issue in detail..."
                                    style="background:var(--color-bg);color:var(--color-text);
                                           border-color:var(--color-border) !important;
                                           font-size:0.88rem;resize:vertical;">{{ user["ticket_data"]["message"] }}</textarea>
                        </div>
                      </div>

                      <input type="hidden" name="crsf_token" value="{{ csrf_token() }}">

                      <div class="pt-3" style="border-top:1px solid var(--color-border);">
                        <button type="submit" class="btn fw-bold px-5 py-3 w-100"
                                style="background:var(--color-accent);color:var(--color-accent-contrast);
                                       border-radius:12px;font-size:0.88rem;letter-spacing:0.3px;border:none;">
                          <i class="fas fa-paper-plane me-2" style="font-size:0.8rem;"></i>
                          {{ lang["tickets.button"] }}
                        </button>
                      </div>

                    </form>
                  </div>
                </div>
              </div>
            {% endif %}

          </div>
        </div>

        <!-- Side tips card -->
        <div class="col-12 col-lg-4">
          <div class="decorative-card p-4 rounded-4 h-100"
            style="--decor-circle-color:var(--color-text);background:var(--color-accent-contrast);border:1px solid var(--color-border);">
            <div class="d-flex align-items-center gap-2 mb-4 pb-3"
                 style="border-bottom:1px solid var(--color-border);">
              <div style="width:38px;height:38px;border-radius:10px;background:var(--color-hover-bg);
                          display:flex;align-items:center;justify-content:center;">
                <i class="fas fa-lightbulb"
                   style="color:var(--color-accent);font-size:0.85rem;"></i>
              </div>
              <h6 class="fw-bold mb-0" style="color:var(--color-text);font-size:0.9rem;">
                Tips for Faster Help
              </h6>
            </div>
            {% set tips = [
              {'icon':'fa-hashtag',      'tip':'Include your Order ID or Transaction ID in the message.'},
              {'icon':'fa-camera',       'tip':'Attach screenshots if possible — they help us resolve issues faster.'},
              {'icon':'fa-align-left',   'tip':'Be specific and concise. One issue per ticket works best.'},
              {'icon':'fa-bell',         'tip':'Check your email for our reply — we notify you on every update.'},
              {'icon':'fa-search',       'tip':'Search your existing tickets before opening a new one.'}
            ] %}
            <div class="d-flex flex-column gap-3">
              {% for t in tips %}
                <div class="d-flex align-items-start gap-3">
                  <div style="width:32px;height:32px;border-radius:8px;background:var(--color-hover-bg);
                              display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="fas {{ t.icon }}"
                       style="color:var(--color-accent);font-size:0.72rem;"></i>
                  </div>
                  <p class="mb-0 small"
                     style="color:var(--color-text);opacity:0.6;font-size:0.78rem;
                            line-height:1.5;padding-top:6px;">
                    {{ t.tip }}
                  </p>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>

      </div>
    {% endif %}


    <div class="d-flex align-items-center gap-3 mb-3">
      <div style="width:40px;height:40px;border-radius:10px;background:var(--color-accent);
                  display:flex;align-items:center;justify-content:center;">
        <i class="fas fa-history"
           style="color:var(--color-accent-contrast);font-size:0.9rem;"></i>
      </div>
      <div>
        <h5 class="fw-bold mb-0" style="color:var(--color-text);font-size:1rem;">
          Your Tickets
        </h5>
        <p class="mb-0 small" style="color:var(--color-text);opacity:0.45;font-size:0.75rem;">
          Click any ticket to view the full conversation
        </p>
      </div>
    </div>

        <div class="decorative-card rounded-4 overflow-hidden mb-4"
          style="--decor-circle-color:var(--color-text);background:var(--color-accent-contrast);border:1px solid var(--color-border);">
      <div class="table-responsive">
        <table class="table mb-0 align-middle">

          <thead>
            <tr style="background:var(--color-accent);">
              <th class="px-4 py-3 border-0 fw-semibold"
                  style="color:var(--color-accent-contrast);font-size:0.72rem;
                         letter-spacing:0.6px;text-transform:uppercase;white-space:nowrap;">
                {{ lang['tickets.id'] }}
              </th>
              <th class="px-3 py-3 border-0 fw-semibold"
                  style="color:var(--color-accent-contrast);font-size:0.72rem;
                         letter-spacing:0.6px;text-transform:uppercase;">
                {{ lang['tickets.subject'] }}
              </th>
              <th class="px-3 py-3 border-0 fw-semibold"
                  style="color:var(--color-accent-contrast);font-size:0.72rem;
                         letter-spacing:0.6px;text-transform:uppercase;white-space:nowrap;">
                {{ lang['tickets.status'] }}
              </th>
              <th class="px-3 py-3 border-0 fw-semibold"
                  style="color:var(--color-accent-contrast);font-size:0.72rem;
                         letter-spacing:0.6px;text-transform:uppercase;white-space:nowrap;">
                {{ lang['tickets.updated'] }}
              </th>
            </tr>
          </thead>

          <tbody>
            {% for ticket in ticketList %}

              {% set st = ticket['status']|lower %}
              {% if st == 'open' %}
                {% set s_bg    = 'rgba(25,135,84,0.1)'  %}
                {% set s_color = '#198754'               %}
                {% set s_icon  = 'fa-door-open'          %}
              {% elseif st == 'answered' %}
                {% set s_bg    = 'rgba(2,132,199,0.1)'  %}
                {% set s_color = '#0284c7'               %}
                {% set s_icon  = 'fa-reply'              %}
              {% elseif st == 'closed' %}
                {% set s_bg    = 'rgba(108,117,125,0.1)' %}
                {% set s_color = '#6c757d'               %}
                {% set s_icon  = 'fa-lock'               %}
              {% elseif st == 'pending' %}
                {% set s_bg    = 'rgba(217,119,6,0.1)'  %}
                {% set s_color = '#d97706'               %}
                {% set s_icon  = 'fa-clock'              %}
              {% else %}
                {% set s_bg    = 'rgba(79,70,229,0.1)'  %}
                {% set s_color = '#4f46e5'               %}
                {% set s_icon  = 'fa-dot-circle'         %}
              {% endif %}

              <tr class="ticket-row"
                  style="border-bottom:1px solid var(--color-border);">

                <!-- ID -->
                <td class="px-4 py-3">
                  <span class="fw-bold rounded-2 px-2 py-1"
                        style="background:var(--color-hover-bg);color:var(--color-accent);
                               font-size:0.75rem;">
                    #{{ ticket['ticket_id'] }}
                  </span>
                </td>

                <!-- Subject -->
                <td class="px-3 py-3">
                  {% if ticket["support_new"] == 2 %}
                    <a href="tickets/{{ ticket['ticket_id'] }}"
                       class="text-decoration-none fw-bold d-flex align-items-center gap-2"
                       style="color:var(--color-accent);font-size:0.88rem;">
                      <i class="fas fa-comment-dots"
                         style="font-size:0.7rem;opacity:0.5;flex-shrink:0;"></i>
                      {{ ticket['subject'] }}
                      <span class="new-ticket-badge">
                        <i class="fas fa-circle" style="font-size:0.45rem;"></i> New Reply
                      </span>
                    </a>
                  {% else %}
                    <a href="tickets/{{ ticket['ticket_id'] }}"
                       class="text-decoration-none d-flex align-items-center gap-2"
                       style="color:var(--color-text);font-size:0.88rem;">
                      <i class="fas fa-comment"
                         style="color:var(--color-accent);font-size:0.7rem;opacity:0.45;flex-shrink:0;"></i>
                      {{ ticket['subject'] }}
                    </a>
                  {% endif %}
                </td>

                <!-- Status -->
                <td class="px-3 py-3">
                  <span style="display:inline-flex;align-items:center;gap:5px;
                               font-size:0.7rem;font-weight:700;letter-spacing:0.4px;
                               padding:4px 10px;border-radius:50px;
                               background:{{ s_bg }};color:{{ s_color }};">
                    <i class="fas {{ s_icon }}" style="font-size:0.6rem;"></i>
                    {{ ticket['status'] }}
                  </span>
                </td>

                <!-- Last Updated -->
                <td class="px-3 py-3">
                  <span class="d-flex align-items-center gap-2"
                        style="font-size:0.8rem;color:var(--color-text);
                               opacity:0.55;white-space:nowrap;">
                    <i class="fas fa-clock" style="font-size:0.65rem;"></i>
                    {{ show_date(ticket['lastupdate_time']) }}
                  </span>
                </td>

              </tr>
            {% endfor %}

            <!-- Empty state -->
            {% if ticketList is empty %}
              <tr>
                <td colspan="4" class="text-center py-5">
                  <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle"
                       style="width:68px;height:68px;background:var(--color-hover-bg);">
                    <i class="fas fa-ticket-alt"
                       style="font-size:1.5rem;color:var(--color-accent);opacity:0.35;"></i>
                  </div>
                  <p class="fw-bold mb-1"
                     style="color:var(--color-text);font-size:0.9rem;">
                    No tickets yet
                  </p>
                  <p class="small mb-0"
                     style="color:var(--color-text);opacity:0.45;">
                    Submit your first support ticket using the form above.
                  </p>
                </td>
              </tr>
            {% endif %}

          </tbody>
        </table>
      </div>
    </div>

    <!-- Content Text Bottom -->
    {% if contentTextBottom is not empty %}
      <div class="d-flex align-items-start gap-3 p-4 mt-2"
           style="background:var(--color-accent-contrast);border-left:4px solid var(--color-accent);
                  border-radius:14px;border:1px solid var(--color-border);">
        <i class="fas fa-info-circle mt-1"
           style="color:var(--color-accent);opacity:0.6;flex-shrink:0;"></i>
        <div style="font-size:0.88rem;line-height:1.6;">{{ contentTextBottom }}</div>
      </div>
    {% endif %}

  </div>
</div>

{% include 'footer.twig' %}