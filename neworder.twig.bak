{% include 'header.twig' %}


<div class="container">
	<div class="row">
		{% if contentText is not empty %}
			<div class="col-md-12">
				<div class="well ">
					{{ contentText }}
				</div>
			</div>
		{% endif %}
		<div class="card-divs">
			<div class="col-md-4">
				<div class="cards">
					<div class="card-body">
						<h3 class="card-title">Total Spent</h3>
						<h3 class="card-text text-right">{{convert_currency(user['spent'])}}</h3>

					</div>
				</div>
			</div>
			<div class="col-md-4">
				<div class="cards">
					<div class="card-body">
						<h3 class="card-title">Total Orders</h3>
						<h3 class="card-text text-right">
							{{totalOrdersCount}}</h3>

					</div>
				</div>
			</div>
			<div class="col-md-4">
				<div class="cards">
					<div class="card-body">
						<h3 class="card-title">Total Balance</h3>
						<h3 class="card-text text-right">{{convert_currency(user['balance'])}}</h3>
					</div>
				</div>
			</div>


		</div>

		<div class="col-md-8 col-md-offset-2">
			{% if convert_currency(user['balance']) < 5 %}
				<div class="alert alert-dismissible alert-danger">
					<button type="button" class="close" data-dismiss="alert">×</button>
					<strong>Dear @{{ user['username'] }},
					</strong>
					<br>{{ lang["neworder.low.balance"] }}
				</div>
			{% endif %}

			{% if error %}
				<div class="alert alert-dismissible alert-danger">
					{{ errorText }}
				</div>
			{% endif %}

			{% if data["order"]["success"] == 1 %}
				<div class="alert alert-dismissible alert-success">
					<strong>
						{{ lang["neworder.success.id"] }}:
					</strong>
					{{ data['order']['id'] }}
					<br>
					<strong>
						{{ lang["neworder.success.service"] }}:
					</strong>
					{{ data['order']['service'] }}
					<br>
					<strong>
						{{ lang["neworder.success.link"] }}:
					</strong>
					{{ data['order']['link'] }}
					<br>
					<strong>
						{{ lang["neworder.success.quantity"] }}:
					</strong>
					{{ data['order']['quantity'] }}
					<br>
					<strong>
						{{ lang["neworder.success.charge"] }}:
					</strong>
					{{convert_currency(data['order']['price'])}}
					<br>
					<strong>
						{{ lang["neworder.success.balance"] }}:
					</strong>
					{{convert_currency(data['order']['balance'])}}
					<br>
				</div>
			{% endif %}
			{% if data["order"]["success"] == 2 %}
				<div class="alert alert-dismissible alert-success">
					<strong>
						{{ lang["neworder.success.id"] }}:
					</strong>
					{{ data['order']['id'] }}
					<br>
					<strong>
						{{ lang["neworder.success.service"] }}:
					</strong>
					{{ data['order']['service'] }}
					<br>
					<strong>
						{{ lang["neworder.success.username"] }}:
					</strong>
					{{ data['order']['link'] }}
					<br>
					<strong>
						{{ lang["neworder.success.quantity"] }}:
					</strong>
					{{ data['order']['min'] }}
					-
					{{ data['order']['max'] }}
					<br>
					<strong>
						{{ lang["neworder.success.posts"] }}:
					</strong>
					{{ data['order']['posts'] }}
					<br>
					<strong>
						{{ lang["neworder.success.delay"] }}:
					</strong>
					{{ data['order']['delay'] }}
					<br>
				</div>
			{% endif %}

			<div class="well">

				<form method="POST" action="" id="neworder-form">


					<div class="form-group">
						{% if site["modules"]["category_filters"] %}
											<div class="category-filter-wrapper" id="category-filters"></div>
						{% endif %}
						{% if site["modules"]["search_services"] %}
							<div class="search-dropdown" id="new-order-search" style="position: relative;" data-lang-placeholder="Search">

								<div class="input-wrapper" style="position: relative;">
									<button type="button" id="searchServicesButtonIcon" class="input-wrapper__prepend">
										<span class="icon style-text-primary">
											<i class="fas fa-search"></i>
										</span>
									</button>
									<input type="text" class="form-control" id="searchServicesInputField" placeholder="Search Services...">
									<button type="button" class="input-wrapper__append" id="searchServicesInputClearButton">
										<span class="fas fa-times"></span>
									</button>
								</div>
							</div>

							<div class="select2-dropdown search-results" id="searchServicesResultsDropdown" style="display: none;"></div>
						</div>
					{% endif %}
					<div class="form-group">
						<label for="neworder-category" class="control-label">{{ lang["neworder.category"] }}</label>
						<select class="form-control" id="neworder-category" name="NewOrderForm[category]">
						</select>
					</div>

					<div class="form-group">
						<label for="neworder-service" class="control-label">{{ lang["neworder.service"] }}</label>
						<select class="form-control" id="neworder-service" name="NewOrderForm[service]"></select>
					</div>

					<div id="neworder_fields"></div>

					<div class="form-group" id="order_charge">
						<label for="charge" class="control-label">{{ lang["neworder.charge"] }}</label>
						<input type="text" class="form-control" id="neworder-charge" readonly>
					</div>

					<input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
					<button id="neworderbutton" type="submit" class="btn btn-primary">{{ lang["neworder.button"] }}</button>

				</form>
			</div>
		</div>

		{% if annoucements|length > 0 %}
		<div class="col-md-8 col-md-offset-2">
			<div class="well">
					<div class="headsir" style="padding: 0;margin: 0;">
						<svg style="margin-right: 5px;vertical-align: text-bottom;" width="30px" height="30px" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
							<g id="Layer_2" data-name="Layer 2">
							  <g id="invisible_box" data-name="invisible box">
								<rect width="48" height="48" fill="none"/>
							  </g>
							  <g id="Q3_icons" data-name="Q3 icons">
								<g>
								  <path d="M34,6h-.6l-30,8.8A2,2,0,0,0,2,16.8v9a2.2,2.2,0,0,0,1.4,2l30,8.8H34a2,2,0,0,0,2-2V8A2,2,0,0,0,34,6ZM19.1,34.2,8.4,31l1.3,8.4A2.9,2.9,0,0,0,12.6,42h4.5a2.8,2.8,0,0,0,2.1-1,3.4,3.4,0,0,0,.8-2.6Z"/>
								  <path d="M40,15.3a1.5,1.5,0,0,0,.9-.2l4-2a2,2,0,0,0-1.8-3.6l-4,2a2,2,0,0,0-.9,2.7A2.1,2.1,0,0,0,40,15.3Z"/>
								  <path d="M44.9,29.6l-4-2a2.1,2.1,0,0,0-2.7.8,2,2,0,0,0,.9,2.7l4,2a1.5,1.5,0,0,0,.9.2,2.1,2.1,0,0,0,1.8-1.1A1.9,1.9,0,0,0,44.9,29.6Z"/>
								  <path d="M40,23.3h4a2,2,0,0,0,0-4H40a2,2,0,0,0,0,4Z"/>
								</g>
							  </g>
							</g>
						  </svg>Announcements
					</div>
					<div class="ssw" style="padding: 10px;">
						{% for news in annoucements %}
						<div class="news-item" style="margin-top: 0;margin-bottom:4px;padding: 0 10px;background-color: rgb(0,0,0, 0.1);border-radius: 4px;">
							<div class="news-details">
								<p class="news-date" style="width: max-content;padding: 1px 6px;background-color: rgb(0,0,0,0.5);">
									<i class="fad fa-calendar-alt mr-1" style="--fa-secondary-opacity: 0.65;"></i>
									{{ show_date(news['updated_at'])|date("jS M, Y g:i A") }}</p>
								<h4 id="service_description" class=" news-title" style="display:block;text-align:left;">
									<span class="icon-container">
										<img src="{{site['url'] ~ '/public/icons/' ~ news['news_icon'] ~ '.png' }}" alt="{{news['news_icon']}}" widht="30" height="30">
									</span>
									<span class="title">{{ news['news_title'] }}</span>
								</h4>
								<p id="service_description" class="news-content" style="border-top-left-radius:0px;border-top-right-radius:0px;">{{ news['news_content'] }}</p>
							</div>
							</div>
						{% endfor %}
						</div>
			</div>
		</div>
		{% endif %}


		{% if contentTextBottom is not empty %}
			<div class="col-md-12">
				<div class="well ">
					{{ contentTextBottom }}
				</div>
			</div>
		{% endif %}
	</div>
</div>

{% include 'footer.twig' %}
