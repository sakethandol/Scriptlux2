{% include 'header.twig' %}
<style>

    .section-hunter-cream {
        background-color: var(--color-accent);
        background-image:
            radial-gradient(at 0% 0%, rgba(255, 252, 222, 0.18) 0px, transparent 55%),
            radial-gradient(at 100% 100%, rgba(255, 252, 222, 0.14) 0px, transparent 55%),
            radial-gradient(at 0% 100%, rgba(255, 252, 222, 0.08) 0px, transparent 45%),
            radial-gradient(at 100% 0%, rgba(255, 252, 222, 0.06) 0px, transparent 45%),
            radial-gradient(at 50% 50%, rgba(255, 252, 222, 0.12) 0px, transparent 75%),
            linear-gradient(
                152deg,
                rgba(255, 252, 222, 0.06) 0%,
                rgba(255, 252, 222, 0.00) 40%,
                rgba(255, 252, 222, 0.04) 100%
            );
        background-attachment: fixed;
        position: relative;
        isolation: isolate;
        overflow: hidden;
        min-height: 100vh;
        padding: 120px 0 80px;
    }

    .section-hunter-cream::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0.5;
        background-image:
            radial-gradient(circle, rgba(255, 252, 222, 0.12) 1px, transparent 1px),
            radial-gradient(circle, rgba(255, 252, 222, 0.05) 1.5px, transparent 1.5px);
        background-size: 28px 28px, 56px 56px;
        background-position: 0 0, 14px 14px;
        z-index: 0;
    }

    .blog-wrapper { position: relative; z-index: 1; }

    /* Blog Card Styling */
    .blog-card {
        background: var(--color-bg);
        border-radius: 30px;
        border: 1px solid var(--color-border);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        overflow: hidden;
    }

    .blog-hero-img {
        width: 100%;
        height: auto;
        max-height: 500px;
        object-fit: cover;
        border-bottom: 1px solid var(--color-border);
    }

    .blog-content-area {
        padding: 3rem;
        color: var(--color-text);
        line-height: 1.8;
        font-size: 1.1rem;
    }

    .blog-title {
        font-weight: 900;
        letter-spacing: -1.5px;
        color: var(--color-accent);
        line-height: 1.1;
        margin-bottom: 2rem;
    }

    /* Back Button & Sidebar */
    .sticky-back {
        position: sticky;
        top: 120px;
    }

    .btn-hunter-outline {
        background: transparent;
        border: 2px solid rgba(255, 252, 222, 0.3);
        color: var(--color-accent-contrast);
        padding: 12px 25px;
        border-radius: 12px;
        font-weight: 700;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .btn-hunter-outline:hover {
        background: var(--color-accent-contrast);
        color: var(--color-accent);
        transform: translateX(-5px);
    }

    /* Text formatting inside blog content */
    .blog-content-area h1, .blog-content-area h2, .blog-content-area h3 {
        color: var(--color-accent);
        font-weight: 800;
        margin-top: 2.5rem;
    }

    @media (max-width: 768px) {
        .blog-content-area { padding: 1.5rem; }
        .blog-title { font-size: 2rem; }
        .section-hunter-cream {
            padding-top: calc(110px + env(safe-area-inset-top));
        }
    }

    @media (max-width: 991px) {
        .section-hunter-cream {
            background-attachment: scroll;
        }
    }
</style>

<div class="section-hunter-cream">
    <div class="container blog-wrapper">
        <div class="row g-5">
            <div class="col-md-3 d-none d-md-block">
                <div class="sticky-back">
                    <a href="{{ site['url'] }}/blog" class="btn-hunter-outline">
                        <i class="fa-solid fa-arrow-left"></i> Go Back
                    </a>
                    <div class="mt-4 opacity-50 text-white small">
                        <p>Published in <br><strong>Official Blog</strong></p>
                    </div>
                </div>
            </div>

            <div class="col-md-9 col-lg-8">
                <div class="blog-card">
                    {% if blogs['blog_thumbnail'] %}
                        <img src="{{ blogs['blog_thumbnail'] }}" class="blog-hero-img" alt="Thumbnail">
                    {% endif %}
                    
                    <div class="blog-content-area">
                        <h1 class="blog-title display-5">{{ blogs['blog_title'] }}</h1>
                        
                        <div class="blog-text">
                            {{ blogs['blog_content'] | raw }}
                        </div>

                        <div class="mt-5 pt-4 border-top d-md-none text-center">
                             <a href="{{ site['url'] }}/blog" class="btn btn-dark px-4 py-2" style="border-radius: 10px;">
                                <i class="fa-solid fa-arrow-left me-2"></i> Go Back 
                             </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% include 'footer.twig' %}