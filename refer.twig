{% include 'header.twig' %}

<style>
  html { scroll-behavior: smooth; }
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .stat-card { transition: transform 0.22s ease, box-shadow 0.22s ease; }
  .stat-card:hover { transform: translateY(-5px); box-shadow: 0 14px 36px var(--color-border) !important; }
  .payout-row { transition: background 0.15s ease, transform 0.15s ease; }
  .payout-row:hover { background: var(--color-hover-bg) !important; transform: translateX(3px); }
  .copy-btn { transition: all 0.18s ease; cursor: pointer; }
  .copy-btn:hover { opacity: 0.8; }
  .donut-wrap { position: relative; width: 140px; height: 140px; flex-shrink: 0; }
  .donut-wrap canvas { width: 140px !important; height: 140px !important; }
  .donut-center {
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    text-align: center; pointer-events: none; line-height: 1.2;
  }
  .progress-bar-custom {
    height: 6px; border-radius: 50px;
    background: var(--color-hover-bg); overflow: hidden;
  }
  .progress-bar-fill {
    height: 100%; border-radius: 50px;
    background: var(--color-accent);
    transition: width 1.2s cubic-bezier(.4,0,.2,1);
  }
  @media (max-width: 576px) {
    .hero-title { font-size: 1.3rem; }
    .donut-wrap { width: 110px; height: 110px; }
    .donut-wrap canvas { width: 110px !important; height: 110px !important; }
  }
</style>

<div class="min-vh-100 pb-5" style="background-color: var(--color-bg); color: var(--color-text);">


  <div style="background: var(--color-accent); position: relative; overflow: hidden;">
    <div style="position:absolute;top:-90px;right:-90px;width:300px;height:300px;
                border-radius:50%;background:rgba(214,255,246,0.05);pointer-events:none;"></div>
    <div style="position:absolute;bottom:-70px;left:60px;width:200px;height:200px;
                border-radius:50%;background:rgba(214,255,246,0.04);pointer-events:none;"></div>
    <div style="position:absolute;top:20px;left:40%;width:120px;height:120px;
                border-radius:50%;background:rgba(214,255,246,0.03);pointer-events:none;"></div>

    <div class="container-fluid px-3 px-md-5 py-5">
      <div class="row align-items-center g-4">

        <div class="col-12 col-md-7">
          <div class="d-flex align-items-center gap-3 mb-3">
            <div style="width:52px;height:52px;border-radius:14px;
                        background:rgba(214,255,246,0.12);
                        display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-hand-holding-usd"
                 style="color:var(--color-accent-contrast);font-size:1.3rem;"></i>
            </div>
            <div>
              <p class="mb-0 fw-semibold"
                 style="color:var(--color-accent-contrast);opacity:0.5;
                        font-size:0.7rem;letter-spacing:2px;text-transform:uppercase;">
                Earn Together
              </p>
              <h1 class="hero-title fw-bold mb-0"
                  style="color:var(--color-accent-contrast);letter-spacing:-0.5px;font-size:1.75rem;">
                Referral Program
              </h1>
            </div>
          </div>
          <p style="color:var(--color-accent-contrast);opacity:0.5;
                    font-size:0.85rem;max-width:440px;line-height:1.6;">
            Share your unique link, earn
            <strong style="color:var(--color-accent-contrast);opacity:1;">
              {{ settings["referral_commision"] }}%
            </strong>
            commission on every referral. Cash out when you hit the minimum payout threshold.
          </p>
          <div class="d-flex flex-wrap gap-2 mt-3">
            <span style="display:inline-flex;align-items:center;gap:7px;font-size:0.72rem;
                         font-weight:600;padding:6px 14px;border-radius:50px;
                         background:rgba(214,255,246,0.1);color:var(--color-accent-contrast);">
              <i class="fas fa-percentage" style="font-size:0.7rem;opacity:0.75;"></i>
              {{ settings["referral_commision"] }}% Commission
            </span>
            <span style="display:inline-flex;align-items:center;gap:7px;font-size:0.72rem;
                         font-weight:600;padding:6px 14px;border-radius:50px;
                         background:rgba(214,255,246,0.1);color:var(--color-accent-contrast);">
              <i class="fas fa-bolt" style="font-size:0.7rem;opacity:0.75;"></i>
              Instant Tracking
            </span>
            <span style="display:inline-flex;align-items:center;gap:7px;font-size:0.72rem;
                         font-weight:600;padding:6px 14px;border-radius:50px;
                         background:rgba(214,255,246,0.1);color:var(--color-accent-contrast);">
              <i class="fas fa-wallet" style="font-size:0.7rem;opacity:0.75;"></i>
              Min. {{ convert_currency(settings["referral_payout"]) }} Payout
            </span>
          </div>
        </div>

        <!-- Referral link box in hero -->
        <div class="col-12 col-md-5">
          <div class="p-4 rounded-4"
               style="background:rgba(214,255,246,0.08);border:1.5px dashed rgba(214,255,246,0.2);">
            <p class="mb-2 fw-semibold"
               style="color:var(--color-accent-contrast);opacity:0.45;
                      font-size:0.68rem;letter-spacing:1.5px;text-transform:uppercase;">
              Your Referral Link
            </p>
            <div class="d-flex align-items-center gap-2">
              <code id="refLink"
                    style="font-size:0.75rem;color:var(--color-text);opacity:0.8;
                           word-break:break-all;flex-grow:1;line-height:1.5;font-family:monospace;">
                {{ site["url"] }}/affiliates?ref={{ user['ref_code'] }}
              </code>
            </div>
            <button onclick="copyRef()" class="copy-btn btn w-100 fw-bold mt-3 py-2"
                    style="background:var(--color-accent-contrast);color:var(--color-accent);
                           border-radius:10px;font-size:0.82rem;border:none;" id="copyBtn">
              <i class="fas fa-copy me-2" style="font-size:0.78rem;"></i> Copy Link
            </button>
          </div>
        </div>

      </div>
    </div>
  </div>

  <div class="container-fluid px-3 px-md-5 mt-4">

    {% if error %}
      <div class="d-flex align-items-start gap-3 p-3 mb-4 rounded-3"
           style="background:rgba(220,53,69,0.08);border-left:4px solid #dc3545;
                  border:1px solid rgba(220,53,69,0.15);">
        <i class="fas fa-exclamation-circle mt-1"
           style="color:#dc3545;flex-shrink:0;font-size:0.85rem;"></i>
        <div style="font-size:0.85rem;color:#dc3545;">{{ errorText }}</div>
      </div>
    {% endif %}
    {% if success %}
      <div class="d-flex align-items-start gap-3 p-3 mb-4 rounded-3"
           style="background:rgba(25,135,84,0.08);border-left:4px solid #198754;
                  border:1px solid rgba(25,135,84,0.15);">
        <i class="fas fa-check-circle mt-1"
           style="color:#198754;flex-shrink:0;font-size:0.85rem;"></i>
        <div style="font-size:0.85rem;color:#198754;">{{ successText }}</div>
      </div>
    {% endif %}

    {% if contentText is not empty %}
      <div class="d-flex align-items-start gap-3 p-4 mb-4"
           style="background:var(--color-accent-contrast);border-left:4px solid var(--color-accent);
                  border-radius:14px;border:1px solid var(--color-border);">
        <i class="fas fa-info-circle mt-1"
           style="color:var(--color-accent);opacity:0.6;flex-shrink:0;"></i>
        <div style="font-size:0.88rem;line-height:1.6;">{{ contentText }}</div>
      </div>
    {% endif %}


    <div class="row g-4 mb-4">

      <!-- Donut 1: Conversion Rate -->
      <div class="col-12 col-md-6 col-lg-4">
        <div class="stat-card h-100 p-4 rounded-4"
             style="background:var(--color-accent-contrast);border:1px solid var(--color-border);">
          <div class="d-flex align-items-center gap-4">
            <div class="donut-wrap">
              <canvas id="donutConversion"></canvas>
              <div class="donut-center">
                <div class="fw-bold" style="font-size:1.05rem;color:var(--color-text);">
                  {{ ref_content['ref_conversion_rate'] }}%
                </div>
                <div style="font-size:0.58rem;color:var(--color-text);opacity:0.45;
                            text-transform:uppercase;letter-spacing:0.5px;">
                  Rate
                </div>
              </div>
            </div>
            <div class="flex-grow-1">
              <p class="mb-1 fw-semibold"
                 style="font-size:0.7rem;color:var(--color-text);opacity:0.5;
                        text-transform:uppercase;letter-spacing:0.5px;">
                Conversion Rate
              </p>
              <p class="mb-3 fw-bold" style="font-size:1.5rem;color:var(--color-text);line-height:1.1;">
                {{ ref_content['ref_conversion_rate'] }}%
              </p>
              <div class="d-flex flex-column gap-2">
                <div class="d-flex justify-content-between small mb-1"
                     style="font-size:0.72rem;opacity:0.6;">
                  <span>Visits</span>
                  <span class="fw-bold">{{ ref_content['referral_clicks'] }}</span>
                </div>
                <div class="progress-bar-custom">
                  <div class="progress-bar-fill"
                       style="width:{{ ref_content['ref_conversion_rate'] }}%;
                              background:var(--color-accent);"></div>
                </div>
                <div class="d-flex justify-content-between small"
                     style="font-size:0.72rem;opacity:0.6;">
                  <span>Sign-ups</span>
                  <span class="fw-bold">{{ ref_content['referral_sign_up'] }}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-md-6 col-lg-4">
        <div class="stat-card h-100 p-4 rounded-4"
             style="background:var(--color-accent-contrast);border:1px solid var(--color-border);">
          <div class="d-flex align-items-center gap-4">
            <div class="donut-wrap">
              <canvas id="donutEarnings"></canvas>
              <div class="donut-center">
                <div class="fw-bold" style="font-size:0.7rem;color:var(--color-text);">Total</div>
                <div class="fw-bold" style="font-size:0.78rem;color:var(--color-text);">
                  {{ convert_currency(ref_content["referral_total_commision"]) }}
                </div>
              </div>
            </div>
            <div class="flex-grow-1">
              <p class="mb-2 fw-semibold"
                 style="font-size:0.7rem;color:var(--color-text);opacity:0.5;
                        text-transform:uppercase;letter-spacing:0.5px;">
                Earnings Split
              </p>
              <div class="d-flex flex-column gap-2">
                <div class="d-flex align-items-center justify-content-between">
                  <span class="d-flex align-items-center gap-2"
                        style="font-size:0.75rem;color:var(--color-text);">
                    <span style="width:9px;height:9px;border-radius:50%;
                                 background:#198754;flex-shrink:0;"></span>
                    Paid
                  </span>
                  <span class="fw-bold" style="font-size:0.78rem;">
                    {{ convert_currency(ref_content["referral_earned_commision"]) }}
                  </span>
                </div>
                <div class="d-flex align-items-center justify-content-between">
                  <span class="d-flex align-items-center gap-2"
                        style="font-size:0.75rem;color:var(--color-text);">
                    <span style="width:9px;height:9px;border-radius:50%;
                                 background:#0284c7;flex-shrink:0;"></span>
                    Unpaid
                  </span>
                  <span class="fw-bold" style="font-size:0.78rem;">
                    {{ convert_currency(ref_content["ref_unpaid_earning"]) }}
                  </span>
                </div>
                <div class="d-flex align-items-center justify-content-between">
                  <span class="d-flex align-items-center gap-2"
                        style="font-size:0.75rem;color:var(--color-text);">
                    <span style="width:9px;height:9px;border-radius:50%;
                                 background:#dc3545;flex-shrink:0;"></span>
                    Rejected
                  </span>
                  <span class="fw-bold" style="font-size:0.78rem;">
                    {{ convert_currency(ref_content["referral_rejected_commision"]) }}
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-md-12 col-lg-4">
        <div class="stat-card h-100 p-4 rounded-4 d-flex flex-column justify-content-between"
             style="background:var(--color-accent);border:1px solid var(--color-accent);">
          <div>
            <div style="width:44px;height:44px;border-radius:12px;
                        background:rgba(214,255,246,0.12);
                        display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
              <i class="fas fa-money-bill-wave"
                 style="color:var(--color-accent-contrast);font-size:1rem;"></i>
            </div>
            <p class="mb-1 fw-semibold"
               style="color:var(--color-accent-contrast);opacity:0.55;
                      font-size:0.7rem;text-transform:uppercase;letter-spacing:0.5px;">
              Available to Withdraw
            </p>
            <p class="fw-bold mb-1"
               style="color:var(--color-accent-contrast);font-size:2rem;line-height:1.1;">
              {{ convert_currency(ref_content["ref_unpaid_earning"]) }}
            </p>
            <p class="mb-4"
               style="color:var(--color-accent-contrast);opacity:0.4;font-size:0.75rem;">
              Minimum payout:
              <strong style="opacity:1;">{{ convert_currency(settings["referral_payout"]) }}</strong>
            </p>
          </div>
          <a href="{{ site["url"] }}/refer/paid-out" class="text-decoration-none">
            <button {{ ref_content["paid_out_allowed"] }} type="button"
                    class="btn fw-bold w-100 py-3"
                    style="background:var(--color-accent-contrast);color:var(--color-accent);
                           border-radius:12px;font-size:0.88rem;border:none;letter-spacing:0.3px;">
              <i class="fas fa-paper-plane me-2" style="font-size:0.8rem;"></i>
              Request Payout
            </button>
          </a>
        </div>
      </div>

    </div>


    <div class="row g-3 mb-5">

      {% set quick = [
        {'icon':'fa-mouse-pointer', 'label':'Total Visits',     'val': ref_content['referral_clicks'],      'color':'#0284c7'},
        {'icon':'fa-user-plus',     'label':'Sign-ups',         'val': ref_content['referral_sign_up'],     'color':'#198754'},
        {'icon':'fa-coins',         'label':'Total Earned',     'val': convert_currency(ref_content["referral_total_commision"]), 'color':'#d97706'},
        {'icon':'fa-times-circle',  'label':'Rejected',         'val': convert_currency(ref_content["referral_rejected_commision"]), 'color':'#dc3545'}
      ] %}

      {% for q in quick %}
        <div class="col-6 col-lg-3">
          <div class="stat-card p-3 p-md-4 rounded-4 d-flex align-items-center gap-3"
               style="background:var(--color-accent-contrast);border:1px solid var(--color-border);">
            <div style="width:42px;height:42px;border-radius:11px;flex-shrink:0;
                        display:flex;align-items:center;justify-content:center;
                        background:{{ q.color }}1a;">
              <i class="fas {{ q.icon }}" style="color:{{ q.color }};font-size:0.9rem;"></i>
            </div>
            <div class="min-width-0">
              <p class="mb-0 fw-semibold"
                 style="font-size:0.65rem;color:var(--color-text);opacity:0.45;
                        text-transform:uppercase;letter-spacing:0.5px;white-space:nowrap;">
                {{ q.label }}
              </p>
              <p class="mb-0 fw-bold"
                 style="font-size:1rem;color:var(--color-text);line-height:1.3;">
                {{ q.val }}
              </p>
            </div>
          </div>
        </div>
      {% endfor %}

    </div>

    <div class="mb-5">
      <div class="d-flex align-items-center gap-3 mb-4">
        <div style="width:40px;height:40px;border-radius:10px;background:var(--color-accent);
                    display:flex;align-items:center;justify-content:center;">
          <i class="fas fa-map-signs"
             style="color:var(--color-accent-contrast);font-size:0.9rem;"></i>
        </div>
        <h5 class="fw-bold mb-0" style="color:var(--color-text);font-size:1rem;">
          How It Works
        </h5>
      </div>

      <div class="row g-3">
        {% set steps = [
          {'num':'01','icon':'fa-link',           'title':'Share Your Link',   'desc':'Copy your unique referral link and share it on social media, blogs, or with friends.'},
          {'num':'02','icon':'fa-user-check',     'title':'They Sign Up',      'desc':'When someone clicks your link and creates an account, they are tracked as your referral.'},
          {'num':'03','icon':'fa-shopping-cart',  'title':'They Place Orders', 'desc':'Every time your referral places an order you earn a ' ~ settings["referral_commision"] ~ '% commission automatically.'},
          {'num':'04','icon':'fa-wallet',         'title':'You Get Paid',      'desc':'Once your unpaid balance reaches the minimum payout of ' ~ convert_currency(settings["referral_payout"]) ~ ', you can request a withdrawal.'}
        ] %}
        {% for s in steps %}
          <div class="col-12 col-sm-6 col-lg-3">
            <div class="stat-card h-100 p-4 rounded-4 position-relative overflow-hidden"
                 style="background:var(--color-accent-contrast);border:1px solid var(--color-border);">
              <div style="position:absolute;top:-10px;right:10px;font-size:4rem;font-weight:900;
                          color:var(--color-text);opacity:0.04;line-height:1;pointer-events:none;
                          user-select:none;">
                {{ s.num }}
              </div>
              <div style="width:42px;height:42px;border-radius:11px;background:var(--color-hover-bg);
                          display:flex;align-items:center;justify-content:center;margin-bottom:14px;">
                <i class="fas {{ s.icon }}" style="color:var(--color-accent);font-size:0.95rem;"></i>
              </div>
              <span style="font-size:0.62rem;font-weight:700;letter-spacing:1px;
                           color:var(--color-accent);opacity:0.5;text-transform:uppercase;">
                Step {{ s.num }}
              </span>
              <h6 class="fw-bold mt-1 mb-2" style="color:var(--color-text);font-size:0.9rem;">
                {{ s.title }}
              </h6>
              <p class="mb-0 small" style="color:var(--color-text);opacity:0.5;
                         line-height:1.55;font-size:0.78rem;">
                {{ s.desc }}
              </p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="d-flex align-items-center gap-3 mb-3">
      <div style="width:40px;height:40px;border-radius:10px;background:var(--color-accent);
                  display:flex;align-items:center;justify-content:center;">
        <i class="fas fa-history"
           style="color:var(--color-accent-contrast);font-size:0.9rem;"></i>
      </div>
      <div>
        <h5 class="fw-bold mb-0" style="color:var(--color-text);font-size:1rem;">
          Payout History
        </h5>
        <p class="mb-0 small" style="color:var(--color-text);opacity:0.45;font-size:0.75rem;">
          All your withdrawal requests and their status
        </p>
      </div>
    </div>

    <div class="rounded-4 overflow-hidden mb-4"
         style="background:var(--color-accent-contrast);border:1px solid var(--color-border);">
      <div class="table-responsive">
        <table class="table mb-0 align-middle">
          <thead>
            <tr style="background:var(--color-accent);">
              <th class="px-4 py-3 border-0 fw-semibold"
                  style="color:var(--color-accent-contrast);font-size:0.72rem;
                         letter-spacing:0.6px;text-transform:uppercase;white-space:nowrap;">
                {{ lang["referral.payout.requested.at"] }}
              </th>
              <th class="px-3 py-3 border-0 fw-semibold"
                  style="color:var(--color-accent-contrast);font-size:0.72rem;
                         letter-spacing:0.6px;text-transform:uppercase;white-space:nowrap;">
                {{ lang["referral.payout.payment.amount"] }}
              </th>
              <th class="px-3 py-3 border-0 fw-semibold"
                  style="color:var(--color-accent-contrast);font-size:0.72rem;
                         letter-spacing:0.6px;text-transform:uppercase;white-space:nowrap;">
                {{ lang["referral.payout.updated.at"] }}
              </th>
              <th class="px-3 py-3 border-0 fw-semibold"
                  style="color:var(--color-accent-contrast);font-size:0.72rem;
                         letter-spacing:0.6px;text-transform:uppercase;white-space:nowrap;">
                {{ lang["referral.payout.payout.status"] }}
              </th>
            </tr>
          </thead>
          <tbody>

            {% for ref_payout in ref_payouts %}

              {% if ref_payout['r_p_status'] == 0 %}
                {% set p_bg    = 'rgba(217,119,6,0.1)'  %}
                {% set p_color = '#d97706'               %}
                {% set p_icon  = 'fa-clock'              %}
                {% set p_label = lang["referral.payout.status.pending"] %}
              {% elseif ref_payout['r_p_status'] == 1 %}
                {% set p_bg    = 'rgba(220,53,69,0.1)'  %}
                {% set p_color = '#dc3545'               %}
                {% set p_icon  = 'fa-times-circle'       %}
                {% set p_label = lang["referral.payout.status.disapproved"] %}
              {% elseif ref_payout['r_p_status'] == 2 %}
                {% set p_bg    = 'rgba(25,135,84,0.1)'  %}
                {% set p_color = '#198754'               %}
                {% set p_icon  = 'fa-check-circle'       %}
                {% set p_label = lang["referral.payout.status.approved"] %}
              {% elseif ref_payout['r_p_status'] == 3 %}
                {% set p_bg    = 'rgba(108,117,125,0.1)' %}
                {% set p_color = '#6c757d'               %}
                {% set p_icon  = 'fa-ban'                %}
                {% set p_label = lang["referral.payout.status.rejected"] %}
              {% else %}
                {% set p_bg    = 'rgba(20,40,29,0.06)'  %}
                {% set p_color = 'var(--color-text)'     %}
                {% set p_icon  = 'fa-dot-circle'         %}
                {% set p_label = '-'                     %}
              {% endif %}

              <tr class="payout-row"
                  style="border-bottom:1px solid var(--color-border);">

                <!-- Requested At -->
                <td class="px-4 py-3">
                  <span class="d-flex align-items-center gap-2"
                        style="font-size:0.82rem;color:var(--color-text);opacity:0.65;white-space:nowrap;">
                    <i class="fas fa-calendar-alt"
                       style="color:var(--color-accent);font-size:0.65rem;opacity:0.6;"></i>
                    {{ ref_payout['r_p_requested_at'] }}
                  </span>
                </td>

                <!-- Amount -->
                <td class="px-3 py-3">
                  <span class="fw-bold d-flex align-items-center gap-1"
                        style="color:#198754;font-size:0.88rem;">
                    <i class="fas fa-coins"
                       style="font-size:0.65rem;opacity:0.7;"></i>
                    {{ curr_symbol }}{{ convert_currency(ref_payout['r_p_amount_requested']) }}
                  </span>
                </td>

                <!-- Updated At -->
                <td class="px-3 py-3">
                  <span style="font-size:0.8rem;color:var(--color-text);opacity:0.55;white-space:nowrap;">
                    {{ ref_payout['r_p_updated_at'] }}
                  </span>
                </td>

                <!-- Status -->
                <td class="px-3 py-3">
                  <span style="display:inline-flex;align-items:center;gap:5px;
                               font-size:0.7rem;font-weight:700;letter-spacing:0.4px;
                               padding:4px 12px;border-radius:50px;
                               background:{{ p_bg }};color:{{ p_color }};">
                    <i class="fas {{ p_icon }}" style="font-size:0.6rem;"></i>
                    {{ p_label }}
                  </span>
                </td>

              </tr>
            {% endfor %}

            <!-- Empty state -->
            {% if ref_payouts is empty %}
              <tr>
                <td colspan="4" class="text-center py-5">
                  <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle"
                       style="width:68px;height:68px;background:var(--color-hover-bg);">
                    <i class="fas fa-wallet"
                       style="font-size:1.5rem;color:var(--color-accent);opacity:0.35;"></i>
                  </div>
                  <p class="fw-bold mb-1" style="color:var(--color-text);font-size:0.9rem;">
                    No payouts yet
                  </p>
                  <p class="small mb-0" style="color:var(--color-text);opacity:0.45;">
                    Your payout requests will appear here once submitted.
                  </p>
                </td>
              </tr>
            {% endif %}

          </tbody>
        </table>
      </div>
    </div>

    {% if contentTextBottom is not empty %}
      <div class="d-flex align-items-start gap-3 p-4 mt-2"
           style="background:var(--color-accent-contrast);border-left:4px solid var(--color-accent);
                  border-radius:14px;border:1px solid var(--color-border);">
        <i class="fas fa-info-circle mt-1"
           style="color:var(--color-accent);opacity:0.6;flex-shrink:0;"></i>
        <div style="font-size:0.88rem;line-height:1.6;">{{ contentTextBottom }}</div>
      </div>
    {% endif %}

  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
<script>
  function copyRef() {
    var text = document.getElementById('refLink').innerText.trim();
    navigator.clipboard.writeText(text).then(function() {
      var btn = document.getElementById('copyBtn');
      btn.innerHTML = '<i class="fas fa-check me-2"></i> Copied!';
      btn.style.background = '#198754';
      btn.style.color = '#fff';
      setTimeout(function() {
        btn.innerHTML = '<i class="fas fa-copy me-2"></i> Copy Link';
        btn.style.background = 'var(--color-accent-contrast)';
        btn.style.color = 'var(--color-accent)';
      }, 2500);
    });
  }

  /* ── Accent color detection ── */
  var accentColor = getComputedStyle(document.documentElement)
                      .getPropertyValue('--color-accent').trim() || '#231651';
  var hoverColor  = getComputedStyle(document.documentElement)
                      .getPropertyValue('--color-hover-bg').trim() || '#C1F2E8';

  /* ── Donut 1: Conversion rate ── */
  var convRate = parseFloat('{{ ref_content["ref_conversion_rate"] }}') || 0;
  new Chart(document.getElementById('donutConversion'), {
    type: 'doughnut',
    data: {
      datasets: [{
        data: [convRate, Math.max(0, 100 - convRate)],
        backgroundColor: [accentColor, hoverColor],
        borderWidth: 0,
        hoverOffset: 4
      }]
    },
    options: {
      cutout: '72%',
      plugins: { legend: { display: false }, tooltip: { enabled: false } },
      animation: { animateRotate: true, duration: 1200 }
    }
  });

  /* ── Donut 2: Earnings split ── */
  var paid     = parseFloat('{{ ref_content["referral_earned_commision"] }}')   || 0;
  var unpaid   = parseFloat('{{ ref_content["ref_unpaid_earning"] }}')          || 0;
  var rejected = parseFloat('{{ ref_content["referral_rejected_commision"] }}') || 0;
  var total    = paid + unpaid + rejected || 1;
  new Chart(document.getElementById('donutEarnings'), {
    type: 'doughnut',
    data: {
      datasets: [{
        data: [paid, unpaid, rejected],
        backgroundColor: ['#198754', '#0284c7', '#dc3545'],
        borderWidth: 0,
        hoverOffset: 4
      }]
    },
    options: {
      cutout: '72%',
      plugins: { legend: { display: false }, tooltip: { enabled: false } },
      animation: { animateRotate: true, duration: 1400 }
    }
  });
</script>

