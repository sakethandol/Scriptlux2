{% include 'header.twig' %}

<style>
  html { scroll-behavior: smooth; }
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .order-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .order-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(20,40,29,0.13) !important; }
  .status-filter-btn { transition: all 0.18s ease; }
  .page-link { transition: all 0.18s ease; }
  .link-pill { transition: background 0.15s; }
  .link-pill:hover { opacity: 0.85; }
  .badge-status { font-size: 0.68rem; letter-spacing: 0.6px; padding: 5px 10px; }
  .copy-id {
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .copy-id:hover { opacity: 0.7; }
  .copy-toast {
    position: fixed;
    top: 22px;
    left: 50%;
    transform: translate(-50%, -20px) scale(0.96);
    opacity: 0;
    pointer-events: none;
    z-index: 1060;
    background: var(--color-text);
    color: var(--color-bg);
    border-radius: 999px;
    padding: 12px 22px;
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.35px;
    box-shadow: 0 14px 34px rgba(20, 40, 29, 0.28);
    transition: opacity 0.22s ease, transform 0.28s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .copy-toast.show {
    opacity: 1;
    transform: translate(-50%, 0) scale(1);
  }
  .copy-toast.error {
    background: #dc3545;
    color: #fff;
  }
  @media (max-width: 576px) {
    .hero-title { font-size: 1.3rem; }
    .order-grid .col-12 { padding-left: 8px; padding-right: 8px; }
    .copy-toast { padding: 10px 16px; font-size: 0.84rem; }
  }
</style>

<div class="min-vh-100 pb-5" style="background-color: var(--color-bg); color: var(--color-text);">
  <div id="copyToast" class="copy-toast" role="status" aria-live="polite">Copied!</div>
  <div class="py-4 mb-2" style="background: linear-gradient(135deg, var(--color-accent) 0%, #1e3d2b 100%);">
    <div class="container-fluid px-3 px-md-5">
      <div class="row align-items-center g-3">
        <div class="col-12 col-md-5">
          <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center justify-content-center rounded-3 shadow"
                 style="width:48px;height:48px;background:rgba(255,252,237,0.12);">
              <i class="fas fa-receipt" style="color:var(--color-accent-contrast);font-size:1.25rem;"></i>
            </div>
            <div>
              <h1 class="hero-title fw-bold mb-0" style="color:var(--color-accent-contrast);letter-spacing:-0.5px;">
                My Orders
              </h1>
              <p class="mb-0 small" style="color:rgba(255,252,237,0.65);">
                Manage your active service requests
              </p>
            </div>
          </div>
        </div>

        <!-- Search -->
        <div class="col-12 col-md-7">
          <form action="" method="get">
            <div class="input-group shadow" style="border-radius:50px;overflow:hidden;">
              <span class="input-group-text border-0 px-3" style="background:#fff;">
                <i class="fa fa-search" style="color:var(--color-accent);opacity:0.6;"></i>
              </span>
              <input type="text" name="search"
                     class="form-control border-0 shadow-none py-2"
                     value="{{ search }}"
                     placeholder="Search by order ID, service or link..."
                     style="background:#fff;color:#14281D;font-size:0.9rem;">
              <button type="submit" class="btn border-0 px-4 fw-bold"
                      style="background-color:var(--color-accent-contrast);color:var(--color-accent);font-size:0.85rem;border-radius:0 50px 50px 0;">
                <i class="fa fa-search me-1"></i> Search
              </button>
            </div>
          </form>
        </div>

      </div>
    </div>
  </div>

  <div class="container-fluid px-3 px-md-5 mt-4">
    <div class="d-flex overflow-auto no-scrollbar gap-2 pb-2" style="white-space:nowrap;">
      {% set statuses = ['all', 'pending', 'inprogress', 'completed', 'partial', 'processing', 'canceled'] %}
      {% for s in statuses %}
        {% set pill_color = '#6c757d' %}
        {% if s == 'completed' %}
          {% set pill_color = '#198754' %}
        {% elseif s == 'pending' %}
          {% set pill_color = '#d97706' %}
        {% elseif s == 'inprogress' %}
          {% set pill_color = '#0284c7' %}
        {% elseif s == 'partial' %}
          {% set pill_color = '#7c3aed' %}
        {% elseif s == 'processing' %}
          {% set pill_color = '#0891b2' %}
        {% elseif s == 'canceled' %}
          {% set pill_color = '#dc3545' %}
        {% endif %}

        <a href="orders/{{ s == 'all' ? '' : s }}"
           class="btn btn-sm status-filter-btn fw-semibold px-4 py-2 rounded-pill border-0 shadow-sm flex-shrink-0"
           style="{% if s == status %}
                    background-color:{{ pill_color }};color:#fff;
                  {% else %}
                    background-color:#fff;color:{{ pill_color }};border:1.5px solid {{ pill_color }} !important;
                  {% endif %}
                  font-size:0.78rem;letter-spacing:0.3px;">
          {{ lang['orders.status.' ~ s] }}
        </a>
      {% endfor %}
    </div>
  </div>

  <div class="container-fluid px-3 px-md-5 mt-4">
    <div class="row g-3 order-grid">

      {% for order in orders %}
      <div class="col-12 col-sm-6 col-lg-4 col-xl-3">

        {% set status_color = '#6c757d' %}
        {% set status_bg = 'rgba(108,117,125,0.10)' %}
        {% set status_border = 'rgba(108,117,125,0.35)' %}
        {% if order['status'] == 'Completed' %}
          {% set status_color = '#198754' %}{% set status_bg = 'rgba(25,135,84,0.10)' %}{% set status_border = 'rgba(25,135,84,0.35)' %}
        {% elseif order['status'] == 'Pending' %}
          {% set status_color = '#d97706' %}{% set status_bg = 'rgba(217,119,6,0.10)' %}{% set status_border = 'rgba(217,119,6,0.35)' %}
        {% elseif order['status'] == 'In progress' %}
          {% set status_color = '#0284c7' %}{% set status_bg = 'rgba(2,132,199,0.10)' %}{% set status_border = 'rgba(2,132,199,0.35)' %}
        {% elseif order['status'] == 'Canceled' %}
          {% set status_color = '#dc3545' %}{% set status_bg = 'rgba(220,53,69,0.10)' %}{% set status_border = 'rgba(220,53,69,0.35)' %}
        {% elseif order['status'] == 'Partial' %}
          {% set status_color = '#7c3aed' %}{% set status_bg = 'rgba(124,58,237,0.10)' %}{% set status_border = 'rgba(124,58,237,0.35)' %}
        {% elseif order['status'] == 'Processing' %}
          {% set status_color = '#0891b2' %}{% set status_bg = 'rgba(8,145,178,0.10)' %}{% set status_border = 'rgba(8,145,178,0.35)' %}
        {% endif %}

           <div class="card order-card h-100 border-0 rounded-4 overflow-hidden"
             style="background:var(--color-accent);box-shadow:0 2px 16px rgba(20,40,29,0.07);">

          <div style="height:4px;background:{{ status_color }};"></div>

          <div class="card-body p-3 p-md-4 d-flex flex-column">

            <div class="d-flex justify-content-between align-items-center mb-3">
              <span class="copy-id d-flex align-items-center gap-1 rounded-2 px-2 py-1 fw-bold"
                  onclick="copyOrderId('{{ order['id'] }}')"
                    style="background:var(--color-hover-bg);color:var(--color-accent);font-size:0.75rem;">
                <i class="fas fa-hashtag" style="font-size:0.65rem;"></i>{{ order['id'] }}
                <i class="fas fa-copy ms-1" style="font-size:0.6rem;opacity:0.5;"></i>
              </span>

              <span class="badge-status badge rounded-pill fw-semibold"
                  style="background-color:{{ status_bg }};color:{{ status_color }};border:1px solid {{ status_border }};">
                {{ order['status'] }}
              </span>
            </div>

            <h6 class="fw-bold mb-2 lh-sm" style="color:var(--color-hover-bg);font-size:0.88rem;
                display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;min-height:2.5rem;">
              {{ order['service'] }}
            </h6>

            <a href="{{ order['link'] }}" target="_blank"
               class="link-pill d-flex align-items-center gap-2 text-decoration-none mb-3 px-3 py-2 rounded-3 small text-truncate"
               style="background:var(--color-hover-bg);color:var(--color-accent);font-size:0.78rem;border:1px solid var(--color-border);">
              <i class="fas fa-link" style="flex-shrink:0;font-size:0.65rem;opacity:0.7;"></i>
              <span class="text-truncate">{{ order['link'] }}</span>
            </a>

            <div class="row g-2 mb-3">
              <div class="col-4">
                <div class="text-center p-2 rounded-3 h-100"
                     style="background:var(--color-bg);border:1px solid var(--color-border);">
                  <div class="text-uppercase fw-semibold mb-1"
                       style="font-size:0.55rem;color:var(--color-text);opacity:0.5;letter-spacing:0.5px;">Qty</div>
                  <div class="fw-bold" style="font-size:0.85rem;color:var(--color-text);">
                    {{ order['quantity'] }}
                  </div>
                </div>
              </div>
              <div class="col-4">
                <div class="text-center p-2 rounded-3 h-100"
                     style="background:var(--color-bg);border:1px solid var(--color-border);">
                  <div class="text-uppercase fw-semibold mb-1"
                       style="font-size:0.55rem;color:var(--color-text);opacity:0.5;letter-spacing:0.5px;">Charge</div>
                  <div class="fw-bold" style="font-size:0.85rem;color:var(--color-text);">
                    {{ convert_currency(order['charge']) }}
                  </div>
                </div>
              </div>
              <div class="col-4">
                <div class="text-center p-2 rounded-3 h-100"
                     style="background:var(--color-bg);border:1px solid var(--color-border);">
                  <div class="text-uppercase fw-semibold mb-1"
                       style="font-size:0.55rem;color:var(--color-text);opacity:0.5;letter-spacing:0.5px;">Date</div>
                  <div class="fw-bold" style="font-size:0.72rem;color:var(--color-text);">
                    {{ show_date(order['date']) }}
                  </div>
                </div>
              </div>
            </div>

            <div class="mt-auto d-grid gap-2">

              {% if site["modules"]['reorder_button'] %}
                <a href="?select_service_id={{order['service_id']}}"
                   class="btn btn-sm fw-bold d-flex align-items-center justify-content-center gap-2 py-2"
                   style="background-color:var(--color-hover-bg);color:var(--color-text);
                          border-radius:10px;font-size:0.78rem;letter-spacing:0.3px;">
                  <i class="fas fa-redo-alt" style="font-size:0.7rem;"></i> Reorder
                </a>
              {% endif %}

              {% if order['refillButton'] == 1 or order['refillButton'] == 2 or order['cancelButton'] == 1 %}
              <div class="d-flex gap-2">
                {% if order['refillButton'] == 1 or order['refillButton'] == 2 %}
                  <button class="btn btn-sm fw-bold flex-grow-1 refill-button"
                          data-order-id="{{ order['id'] }}"
                          style="border:1.5px solid var(--color-hover-bg);color:var(--color-bg);
                                 background:transparent;border-radius:10px;font-size:0.75rem;">
                    <i class="fas fa-sync-alt me-1" style="font-size:0.65rem;"></i> Refill
                  </button>
                {% endif %}

            {% if order['cancelButton'] == 1 %}
    <button class="btn btn-sm cancel-button d-flex align-items-center justify-content-center"
            data-order-id="{{ order['id'] }}"
            style="background: #fff0f0; 
                   color: #dc3545; 
                   border: 1.5px solid rgba(220, 53, 69, 0.2); 
                   border-radius: 10px; 
                   padding: 6px 14px; 
                   transition: all 0.2s ease;"
            onmouseover="this.style.background='#dc3545'; this.style.color='#fff';"
            onmouseout="this.style.background='#fff0f0'; this.style.color='#dc3545';">
        
        <i class="fas fa-trash-alt"></i>
    </button>
{% endif %}
              </div>
              {% endif %}

            </div>
          </div>
        </div>

      </div>
      {% endfor %}

    </div>
    {% if orders is empty %}
    <div class="text-center py-5 mt-3">
      <div class="mb-4 mx-auto d-flex align-items-center justify-content-center rounded-circle shadow-sm"
           style="width:80px;height:80px;background:var(--color-hover-bg);">
        <i class="fas fa-inbox" style="font-size:2rem;color:var(--color-accent);opacity:0.4;"></i>
      </div>
      <h5 class="fw-bold mb-1" style="color:var(--color-text);">No orders found</h5>
      <p class="small opacity-50 mb-0">Try changing the filter or search term.</p>
    </div>
    {% endif %}
    {% if pagination["count"] > 1 %}
    <nav class="mt-5" aria-label="Orders pagination">
      <ul class="pagination justify-content-center flex-wrap gap-2 mb-0">

        {% if pagination['current'] > 1 %}
        <li class="page-item">
          <a class="page-link border-0 rounded-circle shadow-sm d-flex align-items-center justify-content-center fw-bold"
             href="orders/{{ status }}/{{ pagination['current'] - 1 }}{% if search %}?search={{ search }}{% endif %}"
             style="width:40px;height:40px;background:#fff;color:var(--color-text);">
            <i class="fas fa-chevron-left" style="font-size:0.7rem;"></i>
          </a>
        </li>
        {% endif %}

        {% for page in 1..pagination["count"] %}
          <li class="page-item">
            <a class="page-link border-0 rounded-circle shadow-sm d-flex align-items-center justify-content-center fw-bold"
               href="orders/{{ status }}/{{ page }}{% if search %}?search={{ search }}{% endif %}"
               style="width:40px;height:40px;
                      {% if page == pagination['current'] %}
                        background-color:var(--color-accent);color:var(--color-accent-contrast);
                      {% else %}
                        background:#fff;color:var(--color-text);
                      {% endif %}
                      font-size:0.85rem;">
              {{ page }}
            </a>
          </li>
        {% endfor %}

        {% if pagination['current'] < pagination['count'] %}
        <li class="page-item">
          <a class="page-link border-0 rounded-circle shadow-sm d-flex align-items-center justify-content-center fw-bold"
             href="orders/{{ status }}/{{ pagination['current'] + 1 }}{% if search %}?search={{ search }}{% endif %}"
             style="width:40px;height:40px;background:#fff;color:var(--color-text);">
            <i class="fas fa-chevron-right" style="font-size:0.7rem;"></i>
          </a>
        </li>
        {% endif %}

      </ul>
    </nav>
    {% endif %}

  </div>
</div>

<script>
  function showCopyTooltip(message, isError) {
    var toast = document.getElementById('copyToast');
    if (!toast) {
      return;
    }

    toast.textContent = message;
    toast.classList.remove('show', 'error');
    void toast.offsetWidth;
    if (isError) {
      toast.classList.add('error');
    }
    toast.classList.add('show');

    if (window._copyToastTimer) {
      clearTimeout(window._copyToastTimer);
    }

    window._copyToastTimer = setTimeout(function () {
      toast.classList.remove('show', 'error');
    }, 1200);
  }

  function fallbackCopyText(text) {
    var input = document.createElement('input');
    input.value = text;
    document.body.appendChild(input);
    input.select();
    document.execCommand('copy');
    document.body.removeChild(input);
  }

  function copyOrderId(orderId) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(orderId)
        .then(function () {
          showCopyTooltip('Copied!', false);
        })
        .catch(function () {
          try {
            fallbackCopyText(orderId);
            showCopyTooltip('Copied!', false);
          } catch (e) {
            showCopyTooltip('Copy failed', true);
          }
        });
      return;
    }

    try {
      fallbackCopyText(orderId);
      showCopyTooltip('Copied!', false);
    } catch (e) {
      showCopyTooltip('Copy failed', true);
    }
  }
</script>

{% include 'footer.twig' %}