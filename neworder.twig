{% include 'header.twig' %}

<style>
  html { scroll-behavior: smooth; }
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  .stat-card { transition: transform 0.22s ease, box-shadow 0.22s ease; }
  .stat-card:hover { transform: translateY(-5px); box-shadow: 0 14px 36px var(--color-border) !important; }

  .decorative-card {
    position: relative;
    overflow: hidden;
  }
  .decorative-card::after {
    content: "";
    position: absolute;
    right: -32px;
    top: -32px;
    width: 150px;
    height: 150px;
    border-radius: 50%;
    background: var(--decor-circle-color, var(--color-text));
    opacity: 0.8;
    pointer-events: none;
    z-index: 0;
  }
  .decorative-card > * {
    position: relative;
    z-index: 1;
  }

  .order-form-card {
    isolation: isolate;
  }

  .order-form-card .form-bubble {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    opacity: 0.55;
    filter: blur(0.2px);
  }

  .order-form-card .form-bubble.b1 {
    width: 220px;
    height: 220px;
    right: -90px;
    top: -70px;
    background: rgba(214,255,246,0.14);
  }

  .order-form-card .form-bubble.b2 {
    width: 120px;
    height: 120px;
    left: -28px;
    bottom: 120px;
    background: rgba(214,255,246,0.08);
  }

  .order-form-card .form-bubble.b3 {
    width: 72px;
    height: 72px;
    right: 120px;
    top: 135px;
    background: rgba(214,255,246,0.1);
  }

  .news-item.news-social {
    background: var(--news-bg, var(--color-bg)) !important;
    border-color: var(--news-border, var(--color-border)) !important;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.03);
  }

  .news-item.news-social .news-date {
    background: var(--news-pill-bg, var(--color-hover-bg)) !important;
    color: var(--news-text, var(--color-text)) !important;
  }

  .news-item.news-social .news-title {
    color: var(--news-text, var(--color-text));
  }

  .news-item.news-social .news-content {
    color: var(--news-text, var(--color-text));
    opacity: 0.72;
  }

  .form-control:focus, .form-select:focus {
    border-color: var(--color-accent) !important;
    box-shadow: 0 0 0 3px var(--color-border) !important;
    background-color: var(--color-accent-contrast) !important;
  }

  .input-icon-wrap { position: relative; }
  .input-icon-wrap .form-control,
  .input-icon-wrap .form-select { padding-left: 42px; }
  .input-icon-wrap .field-icon {
    position: absolute; left: 14px; top: 50%;
    transform: translateY(-50%);
    color: var(--color-accent); opacity: 0.4;
    font-size: 0.8rem; pointer-events: none; z-index: 5;
  }

  .stat-content { min-width: 0; }
  .stat-label {
    white-space: normal;
    word-break: break-word;
    line-height: 1.2;
  }

  /* Search override – keep existing JS working */
  #new-order-search .input-wrapper {
    position: relative;
    display: flex; align-items: center;
  }
  #new-order-search .input-wrapper__prepend {
    position: absolute; left: 12px; background: none; border: none;
    color: var(--color-accent); opacity: 0.45; z-index: 5; padding: 0;
  }
  #new-order-search .input-wrapper__append {
    position: absolute; right: 12px; background: none; border: none;
    color: var(--color-text); opacity: 0.35; z-index: 5; padding: 0;
  }
  #new-order-search input {
    width: 100%; padding: 12px 40px 12px 40px;
    border-radius: 12px;
    border: 1px solid var(--color-border) !important;
    background: var(--color-bg);
    color: var(--color-text); font-size: 0.88rem;
    outline: none;
  }
  #new-order-search input:focus {
    border-color: var(--color-accent) !important;
    box-shadow: 0 0 0 3px var(--color-border);
  }
  #searchServicesResultsDropdown {
    position: absolute; left: 0; right: 0; z-index: 999;
    background: var(--color-accent-contrast);
    border: 1px solid var(--color-border);
    border-radius: 12px; margin-top: 4px;
    box-shadow: 0 8px 24px var(--color-border);
    overflow: hidden;
  }

  /* News / announcement cards */
  .news-item {
    background: var(--color-bg) !important;
    border: 1px solid var(--color-border);
    border-radius: 14px !important;
    padding: 16px !important;
    margin-bottom: 12px !important;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .news-item:hover { transform: translateX(4px); box-shadow: 0 6px 20px var(--color-border); }
  .news-date {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.4px;
    padding: 4px 10px !important; border-radius: 50px !important;
    background: var(--color-hover-bg) !important;
    color: var(--color-accent) !important;
    margin-bottom: 8px;
  }
  .news-title {
    font-size: 0.92rem; font-weight: 700; color: var(--color-text);
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 6px;
  }
  .news-content {
    font-size: 0.82rem; color: var(--color-text);
    opacity: 0.6; line-height: 1.6; margin-bottom: 0;
  }

  .announcements-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .announcements-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid var(--color-border);
  }

  .announcements-page-btn {
    min-width: 32px;
    height: 32px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-accent-contrast);
    color: var(--color-text);
    font-size: 0.72rem;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 10px;
    cursor: pointer;
    transition: all 0.16s ease;
  }

  .announcements-page-btn:hover {
    background: var(--color-hover-bg);
  }

  .announcements-page-btn.active {
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    border-color: var(--color-accent);
  }

  .order-mode-switch {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 14px;
  }

  .order-mode-btn {
    border-radius: 12px;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.35px;
    text-transform: uppercase;
    border: 1px solid var(--color-border);
    padding: 10px 12px;
    text-align: center;
    text-decoration: none;
    transition: all 0.16s ease;
  }

  .order-mode-btn.active {
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    border-color: var(--color-accent);
  }

  .order-mode-btn.inactive {
    background: var(--color-hover-bg);
    color: var(--color-text);
  }

  .order-mode-btn.inactive:hover {
    background: var(--color-accent-contrast);
    color: var(--color-text);
  }

  /* Category filter passthrough */
  .category-filter-wrapper .btn,
  .category-filter-wrapper button {
    border-radius: 50px !important;
    font-size: 0.75rem; font-weight: 700;
    padding: 6px 16px; border: 1.5px solid var(--color-border) !important;
    background: var(--color-accent-contrast); color: var(--color-text);
    margin: 3px; transition: all 0.16s;
  }
  .category-filter-wrapper .btn.active,
  .category-filter-wrapper button.active {
    background: var(--color-accent) !important;
    color: var(--color-accent-contrast) !important;
    border-color: var(--color-accent) !important;
  }

  @media (max-width: 576px) {
    .hero-title { font-size: 1.3rem; }
    .stat-val   { font-size: 1.2rem; }
    .stat-label {
      font-size: 0.58rem !important;
      letter-spacing: 0.35px !important;
    }
  }
</style>

<div class="min-vh-100 pb-5" style="background-color:var(--color-bg);color:var(--color-text);">
  <div style="background:var(--color-accent);position:relative;overflow:hidden;">
    <div style="position:absolute;top:-90px;right:-90px;width:300px;height:300px;
                border-radius:50%;background:rgba(214,255,246,0.05);pointer-events:none;"></div>
    <div style="position:absolute;bottom:-60px;left:60px;width:200px;height:200px;
                border-radius:50%;background:rgba(214,255,246,0.04);pointer-events:none;"></div>
    <div style="position:absolute;top:30px;left:38%;width:120px;height:120px;
                border-radius:50%;background:rgba(214,255,246,0.03);pointer-events:none;"></div>

    <div class="container-fluid px-3 px-md-5 py-5">
      <div class="row align-items-center g-4">

        <div class="col-12 col-md-7">
          <div class="d-flex align-items-center gap-3 mb-3">
            <div style="width:52px;height:52px;border-radius:14px;
                        background:rgba(214,255,246,0.12);
                        display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-layer-group"
                 style="color:var(--color-accent-contrast);font-size:1.3rem;"></i>
            </div>
            <div>
              <p class="mb-0 fw-semibold"
                 style="color:var(--color-accent-contrast);opacity:0.5;
                        font-size:0.7rem;letter-spacing:2px;text-transform:uppercase;">
                Dashboard
              </p>
              <h1 class="hero-title fw-bold mb-0"
                  style="color:var(--color-accent-contrast);letter-spacing:-0.5px;font-size:1.75rem;">
                New Order
              </h1>
            </div>
          </div>
          <p style="color:var(--color-accent-contrast);opacity:0.5;
                    font-size:0.85rem;max-width:440px;line-height:1.6;">
            Select a category, pick your service, and place your order in seconds.
            Fast, reliable, and instant delivery guaranteed.
          </p>
          <div class="d-flex flex-wrap gap-2 mt-3">
            <span style="display:inline-flex;align-items:center;gap:7px;font-size:0.72rem;
                         font-weight:600;padding:6px 14px;border-radius:50px;
                         background:rgba(214,255,246,0.1);color:var(--color-accent-contrast);">
              <i class="fas fa-bolt" style="font-size:0.7rem;opacity:0.75;"></i> Instant Delivery
            </span>
            <span style="display:inline-flex;align-items:center;gap:7px;font-size:0.72rem;
                         font-weight:600;padding:6px 14px;border-radius:50px;
                         background:rgba(214,255,246,0.1);color:var(--color-accent-contrast);">
              <i class="fas fa-shield-alt" style="font-size:0.7rem;opacity:0.75;"></i> Secure Payment
            </span>
            <span style="display:inline-flex;align-items:center;gap:7px;font-size:0.72rem;
                         font-weight:600;padding:6px 14px;border-radius:50px;
                         background:rgba(214,255,246,0.1);color:var(--color-accent-contrast);">
              <i class="fas fa-headset" style="font-size:0.7rem;opacity:0.75;"></i> 24/7 Support
            </span>
          </div>
        </div>

        <div class="col-12 col-md-5">
          <div class="p-4 rounded-4"
               style="background:rgba(214,255,246,0.07);
                      border:1.5px dashed rgba(214,255,246,0.15);">
            <p class="mb-1 fw-semibold"
               style="color:var(--color-accent-contrast);opacity:0.4;
                      font-size:0.65rem;letter-spacing:1.5px;text-transform:uppercase;">
              Welcome back
            </p>
            <p class="fw-bold mb-1"
               style="color:var(--color-accent-contrast);font-size:1.4rem;letter-spacing:-0.3px;">
              @{{ user['username'] }}
            </p>
            <div class="d-flex align-items-center gap-2 mt-2">
              <span style="font-size:0.72rem;color:var(--color-accent-contrast);opacity:0.5;">
                Balance:
              </span>
              <span class="fw-bold"
                    style="color:var(--color-accent-contrast);font-size:0.88rem;">
                {{ convert_currency(user['balance']) }}
              </span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <div class="container-fluid px-3 px-md-5">
    <div class="row g-3" style="margin-top:-28px;">
{% set stats = [
    {'icon':'fa-calendar-check',          'label':'Today Orders',   'val': todayOrdersCount,                  'color':'var(--color-accent)'},
    {'icon':'fa-shopping-cart', 'label':'Total Orders',   'val': totalOrdersCount,                  'color':'#0284c7'},
    {'icon':'fa-wallet',        'label':'Total Balance',  'val': convert_currency(user['balance']), 'color':'#198754'},
    {'icon':'fa-coins',         'label':'Total Spent',    'val': convert_currency(user['spent']),   'color':'#d97706'}
] %}

      {% for s in stats %}
        <div class="col-6 col-lg-3">
          <div class="stat-card p-3 p-md-4 rounded-4 shadow-sm h-100"
               style="background:var(--color-accent-contrast);border:1px solid var(--color-border);">
            <div class="d-flex align-items-center gap-3">
              <div style="width:46px;height:46px;border-radius:12px;flex-shrink:0;
                          background:{{ s.color }}1a;
                          display:flex;align-items:center;justify-content:center;">
                <i class="fas {{ s.icon }}" style="color:{{ s.color }};font-size:1rem;"></i>
              </div>
              <div class="min-width-0 stat-content">
                <p class="mb-0 fw-semibold stat-label"
                   style="font-size:0.65rem;color:var(--color-text);opacity:0.45;
                          text-transform:uppercase;letter-spacing:0.5px;">
                  {{ s.label }}
                </p>
                <p class="mb-0 fw-bold stat-val text-truncate"
                   style="font-size:1rem;color:var(--color-text);">
                  {{ s.val }}
                </p>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}

    </div>
  </div>

  <div class="container-fluid px-3 px-md-5 mt-4">

    {# {% if contentText is not empty %}
      <div class="d-flex align-items-start gap-3 p-4 mb-4"
           style="background:var(--color-accent-contrast);border-left:4px solid var(--color-accent);
                  border-radius:14px;border:1px solid var(--color-border);">
        <i class="fas fa-info-circle mt-1"
           style="color:var(--color-accent);opacity:0.6;flex-shrink:0;"></i>
        <div style="font-size:0.88rem;line-height:1.6;">{{ contentText }}</div>
      </div>
    {% endif %} #}


    {% if convert_currency(user['balance']) < 5 %}
      <div class="d-flex align-items-start gap-3 p-4 mb-4 rounded-4"
           style="background:rgba(220,53,69,0.07);border:1px solid rgba(220,53,69,0.18);
                  border-left:4px solid #dc3545;">
        <div style="width:38px;height:38px;border-radius:10px;flex-shrink:0;
                    background:rgba(220,53,69,0.12);
                    display:flex;align-items:center;justify-content:center;">
          <i class="fas fa-exclamation-triangle" style="color:#dc3545;font-size:0.85rem;"></i>
        </div>
        <div style="flex-grow:1;">
          <p class="fw-bold mb-1" style="color:#dc3545;font-size:0.88rem;">
            Low Balance — @{{ user['username'] }}
          </p>
          <p class="mb-0 small" style="color:#dc3545;opacity:0.8;font-size:0.8rem;">
            {{ lang["neworder.low.balance"] }}
          </p>
        </div>
        <a href="addfunds" class="btn btn-sm fw-bold flex-shrink-0"
           style="background:#dc3545;color:#fff;border-radius:8px;
                  font-size:0.72rem;border:none;white-space:nowrap;">
          <i class="fas fa-plus me-1" style="font-size:0.65rem;"></i> Add Funds
        </a>
      </div>
    {% endif %}

    <!-- Error -->
    {% if error %}
      <div class="d-flex align-items-start gap-3 p-3 mb-4 rounded-3"
           style="background:rgba(220,53,69,0.08);border-left:4px solid #dc3545;
                  border:1px solid rgba(220,53,69,0.15);">
        <i class="fas fa-times-circle mt-1"
           style="color:#dc3545;flex-shrink:0;font-size:0.85rem;"></i>
        <div style="font-size:0.85rem;color:#dc3545;">{{ errorText }}</div>
      </div>
    {% endif %}

    <!-- Order success type 1 -->
    {% if data["order"]["success"] == 1 %}
      <div class="p-4 mb-4 rounded-4"
           style="background:rgba(25,135,84,0.07);border:1px solid rgba(25,135,84,0.2);">
        <div class="d-flex align-items-center gap-3 mb-3">
          <div style="width:38px;height:38px;border-radius:10px;flex-shrink:0;
                      background:rgba(25,135,84,0.15);
                      display:flex;align-items:center;justify-content:center;">
            <i class="fas fa-check-circle" style="color:#198754;font-size:0.95rem;"></i>
          </div>
          <h6 class="fw-bold mb-0" style="color:#198754;font-size:0.95rem;">
            Order Placed Successfully!
          </h6>
        </div>
        <div class="row g-2">
          {% for lk, lv in {
            (lang["neworder.success.id"]):       data['order']['id'],
            (lang["neworder.success.service"]):  data['order']['service'],
            (lang["neworder.success.link"]):     data['order']['link'],
            (lang["neworder.success.quantity"]): data['order']['quantity'],
            (lang["neworder.success.charge"]):   convert_currency(data['order']['price']),
            (lang["neworder.success.balance"]):  convert_currency(data['order']['balance'])
          } %}
            <div class="col-6 col-md-4">
              <div class="p-2 rounded-3"
                   style="background:rgba(25,135,84,0.08);border:1px solid rgba(25,135,84,0.15);">
                <p class="mb-0"
                   style="font-size:0.62rem;color:#198754;opacity:0.7;
                          text-transform:uppercase;letter-spacing:0.4px;font-weight:700;">
                  {{ lk }}
                </p>
                <p class="mb-0 fw-bold text-truncate"
                   style="font-size:0.82rem;color:#198754;" title="{{ lv }}">
                  {{ lv }}
                </p>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
    {% if data["order"]["success"] == 2 %}
      <div class="p-4 mb-4 rounded-4"
           style="background:rgba(25,135,84,0.07);border:1px solid rgba(25,135,84,0.2);">
        <div class="d-flex align-items-center gap-3 mb-3">
          <div style="width:38px;height:38px;border-radius:10px;flex-shrink:0;
                      background:rgba(25,135,84,0.15);
                      display:flex;align-items:center;justify-content:center;">
            <i class="fas fa-check-circle" style="color:#198754;font-size:0.95rem;"></i>
          </div>
          <h6 class="fw-bold mb-0" style="color:#198754;font-size:0.95rem;">
            Order Placed Successfully!
          </h6>
        </div>
        <div class="row g-2">
          {% for lk, lv in {
            (lang["neworder.success.id"]):       data['order']['id'],
            (lang["neworder.success.service"]):  data['order']['service'],
            (lang["neworder.success.username"]): data['order']['link'],
            (lang["neworder.success.posts"]):    data['order']['posts'],
            (lang["neworder.success.delay"]):    data['order']['delay']
          } %}
            <div class="col-6 col-md-4">
              <div class="p-2 rounded-3"
                   style="background:rgba(25,135,84,0.08);border:1px solid rgba(25,135,84,0.15);">
                <p class="mb-0"
                   style="font-size:0.62rem;color:#198754;opacity:0.7;
                          text-transform:uppercase;letter-spacing:0.4px;font-weight:700;">
                  {{ lk }}
                </p>
                <p class="mb-0 fw-bold text-truncate"
                   style="font-size:0.82rem;color:#198754;">
                  {{ lv }}
                </p>
              </div>
            </div>
          {% endfor %}
          <div class="col-6 col-md-4">
            <div class="p-2 rounded-3"
                 style="background:rgba(25,135,84,0.08);border:1px solid rgba(25,135,84,0.15);">
              <p class="mb-0"
                 style="font-size:0.62rem;color:#198754;opacity:0.7;
                        text-transform:uppercase;letter-spacing:0.4px;font-weight:700;">
                {{ lang["neworder.success.quantity"] }}
              </p>
              <p class="mb-0 fw-bold" style="font-size:0.82rem;color:#198754;">
                {{ data['order']['min'] }} – {{ data['order']['max'] }}
              </p>
            </div>
          </div>
        </div>
      </div>
    {% endif %}
    <div class="row g-4">

      <!-- ══════ ORDER FORM ══════ -->
      <div class="{% if annoucements|length > 0 %}col-12 col-lg-8{% else %}col-12 col-lg-8 mx-auto{% endif %}">
        <div class="decorative-card order-form-card p-4 p-md-5 rounded-4 js-order-form-card"
           style="--decor-circle-color:var(--color-bg);background:var(--color-text);border:1px solid var(--color-border);">
          <span class="form-bubble b1"></span>
          <span class="form-bubble b2"></span>
          <span class="form-bubble b3"></span>

          <div class="d-flex align-items-center gap-3 mb-4 pb-3"
               style="border-bottom:1px solid var(--color-border);">
            <div style="width:42px;height:42px;border-radius:11px;flex-shrink:0;
                        background:var(--color-hover-bg);
                        display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-plus-circle"
                 style="color:var(--color-accent);font-size:0.95rem;"></i>
            </div>
            <div>
              <h5 class="fw-bold mb-0"
                  style="color:var(--color-accent-contrast);font-size:1rem;">
                Place New Order
              </h5>
              <p class="mb-0 small"
                 style="color:var(--color-accent-contrast);opacity:0.55;font-size:0.72rem;">
                Choose category → service → fill details → submit
              </p>
            </div>
          </div>

          <div class="order-mode-switch">
            <span class="order-mode-btn active">
              <i class="fas fa-paper-plane me-2" style="font-size:0.78rem;"></i>
              New Order
            </span>
            <a href="massorder" class="order-mode-btn inactive">
              <i class="fas fa-layer-group me-2" style="font-size:0.78rem;"></i>
              Mass Order
            </a>
          </div>

          <form method="POST" action="" id="neworder-form">
            <div class="d-flex flex-column gap-3">
              {% if site["modules"]["category_filters"] %}
                <div class="category-filter-wrapper" id="category-filters"></div>
              {% endif %}
              {% if site["modules"]["search_services"] %}
                <div class="mb-1">
                  <label class="fw-semibold d-block mb-2"
                        style="font-size:0.78rem;color:var(--color-accent-contrast);opacity:0.7;
                                letter-spacing:0.5px;text-transform:uppercase;">
                    <i class="fas fa-search me-1" style="font-size:0.72rem;"></i>
                    Quick Search
                  </label>
                  <div class="search-dropdown position-relative" id="new-order-search"
                       data-lang-placeholder="Search">
                    <div class="input-wrapper" style="position:relative;">
                      <button type="button" id="searchServicesButtonIcon"
                              class="input-wrapper__prepend">
                        <i class="fas fa-search" style="font-size:0.82rem;"></i>
                      </button>
                      <input type="text" class="form-control"
                             id="searchServicesInputField"
                             placeholder="Search services...">
                      <button type="button" class="input-wrapper__append"
                              id="searchServicesInputClearButton">
                        <i class="fas fa-times" style="font-size:0.78rem;"></i>
                      </button>
                    </div>
                    <div class="select2-dropdown search-results"
                         id="searchServicesResultsDropdown"
                         style="display:none;"></div>
                  </div>
                </div>
              {% endif %}
              <div>
                <label for="neworder-category" class="fw-semibold d-block mb-2"
                    style="font-size:0.78rem;color:var(--color-accent-contrast);opacity:0.7;
                              letter-spacing:0.5px;text-transform:uppercase;">
                  <i class="fas fa-th-large me-1" style="font-size:0.72rem;"></i>
                  {{ lang["neworder.category"] }}
                </label>
                <div class="input-icon-wrap">
                  <i class="fas fa-th-large field-icon"></i>
                  <select class="form-select border rounded-3 py-3"
                          id="neworder-category"
                          name="NewOrderForm[category]"
                          style="background:var(--color-bg);color:var(--color-text);
                                 border-color:var(--color-border) !important;
                                 font-size:0.88rem;">
                  </select>
                </div>
              </div>
              <div>
                <label for="neworder-service" class="fw-semibold d-block mb-2"
                    style="font-size:0.78rem;color:var(--color-accent-contrast);opacity:0.7;
                              letter-spacing:0.5px;text-transform:uppercase;">
                  <i class="fas fa-concierge-bell me-1" style="font-size:0.72rem;"></i>
                  {{ lang["neworder.service"] }}
                </label>
                <div class="input-icon-wrap">
                  <i class="fas fa-concierge-bell field-icon"></i>
                  <select class="form-select border rounded-3 py-3"
                          id="neworder-service"
                          name="NewOrderForm[service]"
                          style="background:var(--color-bg);color:var(--color-text);
                                 border-color:var(--color-border) !important;
                                 font-size:0.88rem;">
                  </select>
                </div>
              </div>
              <div id="neworder_fields"></div>
              <div id="order_charge">
                <label for="neworder-charge" class="fw-semibold d-block mb-2"
                    style="font-size:0.78rem;color:var(--color-accent-contrast);opacity:0.7;
                              letter-spacing:0.5px;text-transform:uppercase;">
                  <i class="fas fa-tag me-1" style="font-size:0.72rem;"></i>
                  {{ lang["neworder.charge"] }}
                </label>
                <div class="input-icon-wrap">
                  <i class="fas fa-tag field-icon"></i>
                  <input type="text"
                         class="form-control border rounded-3 py-3"
                         id="neworder-charge" readonly
                         style="background:var(--color-hover-bg);color:var(--color-text);
                                border-color:var(--color-border) !important;
                                font-size:0.88rem;font-weight:700;cursor:not-allowed;">
                </div>
              </div>

              <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
              <div class="pt-3" style="border-top:1px solid var(--color-border);">
                <button id="neworderbutton" type="submit"
                        class="btn fw-bold w-100 py-3"
                        style="background:var(--color-accent-contrast);color:var(--color-accent);
                               border-radius:12px;font-size:0.88rem;letter-spacing:0.4px;
                               text-transform:uppercase;border:none;">
                  <i class="fas fa-paper-plane me-2" style="font-size:0.8rem;"></i>
                  {{ lang["neworder.button"] }}
                </button>
              </div>

            </div>
          </form>

        </div>
      </div>
      {% if annoucements|length > 0 %}
      <div class="col-12 col-lg-4">
         <div class="decorative-card p-4 rounded-4 h-100 js-announcements-card"
           style="--decor-circle-color:var(--color-text);background:var(--color-accent-contrast);border:1px solid var(--color-border);">
          <div class="d-flex align-items-center gap-3 mb-4 pb-3 js-announcements-header"
               style="border-bottom:1px solid var(--color-border);">
            <div style="width:42px;height:42px;border-radius:11px;flex-shrink:0;
                        background:var(--color-hover-bg);
                        display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-bullhorn"
                 style="color:var(--color-accent);font-size:0.95rem;"></i>
            </div>
            <div>
              <h5 class="fw-bold mb-0"
                  style="color:var(--color-text);font-size:1rem;">
                Announcements
              </h5>
              <p class="mb-0 small"
                 style="color:var(--color-text);opacity:0.45;font-size:0.72rem;">
                Latest news &amp; updates
              </p>
            </div>
            <span class="ms-auto fw-bold rounded-pill px-2 py-1"
                  style="background:var(--color-accent);color:var(--color-accent-contrast);
                         font-size:0.7rem;min-width:24px;text-align:center;">
              {{ annoucements|length }}
            </span>
          </div>
          <div class="announcements-list js-announcements-list">
            {% for news in annoucements %}
              {% set icon_key = news['news_icon']|lower %}
              {% set news_bg = 'rgba(35, 22, 81, 0.07)' %}
              {% set news_border = 'rgba(35, 22, 81, 0.24)' %}
              {% set news_pill_bg = 'rgba(35, 22, 81, 0.14)' %}
              {% set news_text = '#231651' %}

              {% if 'twitch' in icon_key %}
                {% set news_bg = 'rgba(145, 70, 255, 0.10)' %}
                {% set news_border = 'rgba(145, 70, 255, 0.30)' %}
                {% set news_pill_bg = 'rgba(145, 70, 255, 0.18)' %}
                {% set news_text = '#6f2bd9' %}
              {% elseif 'telegram' in icon_key %}
                {% set news_bg = 'rgba(0, 136, 204, 0.10)' %}
                {% set news_border = 'rgba(0, 136, 204, 0.30)' %}
                {% set news_pill_bg = 'rgba(0, 136, 204, 0.17)' %}
                {% set news_text = '#087fbe' %}
              {% elseif 'youtube' in icon_key %}
                {% set news_bg = 'rgba(255, 0, 0, 0.09)' %}
                {% set news_border = 'rgba(255, 0, 0, 0.26)' %}
                {% set news_pill_bg = 'rgba(255, 0, 0, 0.14)' %}
                {% set news_text = '#cc0000' %}
              {% elseif 'instagram' in icon_key %}
                {% set news_bg = 'rgba(225, 48, 108, 0.09)' %}
                {% set news_border = 'rgba(225, 48, 108, 0.28)' %}
                {% set news_pill_bg = 'rgba(225, 48, 108, 0.16)' %}
                {% set news_text = '#c92f68' %}
              {% elseif 'facebook' in icon_key %}
                {% set news_bg = 'rgba(24, 119, 242, 0.10)' %}
                {% set news_border = 'rgba(24, 119, 242, 0.30)' %}
                {% set news_pill_bg = 'rgba(24, 119, 242, 0.16)' %}
                {% set news_text = '#1877f2' %}
              {% elseif 'twitter' in icon_key or icon_key == 'x' %}
                {% set news_bg = 'rgba(15, 23, 42, 0.09)' %}
                {% set news_border = 'rgba(15, 23, 42, 0.28)' %}
                {% set news_pill_bg = 'rgba(15, 23, 42, 0.14)' %}
                {% set news_text = '#0f172a' %}
              {% elseif 'tiktok' in icon_key %}
                {% set news_bg = 'rgba(37, 244, 238, 0.10)' %}
                {% set news_border = 'rgba(37, 244, 238, 0.30)' %}
                {% set news_pill_bg = 'rgba(37, 244, 238, 0.18)' %}
                {% set news_text = '#0891b2' %}
              {% elseif 'discord' in icon_key %}
                {% set news_bg = 'rgba(88, 101, 242, 0.10)' %}
                {% set news_border = 'rgba(88, 101, 242, 0.30)' %}
                {% set news_pill_bg = 'rgba(88, 101, 242, 0.18)' %}
                {% set news_text = '#4f46e5' %}
              {% endif %}

              <div class="news-item news-social js-announcement-item"
                   style="--news-bg:{{ news_bg }};--news-border:{{ news_border }};--news-pill-bg:{{ news_pill_bg }};--news-text:{{ news_text }};">
                <div class="news-details">
                  <p class="news-date">
                    <i class="fas fa-calendar-alt" style="font-size:0.6rem;"></i>
                    {{ show_date(news['updated_at'])|date("jS M, Y g:i A") }}
                  </p>
                  <h4 class="news-title">
                    <span class="icon-container flex-shrink-0">
                      <img src="{{ site['url'] ~ '/public/icons/' ~ news['news_icon'] ~ '.png' }}"
                           alt="{{ news['news_icon'] }}" width="22" height="22"
                           style="border-radius:6px;">
                    </span>
                    <span class="title text-truncate">{{ news['news_title'] }}</span>
                  </h4>

                  <!-- Content -->
                  <p id="service_description" class="news-content">
                    {{ news['news_content'] }}
                  </p>

                </div>
              </div>
            {% endfor %}
          </div>

          <div class="announcements-pagination js-announcements-pagination" style="display:none;"></div>

        </div>
      </div>
      {% endif %}

    </div>
    <div class="row g-3 mt-4">
      <div class="col-12">
        <div class="d-flex align-items-center gap-3 mb-3">
          <div style="width:40px;height:40px;border-radius:10px;background:var(--color-accent);
                      display:flex;align-items:center;justify-content:center;">
            <i class="fas fa-map-signs"
               style="color:var(--color-accent-contrast);font-size:0.9rem;"></i>
          </div>
          <h5 class="fw-bold mb-0"
              style="color:var(--color-text);font-size:1rem;">
            How to Place an Order
          </h5>
        </div>
      </div>

      {% set steps = [
        {'num':'01','icon':'fa-th-large',        'title':'Pick Category',   'desc':'Browse through our service categories and find the platform or type that matches your need.'},
        {'num':'02','icon':'fa-concierge-bell',  'title':'Choose Service',  'desc':'Select the exact service that best fits your goals, budget, and delivery timeline.'},
        {'num':'03','icon':'fa-edit',            'title':'Fill Details',    'desc':'Enter the target URL, username, or any required fields and review the charge before submitting.'},
        {'num':'04','icon':'fa-paper-plane',     'title':'Submit & Track',  'desc':'Hit the order button and track your delivery progress in real time from the Orders page.'}
      ] %}

      {% for s in steps %}
        <div class="col-12 col-sm-6 col-lg-3">
          <div class="stat-card decorative-card h-100 p-4 rounded-4 position-relative overflow-hidden"
               style="--decor-circle-color:var(--color-text);background:var(--color-accent-contrast);border:1px solid var(--color-border);">
            <div style="position:absolute;top:-10px;right:10px;font-size:4.5rem;font-weight:900;
                        color:var(--color-accent-contrast);opacity:0.04;line-height:1;
                        pointer-events:none;user-select:none;">
              {{ s.num }}
            </div>
            <div style="width:42px;height:42px;border-radius:11px;background:var(--color-hover-bg);
                        display:flex;align-items:center;justify-content:center;margin-bottom:14px;">
              <i class="fas {{ s.icon }}"
                 style="color:var(--color-accent);font-size:0.95rem;"></i>
            </div>
            <span style="font-size:0.6rem;font-weight:700;letter-spacing:1px;
                         color:var(--color-accent);opacity:0.5;text-transform:uppercase;">
              Step {{ s.num }}
            </span>
            <h6 class="fw-bold mt-1 mb-2"
                style="color:var(--color-text);font-size:0.9rem;">
              {{ s.title }}
            </h6>
            <p class="mb-0 small"
               style="color:var(--color-text);opacity:0.5;line-height:1.55;font-size:0.78rem;">
              {{ s.desc }}
            </p>
          </div>
        </div>
      {% endfor %}

    </div>

    <!-- Content Text Bottom -->
    {% if contentTextBottom is not empty %}
      <div class="d-flex align-items-start gap-3 p-4 mt-4"
           style="background:var(--color-accent-contrast);border-left:4px solid var(--color-accent);
                  border-radius:14px;border:1px solid var(--color-border);">
        <i class="fas fa-info-circle mt-1"
           style="color:var(--color-accent);opacity:0.6;flex-shrink:0;"></i>
        <div style="font-size:0.88rem;line-height:1.6;">{{ contentTextBottom }}</div>
      </div>
    {% endif %}

  </div>
</div>

<script>
  (function () {
    function getOuterHeight(el) {
      var style = window.getComputedStyle(el);
      var marginTop = parseFloat(style.marginTop) || 0;
      var marginBottom = parseFloat(style.marginBottom) || 0;
      return el.getBoundingClientRect().height + marginTop + marginBottom;
    }

    function buildAnnouncementPagination() {
      var orderFormCard = document.querySelector('.js-order-form-card');
      var announcementsCard = document.querySelector('.js-announcements-card');
      var announcementsHeader = document.querySelector('.js-announcements-header');
      var list = document.querySelector('.js-announcements-list');
      var pagination = document.querySelector('.js-announcements-pagination');
      var items = Array.prototype.slice.call(document.querySelectorAll('.js-announcement-item'));

      if (!orderFormCard || !announcementsCard || !announcementsHeader || !list || !pagination || !items.length) {
        return;
      }

      items.forEach(function (item) {
        item.style.display = '';
        item.style.maxHeight = '';
        item.style.overflowY = '';
      });

      var formHeight = orderFormCard.getBoundingClientRect().height;
      var headerHeight = announcementsHeader.getBoundingClientRect().height;
      var cardStyle = window.getComputedStyle(announcementsCard);
      var cardPaddingTop = parseFloat(cardStyle.paddingTop) || 0;
      var cardPaddingBottom = parseFloat(cardStyle.paddingBottom) || 0;
      var paginationReserve = 52;
      var viewportHeight = Math.max(220, formHeight - headerHeight - cardPaddingTop - cardPaddingBottom - paginationReserve);

      var pages = [];
      var currentPage = [];
      var usedHeight = 0;

      items.forEach(function (item) {
        var itemHeight = getOuterHeight(item);

        if (!currentPage.length) {
          currentPage.push(item);
          usedHeight = itemHeight;
          return;
        }

        if (usedHeight + itemHeight <= viewportHeight) {
          currentPage.push(item);
          usedHeight += itemHeight;
        } else {
          pages.push(currentPage);
          currentPage = [item];
          usedHeight = itemHeight;
        }
      });

      if (currentPage.length) {
        pages.push(currentPage);
      }

      if (!pages.length) {
        return;
      }

      function renderPage(pageIndex) {
        items.forEach(function (item) {
          item.style.display = 'none';
          item.style.maxHeight = '';
          item.style.overflowY = '';
        });

        pages[pageIndex].forEach(function (item) {
          item.style.display = '';
          var currentHeight = getOuterHeight(item);
          if (currentHeight > viewportHeight) {
            item.style.maxHeight = Math.max(160, viewportHeight - 8) + 'px';
            item.style.overflowY = 'auto';
          }
        });

        var buttons = pagination.querySelectorAll('.announcements-page-btn');
        buttons.forEach(function (btn, idx) {
          btn.classList.toggle('active', idx === pageIndex);
        });
      }

      pagination.innerHTML = '';

      if (pages.length <= 1) {
        pagination.style.display = 'none';
        items.forEach(function (item) { item.style.display = ''; });
        return;
      }

      pages.forEach(function (_, index) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'announcements-page-btn';
        btn.textContent = index + 1;
        btn.addEventListener('click', function () {
          renderPage(index);
        });
        pagination.appendChild(btn);
      });

      pagination.style.display = 'flex';
      renderPage(0);
    }

    window.addEventListener('load', buildAnnouncementPagination);
    window.addEventListener('resize', buildAnnouncementPagination);
  })();
</script>

{% include 'footer.twig' %}