{% include 'header.twig' %}

<div class="blog-page-wrapper section-hunter-cream" style="min-height: 100vh; padding: clamp(120px, 12vh, 120px) 0 5rem; overflow-x: hidden;">

    <div class="container-fluid" style="max-width: 1350px;">
        <div class="text-center mb-5 px-3">
            <div class="d-inline-flex align-items-center gap-2 mb-3 px-3 py-1 rounded-pill" 
                 style="background: rgba(var(--color-accent-rgb), 0.1); border: 1px solid rgba(var(--color-accent-rgb), 0.2);">
                <i class="fa-solid fa-feather-pointed" style="color: var(--color-accent-contrast); font-size: 0.8rem;"></i>
                <span style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-accent-contrast);">
                    Insights & Updates
                </span>
            </div>
            <h1 class="fw-black mb-2" style="font-size: clamp(2.5rem, 5vw, 3.8rem); color: var(--color-accent-contrast); letter-spacing: -2px;">Our Blog</h1>
            <p class="opacity-50 fw-medium" style="color: var(--color-accent-contrast);">Stay updated with the latest trends and platform news.</p>
        </div>
        <div class="row g-4">
            {% for post in blogs %}
            <div class="col-12 col-md-6 col-lg-4">
                <article class="blog-card h-100" style="background: var(--color-bg); border: 1.5px solid var(--color-border); border-radius: 24px; overflow: hidden; display: flex; flex-direction: column; transition: all 0.3s ease;">
                    
                    {% if post['blog_thumbnail'] %}
                    <div class="thumbnail-wrapper" style="overflow: hidden; aspect-ratio: 16/9; position: relative;">
                        <a href="{{ site['url'] }}/blog/{{ post['blog_slug'] }}">
                            <img src="{{ post['blog_thumbnail'] }}" alt="{{ post['blog_title'] }}" 
                                 style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;" class="blog-img">
                        </a>
                        <div class="date-badge" style="position: absolute; top: 15px; left: 15px; background: rgba(0,0,0,0.6); color: white; backdrop-filter: blur(5px); padding: 5px 12px; border-radius: 10px; font-size: 0.75rem; font-weight: 700;">
                           New Post
                        </div>
                    </div>
                    {% endif %}

                    <div class="p-4 d-flex flex-column flex-grow-1">
                        <h4 class="fw-black mb-3" style="color: var(--color-text); line-height: 1.3; font-size: 1.35rem; letter-spacing: -0.5px;">
                            {{ post['blog_title'] }}
                        </h4>
                        
                        <div class="opacity-60 mb-4" style="font-size: 0.95rem; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                            {{ post['blog_content']|striptags|slice(0, 120) }}...
                        </div>
                        <div class="mt-auto pt-3 border-top" style="border-color: var(--color-border) !important;">
                            <a href="{{ site['url'] }}/blog/{{ post['blog_slug'] }}" class="read-more-link d-flex align-items-center gap-2 fw-black text-decoration-none" style="color: var(--color-accent); font-size: 0.95rem;">
                                READ MORE <i class="fa-solid fa-arrow-right-long transition-transform"></i>
                            </a>
                        </div>
                    </div>
                </article>
            </div>
            {% endfor %}
        </div>
    </div>
</div>

<style>
    .section-hunter-cream {
        background-color: var(--color-accent);
        background-image:
            radial-gradient(at 0% 0%, rgba(255, 252, 222, 0.18) 0px, transparent 55%),
            radial-gradient(at 100% 100%, rgba(255, 252, 222, 0.14) 0px, transparent 55%),
            radial-gradient(at 0% 100%, rgba(255, 252, 222, 0.08) 0px, transparent 45%),
            radial-gradient(at 100% 0%, rgba(255, 252, 222, 0.06) 0px, transparent 45%),
            radial-gradient(at 50% 50%, rgba(255, 252, 222, 0.12) 0px, transparent 75%),
            linear-gradient(
                152deg,
                rgba(255, 252, 222, 0.06) 0%,
                rgba(255, 252, 222, 0.00) 40%,
                rgba(255, 252, 222, 0.04) 100%
            );
        background-attachment: fixed;
        position: relative;
        isolation: isolate;
        overflow: hidden;
    }

    .section-hunter-cream::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0.5;
        background-image:
            radial-gradient(circle, rgba(255, 252, 222, 0.12) 1px, transparent 1px),
            radial-gradient(circle, rgba(255, 252, 222, 0.05) 1.5px, transparent 1.5px);
        background-size: 28px 28px, 56px 56px;
        background-position: 0 0, 14px 14px;
        z-index: 0;
    }

    .blog-page-wrapper > * {
        position: relative;
        z-index: 1;
    }

    .blog-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        border-color: var(--color-accent) !important;
    }

    .blog-card:hover .blog-img {
        transform: scale(1.1);
    }

    .read-more-link i {
        transition: transform 0.3s ease;
    }

    .read-more-link:hover i {
        transform: translateX(5px);
    }

    /* Mobile Responsive Logic */
    @media (max-width: 991px) {
        .blog-page-wrapper {
            padding-top: 100px !important;
        }
        .blog-card {
            margin-bottom: 10px;
        }

        .section-hunter-cream {
            background-attachment: scroll;
        }
    }

    @media (max-width: 576px) {
        .blog-page-wrapper {
            padding-left: 0.5rem;
            padding-right: 0.5rem;
        }
        .p-4 {
            padding: 1.5rem !important;
        }
        h4 {
            font-size: 1.2rem !important;
        }
    }
</style>

{% include 'footer.twig' %}