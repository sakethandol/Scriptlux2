{% if user['auth'] %}

<style>
/* ══════════════════════════════════════════
   DESIGN TOKENS
══════════════════════════════════════════ */
:root {
  --color-bg:              #fffced;
  --color-text:            #14281D;
  --color-accent:          #14281D;
  --color-accent-contrast: #fffced;
  --color-border:          rgba(20,40,29,.10);
  --color-hover-bg:        #f7f6d8;

  --sidebar-w:      260px;
  --sidebar-icon-w:  64px;
  --topbar-h:        66px;
  --mob-topbar-h:    60px;
  --mob-bar-h:       98px;   /* bottom nav reserved space */

  --r-xs: 8px;
  --r-sm: 12px;
  --r-md: 16px;
  --r-xl: 22px;

  --ease:   .25s cubic-bezier(.4,0,.2,1);
  --spring: .36s cubic-bezier(.34,1.4,.64,1);

  --sh-xs: 0 1px 4px  rgba(20,40,29,.06);
  --sh-sm: 0 3px 12px rgba(20,40,29,.09);
  --sh-md: 0 8px 24px rgba(20,40,29,.12);
  --sh-lg: 0 16px 48px rgba(20,40,29,.16);
  --sh-up: 0 -2px 20px rgba(20,40,29,.09);
}

*,*::before,*::after{box-sizing:border-box;}
body{margin:0;background:var(--color-bg);color:var(--color-text);
  font-family:'DM Sans','Inter',system-ui,sans-serif;}

/* ══════════════════════════════════════════
   DESKTOP TOP BAR  ≥992px
══════════════════════════════════════════ */
.desktop-topbar{
  display:none;
  position:fixed;inset:0 0 auto 0;height:var(--topbar-h);
  z-index:1050;background:var(--color-bg);
  border-bottom:1px solid var(--color-border);
  padding:0 24px;align-items:center;justify-content:space-between;gap:16px;
  box-shadow:var(--sh-xs);
}
@media(min-width:992px){.desktop-topbar{display:flex;}}

.dtb-brand{
  display:flex;align-items:center;gap:10px;text-decoration:none;
  color:var(--color-text);font-weight:800;font-size:15px;letter-spacing:-.03em;flex-shrink:0;
}
.dtb-brand img{max-height:30px;}
.dtb-brand-dot{width:6px;height:6px;border-radius:50%;background:var(--color-accent);flex-shrink:0;}

.dtb-right{display:flex;align-items:center;gap:8px;flex-wrap:wrap;justify-content:flex-end;}

.dtb-balance{
  display:inline-flex;align-items:center;gap:7px;
  background:var(--color-accent);color:var(--color-accent-contrast);
  font-size:13px;font-weight:700;padding:7px 15px;border-radius:999px;
  letter-spacing:-.01em;box-shadow:var(--sh-sm);white-space:nowrap;
}

.dtb-btn{
  display:inline-flex;align-items:center;gap:7px;padding:7px 13px;
  background:var(--color-text);border:1.5px solid var(--color-border);
  color:var(--color-accent-contrast);font-size:13px;font-weight:600;
  text-decoration:none;border-radius:var(--r-sm);cursor:pointer;
  white-space:nowrap;letter-spacing:-.01em;
  transition:background var(--ease),box-shadow var(--ease),transform var(--ease);
}
.dtb-btn:hover{
  background:var(--color-hover-bg);color:var(--color-text);
  box-shadow:var(--sh-sm);transform:translateY(-1px);text-decoration:none;
}

.dtb-dropdown{position:relative;}
.dtb-drop-menu{
  display:none;position:absolute;top:calc(100% + 8px);right:0;
  background:var(--color-bg);border:1.5px solid var(--color-border);
  border-radius:var(--r-md);min-width:130px;z-index:400;
  padding:6px;box-shadow:var(--sh-lg);
}
.dtb-drop-menu.show{display:block;}
.dtb-drop-menu a{
  display:block;padding:9px 12px;font-size:13px;font-weight:600;
  color:var(--color-text);text-decoration:none;border-radius:var(--r-xs);
  transition:background .14s;
}
.dtb-drop-menu a:hover{background:var(--color-hover-bg);}

/* ══════════════════════════════════════════
   DESKTOP SIDEBAR  ≥992px
══════════════════════════════════════════ */
.auth-sidebar{
  display:none;
  position:fixed;left:0;top:var(--topbar-h);
  width:var(--sidebar-w);height:calc(100vh - var(--topbar-h));
  background:var(--color-bg);border-right:1.5px solid var(--color-border);
  flex-direction:column;z-index:1045;
  box-shadow:var(--sh-md);
  transition:width var(--ease);overflow:hidden;
}
@media(min-width:992px){.auth-sidebar{display:flex;}}
.auth-sidebar.collapsed{width:var(--sidebar-icon-w);}

/* Brand */
.sidebar-brand{
  display:flex;align-items:center;justify-content:space-between;
  gap:8px;padding:0 14px;height:64px;min-height:64px;
  border-bottom:1px solid var(--color-border);flex-shrink:0;overflow:hidden;
}
.sidebar-brand a{
  display:flex;align-items:center;gap:10px;text-decoration:none;
  color:var(--color-text);font-weight:800;font-size:14px;letter-spacing:-.03em;
  flex:1;min-width:0;white-space:nowrap;overflow:hidden;
}
.sidebar-brand img{max-height:28px;flex-shrink:0;}
.sidebar-brand-name{overflow:hidden;max-width:160px;transition:max-width var(--ease),opacity var(--ease);}
.auth-sidebar.collapsed .sidebar-brand-name{max-width:0;opacity:0;}
.auth-sidebar.collapsed .sidebar-brand{justify-content:center;padding:0 8px;}
.auth-sidebar.collapsed .sidebar-brand a{flex:0 0 auto;justify-content:center;}

.sidebar-account-cta-wrap{
  padding:10px 10px 6px;
  border-bottom:1px solid var(--color-border);
}
.sidebar-account-cta{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;
  width:100%;
  padding:10px 12px;
  border-radius:12px;
  text-decoration:none;
  color:#fffced;
  font-size:13px;
  font-weight:700;
  letter-spacing:-.01em;
  background:linear-gradient(140deg,#14281D 0%,#254131 100%);
  border:1px solid rgba(20,40,29,.16);
  box-shadow:0 8px 18px rgba(20,40,29,.20);
  transition:transform var(--ease),box-shadow var(--ease),filter var(--ease);
}
.sidebar-account-cta:hover{
  color:#fffced;
  text-decoration:none;
  transform:translateY(-1px);
  box-shadow:0 12px 22px rgba(20,40,29,.28);
  filter:brightness(1.04);
}
.sidebar-account-cta i{font-size:12px;opacity:.9;}
.auth-sidebar.collapsed .sidebar-account-cta-wrap{display:none;}
.sidebar-collapse-btn {
  /* 1. Increased button container size */
  width: 40px; 
  height: 40px; 
  
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1.5px solid var(--color-border);
  border-radius: var(--r-xs);
  background: transparent;
  color: var(--color-text);
  cursor: pointer;
  transition: background var(--ease), transform var(--ease);

  /* 2. Increased font size (works for FontAwesome, Material Icons, etc.) */
  font-size: 20px; 
}

/* 3. Target SVG size (if you are using SVG icons like Lucide or Heroicons) */
.sidebar-collapse-btn svg {
  width: 20px;
  height: 20px;
}

.sidebar-collapse-btn:hover {
  background: var(--color-hover-bg);
}

.auth-sidebar.collapsed .sidebar-collapse-btn {
  transform: rotate(180deg);
}

/* Nav */
.sidebar-nav{
  flex:1;overflow-y:auto;overflow-x:hidden;
  padding:12px 8px;display:flex;flex-direction:column;gap:3px;
  min-height:0;scrollbar-width:thin;scrollbar-color:var(--color-border) transparent;
}
.sidebar-nav::-webkit-scrollbar{width:3px;}
.sidebar-nav::-webkit-scrollbar-thumb{background:var(--color-border);border-radius:99px;}

.sidebar-nav-item{
  display:flex;align-items:center;gap:11px;padding:10px 12px;
  border-radius:var(--r-sm);color:var(--color-text);text-decoration:none;
  font-size:13px;font-weight:600;letter-spacing:-.01em;
  white-space:nowrap;overflow:hidden;border:1.5px solid transparent;
  transition:background var(--ease),transform var(--ease),
             border-color var(--ease),box-shadow var(--ease),color var(--ease);
  position:relative;cursor:pointer;
}
.sidebar-nav-item:hover{
  background:var(--color-hover-bg);border-color:var(--color-border);
  transform:translateX(3px);color:var(--color-text);
  text-decoration:none;box-shadow:var(--sh-xs);
}
.sidebar-nav-item.active{
  background:var(--color-accent)!important;color:var(--color-accent-contrast)!important;
  border-color:transparent;transform:translateX(5px);box-shadow:var(--sh-sm);
}
.sidebar-nav-icon{
  width:32px;height:32px;flex-shrink:0;
  display:inline-flex;align-items:center;justify-content:center;font-size:13px;
  border-radius:var(--r-xs);background:var(--color-hover-bg);color:var(--color-accent);
  transition:background var(--ease),color var(--ease);
}
.sidebar-nav-item.active .sidebar-nav-icon{background:var(--color-hover-bg);color:var(--color-text);}
.sidebar-nav-label{flex:1;overflow:hidden;max-width:160px;transition:max-width var(--ease),opacity var(--ease);}
.sidebar-badge{
  background:var(--color-accent);color:var(--color-accent-contrast);
  font-size:10px;font-weight:700;padding:3px 8px;border-radius:999px;
  flex-shrink:0;margin-left:auto;box-shadow:var(--sh-xs);transition:opacity var(--ease);
}
.sidebar-nav-item.active .sidebar-badge{background:var(--color-accent-contrast);color:var(--color-accent);}
.sidebar-divider{
  height:1px;background:linear-gradient(90deg,transparent,var(--color-border) 50%,transparent);
  margin:6px 4px;flex-shrink:0;
}

/* Collapsed nav */
.auth-sidebar.collapsed .sidebar-nav-label,
.auth-sidebar.collapsed .sidebar-badge{max-width:0;opacity:0;pointer-events:none;}
.auth-sidebar.collapsed .sidebar-nav-item{
  justify-content:center;padding:10px 0;margin:0 7px;gap:0;border-color:transparent!important;
}
.auth-sidebar.collapsed .sidebar-nav-item:hover{transform:scale(1.07);}
.auth-sidebar.collapsed .sidebar-nav-item.active{transform:scale(1.04);}
.auth-sidebar.collapsed .sidebar-nav-icon{width:36px;height:36px;}
.auth-sidebar.collapsed .sidebar-nav-item::after{
  content:attr(data-tooltip);position:absolute;
  left:calc(var(--sidebar-icon-w) + 6px);top:50%;transform:translateY(-50%);
  background:var(--color-accent);color:var(--color-accent-contrast);
  padding:5px 12px;border-radius:var(--r-xs);font-size:12px;font-weight:600;
  white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .15s;
  z-index:500;box-shadow:var(--sh-md);
}
.auth-sidebar.collapsed .sidebar-nav-item:hover::after{opacity:1;}

/* Bottom panel */
.sidebar-bottom{
  border-top:1px solid var(--color-border);padding:10px 8px 12px;
  flex-shrink:0;background:var(--color-bg);
  display:flex;flex-direction:column;gap:4px;
}
.sidebar-balance-row{
  display:flex;align-items:center;gap:10px;padding:10px 12px;
  border-radius:var(--r-sm);background:var(--color-hover-bg);
  border:1.5px solid var(--color-border);overflow:hidden;
  justify-content:center;
}
.sidebar-balance-pill{
  background:var(--color-accent);color:var(--color-accent-contrast);
  font-size:12px;font-weight:700;padding:4px 11px;border-radius:999px;
  white-space:nowrap;flex-shrink:0;letter-spacing:-.01em;
  transition:opacity var(--ease),max-width var(--ease);
}
.sidebar-dropdown{position:relative;}
.sidebar-dropdown-menu{
  display:none;position:absolute;bottom:calc(100% + 6px);left:0;
  background:var(--color-bg);border:1.5px solid var(--color-border);
  border-radius:var(--r-md);min-width:130px;z-index:300;
  padding:6px;box-shadow:var(--sh-lg);
}
.sidebar-dropdown-menu.show{display:block;}
.sidebar-dropdown-menu a{
  display:block;padding:9px 12px;font-size:13px;font-weight:600;
  color:var(--color-text);text-decoration:none;border-radius:var(--r-xs);transition:background .14s;
}
.sidebar-dropdown-menu a:hover{background:var(--color-hover-bg);}

/* Collapsed bottom */
.auth-sidebar.collapsed .sidebar-bottom{padding:10px 0 12px;align-items:center;gap:4px;}
.auth-sidebar.collapsed .sidebar-balance-row{
  justify-content:center;padding:10px 0;margin:0 7px;
  width:calc(100% - 14px);position:relative;
}
.auth-sidebar.collapsed .sidebar-balance-pill{max-width:0;opacity:0;pointer-events:none;}
.auth-sidebar.collapsed .sidebar-balance-row::after{
  content:attr(data-balance-label);position:absolute;
  left:calc(var(--sidebar-icon-w) - 1px);top:50%;transform:translateY(-50%);
  background:var(--color-accent);color:var(--color-accent-contrast);
  padding:5px 12px;border-radius:var(--r-xs);font-size:12px;font-weight:700;
  white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .15s;z-index:500;box-shadow:var(--sh-md);
}
.auth-sidebar.collapsed .sidebar-balance-row:hover::after{opacity:1;}
.auth-sidebar.collapsed .sidebar-bottom .sidebar-nav-item{
  justify-content:center;padding:10px 0;margin:0 7px;
  gap:0;width:calc(100% - 14px);border-color:transparent!important;
}
.auth-sidebar.collapsed .sidebar-bottom .sidebar-nav-item:hover{transform:scale(1.07);}
.auth-sidebar.collapsed .sidebar-bottom .sidebar-nav-label{max-width:0;opacity:0;pointer-events:none;}
.auth-sidebar.collapsed .sidebar-bottom .sidebar-nav-icon{width:36px;height:36px;}
.auth-sidebar.collapsed .sidebar-bottom .sidebar-nav-item::after{
  content:attr(data-tooltip);position:absolute;
  left:calc(var(--sidebar-icon-w) - 1px);top:50%;transform:translateY(-50%);
  background:var(--color-accent);color:var(--color-accent-contrast);
  padding:5px 12px;border-radius:var(--r-xs);font-size:12px;font-weight:600;
  white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .15s;z-index:500;box-shadow:var(--sh-md);
}
.auth-sidebar.collapsed .sidebar-bottom .sidebar-nav-item:hover::after{opacity:1;}
.auth-sidebar.collapsed .sb-chevron{display:none;}
.auth-sidebar.collapsed .sidebar-dropdown-menu{left:calc(var(--sidebar-icon-w) + 4px);bottom:0;}

/* Desktop body push */
body.auth-sidebar-open{padding-left:var(--sidebar-w);padding-top:var(--topbar-h);transition:padding var(--ease);}
body.auth-sidebar-collapsed{padding-left:var(--sidebar-icon-w);padding-top:var(--topbar-h);transition:padding var(--ease);}

/* ══════════════════════════════════════════
   MOBILE ONLY  ≤991px
══════════════════════════════════════════ */
@media(max-width:991px){
  .desktop-topbar{display:none!important;}
  .auth-sidebar{display:none!important;}
  body.auth-sidebar-open,body.auth-sidebar-collapsed{
    padding-left:0!important;padding-top:0!important;
  }
  /* Extra bottom padding so content isn't hidden behind nav */
  body{padding-bottom:calc(var(--mob-bar-h) + env(safe-area-inset-bottom, 0px));}
}

/* ──────────────────────────────────────────
   MOBILE TOP BAR  (matches image 3 exactly)
────────────────────────────────────────── */
.mobile-topbar{
  display:none;
  position:sticky;top:0;z-index:900;
  align-items:center;gap:12px;
  padding:0 14px;height:var(--mob-topbar-h);
  background:var(--color-bg);
  border-bottom:1px solid var(--color-border);
  box-shadow:var(--sh-xs);
}
@media(max-width:991px){.mobile-topbar{display:flex;}}

/* Square hamburger box — exactly like image 3 */
.mob-menu-btn{
  width:42px;height:42px;flex-shrink:0;
  display:inline-flex;align-items:center;justify-content:center;
  background:var(--color-bg);
  border:1.5px solid var(--color-border);
  border-radius:var(--r-sm);
  color:var(--color-text);cursor:pointer;
  box-shadow:var(--sh-xs);
  transition:background var(--ease),box-shadow var(--ease);
}
.mob-menu-btn:hover{background:var(--color-hover-bg);box-shadow:var(--sh-sm);}

.mob-brand{
  flex:1;min-width:0;
  display:flex;align-items:center;gap:8px;
  text-decoration:none;color:var(--color-text);
  font-weight:800;font-size:16px;letter-spacing:-.03em;
}
.mob-brand img{max-height:26px;}

.mob-balance-pill{
  display:inline-flex;align-items:center;gap:6px;
  background:var(--color-accent);color:var(--color-accent-contrast);
  font-size:12px;font-weight:700;padding:8px 14px;
  border-radius:999px;white-space:nowrap;flex-shrink:0;
  letter-spacing:-.01em;box-shadow:var(--sh-sm);
}

/* ──────────────────────────────────────────
   MOBILE BOTTOM NAV BAR
────────────────────────────────────────── */
.mob-bottom-nav{
  display:none;
  position:fixed;
  left:12px;
  right:12px;
  bottom:calc(8px + env(safe-area-inset-bottom,0px));
  height:74px;
  background:var(--color-bg);
  border:1px solid rgba(20,40,29,.10);
  border-radius:24px;
  box-shadow:0 12px 28px rgba(20,40,29,.14);
  z-index:950;
  align-items:center;
  justify-content:center;
  padding:8px 8px;
  overflow:visible;
}
@media(max-width:991px){.mob-bottom-nav{display:flex;}}

.mob-nav-side{
  flex:1;
  display:flex;
  align-items:stretch;
  min-width:0;
}
.mob-nav-side-left{padding-right:44px;}
.mob-nav-side-right{padding-left:44px;}

/* Individual tab */
.mob-tab{
  flex:1;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:3px;padding:6px 2px;
  text-decoration:none;
  background:none;border:none;cursor:pointer;
  color:var(--color-text);
  opacity:.55;
  font-size:10px;font-weight:600;letter-spacing:.003em;
  border-radius:var(--r-sm);
  transition:color var(--ease);
  position:relative;
  min-width:0;
}
.mob-tab:hover{color:var(--color-text);}
.mob-tab.active{color:var(--color-accent);opacity:1;}

/* Active underline pip at very top of tab */
.mob-tab.active::before{
  content:'';position:absolute;top:-6px;left:50%;transform:translateX(-50%);
  width:30px;height:3px;border-radius:99px;
  background:var(--color-accent);
}

.mob-tab-icon{
  width:22px;height:22px;
  display:flex;align-items:center;justify-content:center;
  font-size:17px;
  transition:transform var(--ease);
}
.mob-tab.active .mob-tab-icon{transform:translateY(-1px);}

/* Ticket badge on tab */
.mob-tab-badge{
  position:absolute;top:2px;right:calc(50% - 18px);
  background:var(--color-accent);color:var(--color-accent-contrast);
  font-size:9px;font-weight:700;padding:1px 5px;border-radius:999px;
  border:2px solid var(--color-bg);min-width:16px;text-align:center;
}

/* MORE tab */
.mob-tab-more{
  flex:1;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:3px;padding:6px 2px;
  background:none;border:none;cursor:pointer;
  color:var(--color-text);
  opacity:.55;
  font-size:10px;font-weight:600;letter-spacing:.003em;
  border-radius:var(--r-sm);
  transition:color var(--ease);
  position:relative;
}
.mob-tab-more:hover{color:var(--color-text);}
.mob-tab-more .mob-tab-icon{
  width:22px;height:22px;font-size:17px;
  transition:transform var(--ease);
}
.mob-tab-more.open{color:var(--color-accent);opacity:1;}
.mob-tab-more.open::before{
  content:'';position:absolute;top:-6px;left:50%;transform:translateX(-50%);
  width:30px;height:3px;border-radius:99px;background:var(--color-accent);
}
.mob-tab-more.open .mob-tab-icon{transform:translateY(-1px);}

.mob-center-action{
  position:absolute;
  left:50%;
  top:-12px;
  transform:translateX(-50%);
  width:78px;
  height:78px;
  border-radius:999px;
  border:6px solid var(--color-bg);
  background:var(--color-accent);
  color:var(--color-accent-contrast);
  display:inline-flex;
  align-items:center;
  justify-content:center;
  text-decoration:none;
  box-shadow:0 10px 22px rgba(20,40,29,.32);
  z-index:2;
  transition:transform var(--ease), box-shadow var(--ease), background var(--ease);
}
.mob-center-action:hover{
  color:var(--color-accent-contrast);
  transform:translateX(-50%) translateY(-2px);
  box-shadow:0 16px 32px rgba(20,40,29,.42);
}
.mob-center-action:active{transform:translateX(-50%) translateY(1px);}
.mob-center-action i{font-size:28px;line-height:1;}

.mob-tab-label,
.mob-tab-more-label{
  line-height:1;
  white-space:nowrap;
}

@media(max-width:380px){
  .mob-bottom-nav{left:8px;right:8px;height:70px;border-radius:22px;}
  .mob-center-action{width:72px;height:72px;top:-10px;border-width:6px;}
  .mob-nav-side-left{padding-right:38px;}
  .mob-nav-side-right{padding-left:38px;}
  .mob-tab,.mob-tab-more{font-size:9px;}
}

/* ──────────────────────────────────────────
  MOBILE DRAWER MENU (opens from right)
────────────────────────────────────────── */
.mob-overlay{
  display:none;position:fixed;inset:0;
  background:rgba(20,40,29,.38);
  backdrop-filter:blur(3px);-webkit-backdrop-filter:blur(3px);
  z-index:960;opacity:0;transition:opacity var(--ease);
}
.mob-overlay.show{display:block;opacity:1;}

.mob-sheet{
  position:fixed;
  top:0;
  right:0;
  bottom:0;
  left:auto;
  z-index:970;
  background:var(--color-bg);
  border-radius:18px 0 0 18px;
  border:1.5px solid var(--color-border);
  border-right:none;
  box-shadow:var(--sh-lg);
  padding:0;
  width:min(86vw,380px);
  max-width:100%;
  height:100vh;
  max-height:100vh;
  display:flex;flex-direction:column;
  transform:translateX(100%);
  transition:transform var(--spring);
  overflow-y:auto;
  -webkit-overflow-scrolling:touch;
  overscroll-behavior:contain;
  scrollbar-width:thin;
  scrollbar-color:var(--color-border) var(--color-bg);
}
.mob-sheet.show{transform:translateX(0);}
.mob-sheet::-webkit-scrollbar{width:6px;}
.mob-sheet::-webkit-scrollbar-track{background:var(--color-bg);}
.mob-sheet::-webkit-scrollbar-thumb{background:var(--color-border);border-radius:999px;}

@media(max-width:991px){
  .mob-sheet{max-height:100vh;height:100vh;}
}

@media(min-width:992px){
  .mob-overlay,
  .mob-sheet{display:none!important;}
}

/* Handle */
.mob-sheet-handle{
  display:none;
}

/* Sheet header: MENU label + X  — like image 2 bottom */
.mob-sheet-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 16px 12px;flex-shrink:0;
  border-bottom:1px solid var(--color-border);
  position:sticky;top:0;z-index:2;background:var(--color-bg);
}
.mob-sheet-title{
  font-size:11px;font-weight:700;letter-spacing:.09em;
  text-transform:uppercase;color:var(--color-text);opacity:.65;
}
.mob-sheet-close{
  width:28px;height:28px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  background:var(--color-hover-bg);border:none;
  color:var(--color-text);cursor:pointer;font-size:14px;
  transition:background var(--ease);
}
.mob-sheet-close:hover{background:var(--color-border);}

/* Scrollable body */
.mob-sheet-body{
  overflow:visible;flex:0 0 auto;min-height:auto;
  padding:10px 12px calc(16px + env(safe-area-inset-bottom, 0px));
}

#mobile-sidebar{
  overflow-y:auto;
  -webkit-overflow-scrolling:touch;
  overscroll-behavior:contain;
  scrollbar-width:thin;
  scrollbar-color:var(--color-border) var(--color-bg);
}
#mobile-sidebar::-webkit-scrollbar{width:6px;}
#mobile-sidebar::-webkit-scrollbar-track{background:var(--color-bg);}
#mobile-sidebar::-webkit-scrollbar-thumb{background:var(--color-border);border-radius:999px;}

/* Sheet nav item */
.mob-sheet-row{
  display:flex;align-items:center;gap:14px;
  padding:12px 10px;
  border-radius:var(--r-md);
  color:var(--color-text);text-decoration:none;
  font-size:14px;font-weight:600;letter-spacing:-.01em;
  border:1.5px solid transparent;
  cursor:pointer;
  /* stagger in */
  opacity:0;transform:translateY(10px);
  transition:opacity .2s,transform .2s,background var(--ease),border-color var(--ease);
}
.mob-sheet.show .mob-sheet-row{opacity:1;transform:translateY(0);}
.mob-sheet.show .mob-sheet-row:nth-child(1){transition-delay:.03s;}
.mob-sheet.show .mob-sheet-row:nth-child(2){transition-delay:.06s;}
.mob-sheet.show .mob-sheet-row:nth-child(3){transition-delay:.09s;}
.mob-sheet.show .mob-sheet-row:nth-child(4){transition-delay:.12s;}
.mob-sheet.show .mob-sheet-row:nth-child(5){transition-delay:.15s;}
.mob-sheet.show .mob-sheet-row:nth-child(6){transition-delay:.18s;}
.mob-sheet.show .mob-sheet-row:nth-child(7){transition-delay:.21s;}
.mob-sheet.show .mob-sheet-row:nth-child(8){transition-delay:.24s;}
.mob-sheet.show .mob-sheet-row:nth-child(9){transition-delay:.27s;}
.mob-sheet-row:hover{background:var(--color-hover-bg);border-color:var(--color-border);}
.mob-sheet-row.active{
  background:var(--color-accent);color:var(--color-accent-contrast);
  border-color:transparent;
}

.mob-sheet-icon{
  width:38px;height:38px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:15px;border-radius:var(--r-sm);
  background:var(--color-hover-bg);color:var(--color-accent);
}
.mob-sheet-row.active .mob-sheet-icon{background:var(--color-hover-bg);color:var(--color-accent-contrast);}

.mob-sheet-divider{
  height:1px;margin:6px 4px;
  background:linear-gradient(90deg,transparent,var(--color-border) 50%,transparent);
}

/* Currency chips in sheet */
.mob-curr-row{padding:10px 10px 4px;}
.mob-curr-label{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--color-text);opacity:.65;margin-bottom:8px;}
.mob-curr-chips{display:flex;flex-wrap:wrap;gap:6px;}
.mob-curr-chip{
  display:inline-flex;align-items:center;
  padding:6px 13px;border-radius:999px;
  font-size:12px;font-weight:700;text-decoration:none;
  border:1.5px solid var(--color-border);
  background:var(--color-hover-bg);color:var(--color-text);
  transition:background var(--ease),color var(--ease);
}
.mob-curr-chip.selected{background:var(--color-accent);color:var(--color-accent-contrast);border-color:transparent;}
</style>

