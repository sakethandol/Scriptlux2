<script>
(function(){
  'use strict';

  /* ── Desktop sidebar ── */
  var sidebar     = document.getElementById('authSidebar');
  var collapseBtn = document.getElementById('sidebarCollapseBtn');
  var currToggle  = document.getElementById('currencyToggle');
  var currMenu    = document.getElementById('currencyMenu');
  var dtbCurrBtn  = document.getElementById('dtbCurrBtn');
  var dtbCurrMenu = document.getElementById('dtbCurrMenu');
  var STORE       = 'auth_sidebar_collapsed';

  /* ── Mobile sheet ── */
  var mobMenuBtn  = document.getElementById('mobMenuBtn');
  var mobMoreBtn  = document.getElementById('mobMoreBtn');
  var sheet       = document.getElementById('mobSheet');
  var overlay     = document.getElementById('mobOverlay');
  var sheetClose  = document.getElementById('mobSheetClose');

  function isMobile(){ return window.innerWidth <= 991; }

  /* Desktop collapse */
  function syncDesktop(){
    if(!sidebar) return;
    var c = localStorage.getItem(STORE) === '1';
    sidebar.classList.toggle('collapsed', c);
    document.body.classList.toggle('auth-sidebar-open',     !c);
    document.body.classList.toggle('auth-sidebar-collapsed', c);
  }
  function resetMobile(){
    document.body.classList.remove('auth-sidebar-open','auth-sidebar-collapsed');
  }
  function init(){ isMobile() ? resetMobile() : syncDesktop(); }
  init();

  if(collapseBtn && sidebar){
    collapseBtn.addEventListener('click', function(){
      if(isMobile()) return;
      var c = sidebar.classList.toggle('collapsed');
      localStorage.setItem(STORE, c ? '1' : '0');
      document.body.classList.toggle('auth-sidebar-open',     !c);
      document.body.classList.toggle('auth-sidebar-collapsed', c);
    });
  }

  /* Desktop dropdowns */
  if(currToggle && currMenu){
    currToggle.addEventListener('click', function(e){
      e.preventDefault(); e.stopPropagation();
      currMenu.classList.toggle('show');
    });
  }
  if(dtbCurrBtn && dtbCurrMenu){
    dtbCurrBtn.addEventListener('click', function(e){
      e.stopPropagation();
      dtbCurrMenu.classList.toggle('show');
    });
  }
  document.addEventListener('click', function(){
    if(currMenu)    currMenu.classList.remove('show');
    if(dtbCurrMenu) dtbCurrMenu.classList.remove('show');
  });

  /* Mobile sheet open / close */
  function openSheet(){
    sheet.classList.add('show');
    overlay.classList.add('show');
    if(mobMoreBtn) mobMoreBtn.classList.add('open');
    if(mobMenuBtn) mobMenuBtn.style.opacity = '.6';
    document.body.style.overflow = 'hidden';
  }
  function closeSheet(){
    sheet.classList.remove('show');
    overlay.classList.remove('show');
    if(mobMoreBtn) mobMoreBtn.classList.remove('open');
    if(mobMenuBtn) mobMenuBtn.style.opacity = '';
    document.body.style.overflow = '';
  }

  /* Both the top-bar hamburger AND the bottom More tab open the sheet */
  if(mobMenuBtn) mobMenuBtn.addEventListener('click', function(e){ e.stopPropagation(); openSheet(); });
  if(mobMoreBtn) mobMoreBtn.addEventListener('click', function(e){
    e.stopPropagation();
    sheet.classList.contains('show') ? closeSheet() : openSheet();
  });
  if(overlay)    overlay.addEventListener('click', closeSheet);
  if(sheetClose) sheetClose.addEventListener('click', closeSheet);

  /* Close on item tap */
  if(sheet){
    sheet.querySelectorAll('.mob-sheet-row').forEach(function(el){
      el.addEventListener('click', function(){
        var href = el.getAttribute('href');
        if(href && href !== '#') closeSheet();
      });
    });
  }

  document.addEventListener('keydown', function(e){
    if(e.key !== 'Escape') return;
    closeSheet();
    if(currMenu)    currMenu.classList.remove('show');
    if(dtbCurrMenu) dtbCurrMenu.classList.remove('show');
  });

  var rt;
  window.addEventListener('resize', function(){
    clearTimeout(rt);
    rt = setTimeout(function(){ closeSheet(); init(); }, 80);
  });
})();
</script>

