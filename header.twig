{% if user['auth'] %}

<style>
  :root {

    --sidebar-w: 240px;
    --sidebar-collapsed-w: 58px;
    --desktop-topbar-h: 72px;
  }

  /* ── LAYOUT WRAPPER ── */
  .app-layout {
    display: flex;
    min-height: 100vh;
    position: relative;
  }

  /* ── SIDEBAR ── */
  .auth-sidebar {
    width: var(--sidebar-w);
    min-width: var(--sidebar-w);
    background: var(--color-bg);
    border-right: 1px solid var(--color-border);
    box-shadow: 8px 0 24px var(--color-border);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: var(--desktop-topbar-h);
    left: 0;
    height: calc(100vh - var(--desktop-topbar-h));
    z-index: 1040;
    transition: width 0.25s ease, min-width 0.25s ease, transform 0.25s ease;
    overflow: hidden;
    overflow-x: hidden;
  }

  .auth-sidebar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--color-hover-bg), transparent);
    pointer-events: none;
  }

  .auth-sidebar.collapsed {
    width: var(--sidebar-collapsed-w);
    min-width: var(--sidebar-collapsed-w);
  }

  /* Brand / Logo row */
  .sidebar-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 14px;
    border-bottom: 1px solid var(--color-border);
    min-height: 72px;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .sidebar-brand a {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--color-text);
    font-weight: 800;
    font-size: 14px;
    white-space: nowrap;
    min-width: 0;
    flex: 1;
    overflow: hidden;
  }

  .sidebar-brand img {
    max-height: 34px;
    flex-shrink: 0;
  }

  .sidebar-brand-name {
    overflow: hidden;
    transition: opacity 0.2s, max-width 0.25s;
    max-width: 160px;
    letter-spacing: -0.02em;
  }

  .auth-sidebar.collapsed .sidebar-brand-name {
    opacity: 0;
    max-width: 0;
  }

  .auth-sidebar.collapsed .sidebar-brand {
    justify-content: center;
    padding-left: 8px;
    padding-right: 8px;
  }

  .auth-sidebar.collapsed .sidebar-brand a {
    justify-content: center;
    flex: 0 0 auto;
  }

  .sidebar-collapse-btn {
    background: transparent;
    border: 1px solid var(--color-border);
    cursor: pointer;
    color: var(--color-text);
    opacity: 0.72;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 7px;
    border-radius: 10px;
    flex-shrink: 0;
    transition: opacity 0.2s, background 0.15s, transform 0.25s, box-shadow 0.2s;
  }

  .sidebar-collapse-btn:hover {
    opacity: 1;
    background: var(--color-hover-bg);
    box-shadow: 0 8px 18px var(--color-border);
  }

  .auth-sidebar.collapsed .sidebar-collapse-btn {
    transform: rotate(180deg);
  }

  /* Nav items */
  .sidebar-nav {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 14px 10px 10px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 0;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
    position: relative;
    z-index: 1;
  }

  .sidebar-nav::-webkit-scrollbar { width: 5px; }
  .sidebar-nav::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 999px;
  }

  .sidebar-nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 12px;
    border-radius: 14px;
    color: var(--color-text);
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    transition: background 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease, color 0.18s ease;
    cursor: pointer;
    position: relative;
    border: 1px solid transparent;
    background: var(--color-bg);
    box-shadow: inset 0 1px 0 var(--color-border);
  }

  .sidebar-nav-item:hover {
    background: var(--color-hover-bg);
    color: var(--color-text);
    text-decoration: none;
    transform: translateX(3px);
    box-shadow: 0 12px 24px var(--color-border);
  }

  .sidebar-nav-item.active {
    background: var(--color-accent) !important;
    color: var(--color-accent-contrast) !important;
    box-shadow: 0 12px 28px var(--color-border);
    border-color: var(--color-border);
    transform: translateX(4px);
  }

  .sidebar-nav-icon {
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    flex-shrink: 0;
    border-radius: 10px;
    background: var(--color-hover-bg);
    color: var(--color-accent);
  }

  .sidebar-nav-label {
    flex: 1;
    overflow: hidden;
    transition: opacity 0.2s, max-width 0.25s;
    max-width: 160px;
    letter-spacing: -0.01em;
  }

  .auth-sidebar.collapsed .sidebar-nav-label {
    opacity: 0;
    max-width: 0;
  }

  .auth-sidebar.collapsed .sidebar-nav-item {
    justify-content: center;
    gap: 0;
    padding-left: 0;
    padding-right: 0;
    margin-inline: 6px;
  }

  .auth-sidebar.collapsed .sidebar-nav-item:hover {
    transform: translateX(0) scale(1.02);
  }

  .auth-sidebar.collapsed .sidebar-nav-icon {
    width: 34px;
    height: 34px;
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    box-shadow: 0 10px 18px var(--color-border);
  }

  .auth-sidebar.collapsed .sidebar-nav-item.active .sidebar-nav-icon {
    background: var(--color-accent-contrast);
    color: var(--color-accent);
  }

  .auth-sidebar.collapsed .sidebar-nav-item::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 24px;
    border-radius: 999px;
    background: transparent;
    transition: background 0.18s ease;
  }

  .auth-sidebar.collapsed .sidebar-nav-item.active::before {
    background: var(--color-accent-contrast);
  }

  .auth-sidebar.collapsed .sidebar-nav-item:hover::before {
    background: var(--color-hover-bg);
  }

  .auth-sidebar.collapsed .sidebar-nav-item::after {
    left: calc(var(--sidebar-collapsed-w) + 10px);
  }

  .auth-sidebar.collapsed .sidebar-balance-row {
    justify-content: center;
    padding-left: 0;
    padding-right: 0;
    margin-inline: 6px;
  }

  .auth-sidebar.collapsed .sidebar-balance-row .sidebar-nav-icon {
    width: 34px;
    height: 34px;
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    box-shadow: 0 10px 18px var(--color-border);
  }

  .auth-sidebar.collapsed .sidebar-balance-row::after {
    content: attr(data-balance-label);
    position: absolute;
    left: calc(var(--sidebar-collapsed-w) + 10px);
    top: 50%;
    transform: translateY(-50%);
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    padding: 5px 10px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 700;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease;
  }

  .auth-sidebar.collapsed .sidebar-balance-row:hover::after {
    opacity: 1;
  }

  .sidebar-badge {
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    font-size: 10px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 20px;
    flex-shrink: 0;
    margin-left: auto;
    transition: opacity 0.2s;
    box-shadow: 0 8px 16px var(--color-border);
  }

  .sidebar-nav-item.active .sidebar-badge {
    background: var(--color-accent-contrast);
    color: var(--color-accent);
  }

  .auth-sidebar.collapsed .sidebar-badge {
    opacity: 0;
    pointer-events: none;
  }

  .sidebar-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border), transparent);
    margin: 6px 10px;
    flex-shrink: 0;
  }

  /* Bottom section */
  .sidebar-bottom {
    border-top: 1px solid var(--color-border);
    padding: 12px 10px 14px;
    display: none;
    gap: 8px;
    flex-shrink: 0;
    position: sticky;
    bottom: 0;
    z-index: 1;
    background: var(--color-bg);
    backdrop-filter: blur(10px);
  }

  .sidebar-bottom-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sidebar-bottom::before {
    content: '';
    position: absolute;
    inset: 10px 10px auto 10px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border), transparent);
  }

  .sidebar-balance-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    overflow: hidden;
    border-radius: 14px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
  }

  .sidebar-balance-pill {
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    font-size: 12px;
    font-weight: 700;
    padding: 5px 11px;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.2s;
    box-shadow: 0 10px 20px var(--color-border);
  }

  .auth-sidebar.collapsed .sidebar-balance-pill {
    opacity: 0;
    pointer-events: none;
  }

  /* Currency dropdown inside sidebar */
  .sidebar-dropdown {
    position: relative;
  }

  .sidebar-dropdown-menu {
    display: none;
    position: absolute;
    bottom: calc(100% + 6px);
    left: 0;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    min-width: 130px;
    z-index: 200;
    padding: 6px 0;
    box-shadow: 0 16px 28px var(--color-border);
    backdrop-filter: blur(14px);
  }

  .sidebar-dropdown-menu.show { display: block; }

  .sidebar-dropdown-menu a {
    display: block;
    padding: 9px 14px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    transition: background 0.12s, color 0.12s;
  }

  .sidebar-dropdown-menu a:hover {
    background: var(--color-hover-bg);
  }

  /* Tooltip for collapsed state */
  .auth-sidebar.collapsed .sidebar-nav-item,
  .auth-sidebar.collapsed .sidebar-balance-row {
    position: relative;
  }

  .auth-sidebar.collapsed .sidebar-nav-item::after {
    content: attr(data-tooltip);
    position: absolute;
    left: calc(var(--sidebar-collapsed-w) - 2px);
    top: 50%;
    transform: translateY(-50%);
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    padding: 5px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
    z-index: 300;
  }

  .auth-sidebar.collapsed .sidebar-nav-item:hover::after {
    opacity: 1;
  }

  /* ── MAIN CONTENT PUSH ── */
  .app-content {
    flex: 1;
    margin-left: var(--sidebar-w);
    transition: margin-left 0.25s ease;
    min-width: 0;
  }

  .auth-sidebar.collapsed ~ .app-content {
    margin-left: var(--sidebar-collapsed-w);
  }

  body.auth-sidebar-open {
    padding-left: var(--sidebar-w);
    padding-top: var(--desktop-topbar-h);
    transition: padding-left 0.25s ease, padding-top 0.25s ease;
  }

  body.auth-sidebar-collapsed {
    padding-left: var(--sidebar-collapsed-w);
    padding-top: var(--desktop-topbar-h);
    transition: padding-left 0.25s ease, padding-top 0.25s ease;
  }

  .desktop-topbar {
    display: none;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--desktop-topbar-h);
    padding: 0 22px;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    z-index: 1035;
    box-shadow: 0 8px 24px var(--color-border);
  }

  .desktop-topbar-left {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  .desktop-topbar-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 800;
    font-size: 15px;
    min-width: 0;
  }

  .desktop-topbar-brand img {
    max-height: 34px;
    flex-shrink: 0;
  }

  .desktop-topbar-tagline {
    display: inline-flex;
    align-items: center;
    padding: 5px 10px;
    border-radius: 999px;
    background: var(--color-hover-bg);
    color: var(--color-text);
    font-size: 12px;
    font-weight: 700;
    white-space: nowrap;
  }

  .desktop-topbar-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .desktop-topbar-action,
  .desktop-topbar-currency {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 12px;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    text-decoration: none;
    font-weight: 700;
    font-size: 13px;
    transition: background 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
  }

  .desktop-topbar-action:hover,
  .desktop-topbar-currency:hover {
    background: var(--color-hover-bg);
    color: var(--color-text);
    transform: translateY(-1px);
    box-shadow: 0 10px 20px var(--color-border);
  }

  .desktop-topbar-balance {
    display: inline-flex;
    align-items: center;
    padding: 9px 13px;
    border-radius: 12px;
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    font-weight: 800;
    font-size: 13px;
    box-shadow: 0 10px 20px var(--color-border);
    white-space: nowrap;
  }

  .desktop-topbar .dropdown {
    position: relative;
  }

  .desktop-topbar .dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 140px;
    padding: 6px 0;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    background: var(--color-bg);
    box-shadow: 0 16px 28px var(--color-border);
  }

  .desktop-topbar .dropdown-menu.show {
    display: block;
  }

  .desktop-topbar .dropdown-menu a {
    display: block;
    padding: 9px 14px;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 600;
  }

  .desktop-topbar .dropdown-menu a:hover {
    background: var(--color-hover-bg);
  }

  /* ── MOBILE OVERLAY ── */
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--color-text);
    opacity: 0.18;
    z-index: 1039;
  }

