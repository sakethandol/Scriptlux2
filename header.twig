<script>
(function () {
  var sidebar = document.getElementById('authSidebar');
  var overlay = document.getElementById('sidebarOverlay');
  var hamburger = document.getElementById('sidebarHamburger');
  var collapseBtn = document.getElementById('sidebarCollapseBtn');
  var currencyToggle = document.getElementById('currencyToggle');
  var currencyMenu = document.getElementById('currencyMenu');

  var STORAGE_KEY = 'sidebar_collapsed';
  var isCollapsed = localStorage.getItem(STORAGE_KEY) === '1';

  function isMobile() { return window.innerWidth <= 991; }

  function syncBodyState() {
    document.body.classList.remove('auth-sidebar-open', 'auth-sidebar-collapsed');

    if (isMobile()) {
      return;
    }

    if (sidebar.classList.contains('collapsed')) {
      document.body.classList.add('auth-sidebar-collapsed');
    } else {
      document.body.classList.add('auth-sidebar-open');
    }
  }

  // Restore collapse state on desktop load
  if (!isMobile() && isCollapsed) {
    sidebar.classList.add('collapsed');
  }
  syncBodyState();

  // Desktop collapse toggle
  if (collapseBtn) {
    collapseBtn.addEventListener('click', function () {
      if (isMobile()) return;
      isCollapsed = !sidebar.classList.contains('collapsed');
      sidebar.classList.toggle('collapsed', isCollapsed);
      localStorage.setItem(STORAGE_KEY, isCollapsed ? '1' : '0');
      syncBodyState();
    });
  }

  // Mobile hamburger open
  if (hamburger) {
    hamburger.addEventListener('click', function () {
      sidebar.classList.add('mobile-open');
      overlay.classList.add('show');
      document.body.style.overflow = 'hidden';
    });
  }

  function closeMobile() {
    sidebar.classList.remove('mobile-open');
    overlay.classList.remove('show');
    document.body.style.overflow = '';
  }

  if (overlay) {
    overlay.addEventListener('click', closeMobile);
  }

  // Close mobile sidebar on nav link click
  var navItems = sidebar.querySelectorAll('.sidebar-nav-item');
  navItems.forEach(function (item) {
    item.addEventListener('click', function () {
      if (isMobile()) closeMobile();
    });
  });

  // Currency dropdown
  if (currencyToggle && currencyMenu) {
    currencyToggle.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      var isOpen = currencyMenu.classList.contains('show');
      currencyMenu.classList.toggle('show', !isOpen);
    });

    document.addEventListener('click', function () {
      currencyMenu.classList.remove('show');
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') currencyMenu.classList.remove('show');
    });
  }

  // Reset on resize
  window.addEventListener('resize', function () {
    if (!isMobile()) {
      closeMobile();
    }
    syncBodyState();
  });
})();
</script>

