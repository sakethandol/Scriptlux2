  // Mobile Menu
 // ...existing code...
function toggleMobileMenu() {
  const sidebar = document.getElementById('mobile-sidebar');
  const overlay = document.getElementById('mobile-overlay');
  
  // Check current state
  const isOpen = sidebar.style.transform === 'translateX(0px)' || sidebar.style.transform === 'translateX(0%)';
  
  if (!isOpen) {
    // Open menu
    sidebar.style.transform = 'translateX(0)';
    overlay.classList.remove('d-none');
    setTimeout(() => overlay.classList.add('opacity-100'), 10);
    document.body.style.overflow = 'hidden';
  } else {
    // Close menu
    sidebar.style.transform = 'translateX(100%)';
    overlay.classList.remove('opacity-100');
    setTimeout(() => overlay.classList.add('d-none'), 500);
    document.body.style.overflow = 'auto';
  }
}
// ...existing code...

  // Scrolled shadow state
  window.addEventListener('scroll', () => {
    document.getElementById('main-nav').classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });
</script>
<script>
  document.querySelectorAll('.dropdown').forEach(function(dropdown) {
    const btn = dropdown.querySelector('[data-bs-toggle="dropdown"]');
    const menu = dropdown.querySelector('.dropdown-menu');

    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      menu.classList.toggle('show');
    });

    document.addEventListener('click', function() {
      menu.classList.remove('show');
    });

    menu.addEventListener('click', function(e) {
      e.stopPropagation();
    });
  });
</script>
